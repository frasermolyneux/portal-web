@model XtremeIdiots.Portal.Web.ViewModels.GlobalSettingsViewModel

@{
    ViewData["Title"] = "Global Settings";
}

<div class="wrapper wrapper-content animated fadeInRight">
    <form asp-action="Index" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="row">
            <div class="col-lg-12">

                @* Agent Defaults *@
                <div class="ibox">
                    <div class="ibox-title">
                        <h5><i class="fa-solid fa-fw fa-robot" aria-hidden="true"></i> Agent Defaults</h5>
                    </div>
                    <div class="ibox-content">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="AgentPollIntervalMs" class="form-label"></label>
                                    <input asp-for="AgentPollIntervalMs" class="form-control" type="number" />
                                    <span asp-validation-for="AgentPollIntervalMs" class="text-danger"></span>
                                    <small class="form-text text-muted">How frequently agents check for new log
                                        data.</small>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label asp-for="AgentStatusPublishIntervalSeconds" class="form-label"></label>
                                        <input asp-for="AgentStatusPublishIntervalSeconds" class="form-control"
                                               type="number" />
                                        <span asp-validation-for="AgentStatusPublishIntervalSeconds"
                                              class="text-danger"></span>
                                        <small class="form-text text-muted">How often agents publish server status
                                            snapshots.</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label asp-for="AgentName" class="form-label"></label>
                                            <input asp-for="AgentName" class="form-control" maxlength="120" />
                                            <span asp-validation-for="AgentName" class="text-danger"></span>
                                            <small class="form-text text-muted">Prefix prepended to automated broadcast
                                                messages. Use CoD color tokens if desired.</small>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="mb-3">
                                                <label asp-for="AgentRconSyncIntervalSeconds" class="form-label"></label>
                                                <input asp-for="AgentRconSyncIntervalSeconds" class="form-control" type="number" />
                                                <span asp-validation-for="AgentRconSyncIntervalSeconds" class="text-danger"></span>
                                                <small class="form-text text-muted">How often agents query game servers via
                                                    RCON/Query.</small>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="mb-3">
                                                    <label asp-for="AgentOffsetSaveIntervalSeconds" class="form-label"></label>
                                                    <input asp-for="AgentOffsetSaveIntervalSeconds" class="form-control"
                                                           type="number" />
                                                    <span asp-validation-for="AgentOffsetSaveIntervalSeconds"
                                                          class="text-danger"></span>
                                                    <small class="form-text text-muted">How often agents persist log file read
                                                        position.</small>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    @* Ban File Sync Defaults *@
                                    <div class="ibox">
                                        <div class="ibox-title">
                                            <h5><i class="fa-solid fa-fw fa-ban" aria-hidden="true"></i> Ban File Sync Defaults</h5>
                                        </div>
                                        <div class="ibox-content">
                                            <div class="row">
                                                <div class="col-md-6">
                                                    <div class="mb-3">
                                                        <label asp-for="BanFileSyncCheckIntervalSeconds" class="form-label"></label>
                                                        <input asp-for="BanFileSyncCheckIntervalSeconds" class="form-control"
                                                               type="number" />
                                                        <span asp-validation-for="BanFileSyncCheckIntervalSeconds"
                                                              class="text-danger"></span>
                                                        <small class="form-text text-muted">How often agents check ban files for new
                                                            entries.</small>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        @* Moderation Defaults *@
                                        <div class="ibox">
                                            <div class="ibox-title">
                                                <h5><i class="fa-solid fa-fw fa-shield" aria-hidden="true"></i> Chat Moderation Defaults</h5>
                                            </div>
                                            <div class="ibox-content">
                                                <div class="row">
                                                    <div class="col-md-6">
                                                        <div class="mb-3">
                                                            <label asp-for="ModerationHateSeverityThreshold" class="form-label"></label>
                                                            <select asp-for="ModerationHateSeverityThreshold" class="form-select"
                                                                    asp-items="XtremeIdiots.Portal.Web.ViewModels.GlobalSettingsViewModel.BuildSeverityOptions(false)"></select>
                                                            <span asp-validation-for="ModerationHateSeverityThreshold"
                                                                  class="text-danger"></span>
                                                            <small class="form-text text-muted">Minimum hate severity (0–6) that triggers
                                                                moderation, or Disabled.</small>
                                                            </div>
                                                        </div>
                                                        <div class="col-md-6">
                                                            <div class="mb-3">
                                                                <label asp-for="ModerationViolenceSeverityThreshold" class="form-label"></label>
                                                                <select asp-for="ModerationViolenceSeverityThreshold" class="form-select"
                                                                        asp-items="XtremeIdiots.Portal.Web.ViewModels.GlobalSettingsViewModel.BuildSeverityOptions(false)"></select>
                                                                <span asp-validation-for="ModerationViolenceSeverityThreshold"
                                                                      class="text-danger"></span>
                                                                <small class="form-text text-muted">Minimum violence severity (0–6) that triggers
                                                                    moderation, or Disabled.</small>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="row">
                                                            <div class="col-md-6">
                                                                <div class="mb-3">
                                                                    <label asp-for="ModerationSexualSeverityThreshold" class="form-label"></label>
                                                                    <select asp-for="ModerationSexualSeverityThreshold" class="form-select"
                                                                            asp-items="XtremeIdiots.Portal.Web.ViewModels.GlobalSettingsViewModel.BuildSeverityOptions(false)"></select>
                                                                    <span asp-validation-for="ModerationSexualSeverityThreshold"
                                                                          class="text-danger"></span>
                                                                    <small class="form-text text-muted">Minimum sexual severity (0–6) that triggers
                                                                        moderation, or Disabled.</small>
                                                                    </div>
                                                                </div>
                                                                <div class="col-md-6">
                                                                    <div class="mb-3">
                                                                        <label asp-for="ModerationSelfHarmSeverityThreshold" class="form-label"></label>
                                                                        <select asp-for="ModerationSelfHarmSeverityThreshold" class="form-select"
                                                                                asp-items="XtremeIdiots.Portal.Web.ViewModels.GlobalSettingsViewModel.BuildSeverityOptions(false)"></select>
                                                                        <span asp-validation-for="ModerationSelfHarmSeverityThreshold"
                                                                              class="text-danger"></span>
                                                                        <small class="form-text text-muted">Minimum self-harm severity (0–6) that triggers
                                                                            moderation, or Disabled.</small>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <div class="row">
                                                                    <div class="col-md-6">
                                                                        <div class="mb-3">
                                                                            <label asp-for="ModerationMinMessageLength" class="form-label"></label>
                                                                            <input asp-for="ModerationMinMessageLength" class="form-control" type="number" />
                                                                            <span asp-validation-for="ModerationMinMessageLength" class="text-danger"></span>
                                                                            <small class="form-text text-muted">Messages shorter than this skip content safety
                                                                                analysis.</small>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>

                                                            @* Event Processing Defaults *@
                                                            <div class="ibox">
                                                                <div class="ibox-title">
                                                                    <h5><i class="fa-solid fa-fw fa-timeline" aria-hidden="true"></i> Event Processing Defaults</h5>
                                                                </div>
                                                                <div class="ibox-content">
                                                                    <div class="row">
                                                                        <div class="col-md-6">
                                                                            <div class="mb-3">
                                                                                <label asp-for="EventsStaleThresholdSeconds" class="form-label"></label>
                                                                                <input asp-for="EventsStaleThresholdSeconds" class="form-control" type="number" />
                                                                                <span asp-validation-for="EventsStaleThresholdSeconds" class="text-danger"></span>
                                                                                <small class="form-text text-muted">Events older than this are logged as
                                                                                    warnings.</small>
                                                                                </div>
                                                                            </div>
                                                                            <div class="col-md-6">
                                                                                <div class="mb-3">
                                                                                    <label asp-for="EventsPlayerCacheExpirationSeconds" class="form-label"></label>
                                                                                    <input asp-for="EventsPlayerCacheExpirationSeconds" class="form-control"
                                                                                           type="number" />
                                                                                    <span asp-validation-for="EventsPlayerCacheExpirationSeconds"
                                                                                          class="text-danger"></span>
                                                                                    <small class="form-text text-muted">How long player data is cached before
                                                                                        re-fetch.</small>
                                                                                    </div>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                    </div>

                                                                    <div class="ibox">
                                                                        <div class="ibox-title d-flex justify-content-between align-items-center">
                                                                            <h5 class="mb-0"><i class="fa-solid fa-fw fa-face-laugh" aria-hidden="true"></i> !fu Global Funny Messages</h5>
                                                                            <button type="button" class="btn btn-outline-secondary btn-sm" id="add-global-funny-message">
                                                                                <i class="fa-solid fa-fw fa-plus" aria-hidden="true"></i> Add message
                                                                            </button>
                                                                        </div>
                                                                        <div class="ibox-content">
                                                                            <p class="mb-2">These are the fallback messages used when server-specific funny messages are empty.</p>
                                                                            <p class="text-muted mb-3">Use <code>{name}</code> token for resolved player name. CoD color codes are supported in preview.</p>

                                                                            <p id="global-funny-messages-empty" class="text-muted @(Model.FunnyMessages.Count > 0 ? "d-none" : string.Empty)">
                                                                                No global funny messages configured.
                                                                            </p>

                                                                            <div id="global-funny-messages-container">
                                                                                @for (var i = 0; i < Model.FunnyMessages.Count; i++)
                                                                                {
                                                                                    <div class="border rounded p-3 mb-3" data-global-funny-row>
                                                                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                                                                            <div class="form-check form-switch mb-0">
                                                                                                <input type="hidden" data-field="enabled-hidden" name="FunnyMessages[@i].Enabled" value="false" />
                                                                                                @if (Model.FunnyMessages[i].Enabled)
                                                                                                {
                                                                                                    <input class="form-check-input" data-field="enabled" type="checkbox" name="FunnyMessages[@i].Enabled" value="true" id="FunnyMessages_@(i)__Enabled" checked="checked" />
                                                                                                }
                                                                                                else
                                                                                                {
                                                                                                    <input class="form-check-input" data-field="enabled" type="checkbox" name="FunnyMessages[@i].Enabled" value="true" id="FunnyMessages_@(i)__Enabled" />
                                                                                                }
                                                                                                <label class="form-check-label" data-field="enabled-label" for="FunnyMessages_@(i)__Enabled">Enabled</label>
                                                                                            </div>
                                                                                            <div class="btn-group btn-group-sm" role="group" aria-label="Funny message ordering">
                                                                                                <button type="button" class="btn btn-outline-secondary" data-action="move-up" aria-label="Move message up">
                                                                                                    <i class="fa-solid fa-fw fa-arrow-up" aria-hidden="true"></i>
                                                                                                </button>
                                                                                                <button type="button" class="btn btn-outline-secondary" data-action="move-down" aria-label="Move message down">
                                                                                                    <i class="fa-solid fa-fw fa-arrow-down" aria-hidden="true"></i>
                                                                                                </button>
                                                                                                <button type="button" class="btn btn-outline-danger" data-action="remove" aria-label="Remove message">
                                                                                                    <i class="fa-solid fa-fw fa-trash" aria-hidden="true"></i>
                                                                                                </button>
                                                                                            </div>
                                                                                        </div>
                                                                                        <input class="form-control" data-field="message" asp-for="FunnyMessages[i].Message" maxlength="@XtremeIdiots.Portal.Web.ViewModels.GlobalSettingsViewModel.MaxFunnyMessageLength" />
                                                                                        <small class="form-text text-muted"><span data-field="char-count">0</span>/@XtremeIdiots.Portal.Web.ViewModels.GlobalSettingsViewModel.MaxFunnyMessageLength characters</small>
                                                                                        <div class="small text-muted mt-1" data-field="preview">(preview)</div>
                                                                                        <span class="text-danger" data-field="validation" data-valmsg-for="FunnyMessages[@i].Message" data-valmsg-replace="true"></span>
                                                                                    </div>
                                                                                }
                                                                            </div>
                                                                        </div>
                                                                    </div>

                                                                    @* Save Button *@
                                                                    <div class="ibox">
                                                                        <div class="ibox-content">
                                                                            <button type="submit" class="btn btn-primary">
                                                                                <i class="fa-solid fa-fw fa-floppy-disk" aria-hidden="true"></i> Save Settings
                                                                            </button>
                                                                        </div>
                                                                    </div>

                                                                </div>
                                                            </div>
                                                        </form>
                                                    </div>

                                                    @section Scripts {
                                                        @{
                                                            await Html.RenderPartialAsync("_ValidationScriptsPartial");
                                                        }
                                                        <script>
                                                            function stripCodColorCodes(text) {
                                                                return text.replace(/\^[0-9]/g, '');
                                                            }

                                                            function renderCodPreview(previewElement, text) {
                                                                var colors = {
                                                                    '1': '#ff4d4f',
                                                                    '2': '#52c41a',
                                                                    '3': '#ffd666',
                                                                    '4': '#40a9ff',
                                                                    '5': '#69c0ff',
                                                                    '6': '#fa8c16',
                                                                    '7': '#f0f0f0',
                                                                    '8': '#000000',
                                                                    '9': '#ff85c0',
                                                                    '0': '#ffffff'
                                                                };

                                                                previewElement.textContent = '';

                                                                var currentColor = colors['0'];
                                                                var lastIndex = 0;
                                                                var regex = /\^([0-9])/g;
                                                                var match;

                                                                while ((match = regex.exec(text)) !== null) {
                                                                    var segment = text.substring(lastIndex, match.index);
                                                                    if (segment.length) {
                                                                        var span = document.createElement('span');
                                                                        span.style.color = currentColor;
                                                                        span.textContent = segment;
                                                                        previewElement.appendChild(span);
                                                                    }

                                                                    currentColor = colors[match[1]] || currentColor;
                                                                    lastIndex = regex.lastIndex;
                                                                }

                                                                var tail = text.substring(lastIndex);
                                                                if (tail.length) {
                                                                    var tailSpan = document.createElement('span');
                                                                    tailSpan.style.color = currentColor;
                                                                    tailSpan.textContent = tail;
                                                                    previewElement.appendChild(tailSpan);
                                                                }
                                                            }

                                                            function updateGlobalFunnyRowPreview(row, agentName) {
                                                                var input = row.querySelector('[data-field="message"]');
                                                                var preview = row.querySelector('[data-field="preview"]');
                                                                var count = row.querySelector('[data-field="char-count"]');
                                                                if (!input || !preview || !count) return;

                                                                var value = input.value || '';
                                                                count.textContent = value.length.toString();

                                                                var previewText = value.replaceAll('{name}', 'PlayerName');
                                                                if (agentName.length > 0) {
                                                                    previewText = previewText.length > 0 ? (agentName + ' ' + previewText) : agentName;
                                                                }

                                                                if (!previewText.length) {
                                                                    preview.textContent = '(preview)';
                                                                    return;
                                                                }

                                                                renderCodPreview(preview, previewText);
                                                            }

                                                            function updateGlobalFunnyEmptyState(container) {
                                                                var emptyState = document.getElementById('global-funny-messages-empty');
                                                                if (!emptyState) return;
                                                                emptyState.classList.toggle('d-none', container.querySelectorAll('[data-global-funny-row]').length > 0);
                                                            }

                                                            function reindexGlobalFunnyRows(container) {
                                                                container.querySelectorAll('[data-global-funny-row]').forEach(function (row, index) {
                                                                    var enabledHidden = row.querySelector('[data-field="enabled-hidden"]');
                                                                    var enabled = row.querySelector('[data-field="enabled"]');
                                                                    var enabledLabel = row.querySelector('[data-field="enabled-label"]');
                                                                    var message = row.querySelector('[data-field="message"]');
                                                                    var validation = row.querySelector('[data-field="validation"]');

                                                                    if (enabledHidden) enabledHidden.name = 'FunnyMessages[' + index + '].Enabled';
                                                                    if (enabled) {
                                                                        enabled.name = 'FunnyMessages[' + index + '].Enabled';
                                                                        enabled.id = 'FunnyMessages_' + index + '__Enabled';
                                                                    }
                                                                    if (enabledLabel) enabledLabel.htmlFor = 'FunnyMessages_' + index + '__Enabled';
                                                                    if (message) {
                                                                        message.name = 'FunnyMessages[' + index + '].Message';
                                                                        message.id = 'FunnyMessages_' + index + '__Message';
                                                                    }
                                                                    if (validation) {
                                                                        validation.setAttribute('data-valmsg-for', 'FunnyMessages[' + index + '].Message');
                                                                    }
                                                                });
                                                            }

                                                            function wireGlobalFunnyRow(row, container, agentNameProvider) {
                                                                var removeButton = row.querySelector('[data-action="remove"]');
                                                                var moveUpButton = row.querySelector('[data-action="move-up"]');
                                                                var moveDownButton = row.querySelector('[data-action="move-down"]');
                                                                var messageInput = row.querySelector('[data-field="message"]');

                                                                if (removeButton) {
                                                                    removeButton.addEventListener('click', function () {
                                                                        row.remove();
                                                                        reindexGlobalFunnyRows(container);
                                                                        updateGlobalFunnyEmptyState(container);
                                                                    });
                                                                }

                                                                if (moveUpButton) {
                                                                    moveUpButton.addEventListener('click', function () {
                                                                        var previous = row.previousElementSibling;
                                                                        if (!previous) return;
                                                                        container.insertBefore(row, previous);
                                                                        reindexGlobalFunnyRows(container);
                                                                    });
                                                                }

                                                                if (moveDownButton) {
                                                                    moveDownButton.addEventListener('click', function () {
                                                                        var next = row.nextElementSibling;
                                                                        if (!next) return;
                                                                        container.insertBefore(next, row);
                                                                        reindexGlobalFunnyRows(container);
                                                                    });
                                                                }

                                                                if (messageInput) {
                                                                    messageInput.addEventListener('input', function () {
                                                                        updateGlobalFunnyRowPreview(row, agentNameProvider());
                                                                    });
                                                                }

                                                                updateGlobalFunnyRowPreview(row, agentNameProvider());
                                                            }

                                                            (function initializeGlobalFunnyMessages() {
                                                                var container = document.getElementById('global-funny-messages-container');
                                                                if (!container) return;

                                                                var addButton = document.getElementById('add-global-funny-message');
                                                                var agentNameInput = document.getElementById('AgentName');

                                                                function getAgentName() {
                                                                    return (agentNameInput?.value || '').trim();
                                                                }

                                                                function createRow() {
                                                                    var row = document.createElement('div');
                                                                    row.className = 'border rounded p-3 mb-3';
                                                                    row.setAttribute('data-global-funny-row', '');
                                                                    row.innerHTML = `
                                                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                                                            <div class="form-check form-switch mb-0">
                                                                                <input type="hidden" data-field="enabled-hidden" value="false" />
                                                                                <input class="form-check-input" data-field="enabled" type="checkbox" value="true" checked="checked" />
                                                                                <label class="form-check-label" data-field="enabled-label">Enabled</label>
                                                                            </div>
                                                                            <div class="btn-group btn-group-sm" role="group" aria-label="Funny message ordering">
                                                                                <button type="button" class="btn btn-outline-secondary" data-action="move-up" aria-label="Move message up">
                                                                                    <i class="fa-solid fa-fw fa-arrow-up" aria-hidden="true"></i>
                                                                                </button>
                                                                                <button type="button" class="btn btn-outline-secondary" data-action="move-down" aria-label="Move message down">
                                                                                    <i class="fa-solid fa-fw fa-arrow-down" aria-hidden="true"></i>
                                                                                </button>
                                                                                <button type="button" class="btn btn-outline-danger" data-action="remove" aria-label="Remove message">
                                                                                    <i class="fa-solid fa-fw fa-trash" aria-hidden="true"></i>
                                                                                </button>
                                                                            </div>
                                                                        </div>
                                                                        <input class="form-control" data-field="message" maxlength="@XtremeIdiots.Portal.Web.ViewModels.GlobalSettingsViewModel.MaxFunnyMessageLength" />
                                                                        <small class="form-text text-muted"><span data-field="char-count">0</span>/@XtremeIdiots.Portal.Web.ViewModels.GlobalSettingsViewModel.MaxFunnyMessageLength characters</small>
                                                                        <div class="small text-muted mt-1" data-field="preview">(preview)</div>
                                                                        <span class="text-danger" data-field="validation" data-valmsg-replace="true"></span>
                                                                    `;

                                                                    wireGlobalFunnyRow(row, container, getAgentName);
                                                                    return row;
                                                                }

                                                                container.querySelectorAll('[data-global-funny-row]').forEach(function (row) {
                                                                    wireGlobalFunnyRow(row, container, getAgentName);
                                                                });

                                                                if (addButton) {
                                                                    addButton.addEventListener('click', function () {
                                                                        container.appendChild(createRow());
                                                                        reindexGlobalFunnyRows(container);
                                                                        updateGlobalFunnyEmptyState(container);
                                                                    });
                                                                }

                                                                if (agentNameInput) {
                                                                    agentNameInput.addEventListener('input', function () {
                                                                        container.querySelectorAll('[data-global-funny-row]').forEach(function (row) {
                                                                            updateGlobalFunnyRowPreview(row, getAgentName());
                                                                        });
                                                                    });
                                                                }

                                                                reindexGlobalFunnyRows(container);
                                                                updateGlobalFunnyEmptyState(container);

                                                                var form = container.closest('form') || document.querySelector('form[method="post"]');
                                                                if (form) {
                                                                    form.addEventListener('submit', function () {
                                                                        reindexGlobalFunnyRows(container);

                                                                        // Post a single value for each boolean field to avoid list binding ambiguity.
                                                                        container.querySelectorAll('[data-global-funny-row]').forEach(function (row) {
                                                                            var enabledHidden = row.querySelector('[data-field="enabled-hidden"]');
                                                                            var enabled = row.querySelector('[data-field="enabled"]');

                                                                            if (!enabledHidden || !enabled) return;
                                                                            enabledHidden.disabled = enabled.checked;
                                                                        });
                                                                    });
                                                                }
                                                            })();
                                                        </script>
                                                    }
