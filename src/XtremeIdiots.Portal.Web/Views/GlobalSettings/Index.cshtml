@model XtremeIdiots.Portal.Web.ViewModels.GlobalSettingsViewModel

@{
    ViewData["Title"] = "Global Settings";
}

<div class="wrapper wrapper-content animated fadeInRight">
    <form asp-action="Index" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="row">
            <div class="col-lg-12">

                @* Agent Defaults *@
                <div class="ibox">
                    <div class="ibox-title">
                        <h5><i class="fa-solid fa-fw fa-robot" aria-hidden="true"></i> Agent Defaults</h5>
                    </div>
                    <div class="ibox-content">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="AgentPollIntervalMs" class="form-label"></label>
                                    <input asp-for="AgentPollIntervalMs" class="form-control" type="number" />
                                    <span asp-validation-for="AgentPollIntervalMs" class="text-danger"></span>
                                    <small class="form-text text-muted">How frequently agents check for new log
                                        data.</small>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label asp-for="AgentStatusPublishIntervalSeconds" class="form-label"></label>
                                        <input asp-for="AgentStatusPublishIntervalSeconds" class="form-control"
                                               type="number" />
                                        <span asp-validation-for="AgentStatusPublishIntervalSeconds"
                                              class="text-danger"></span>
                                        <small class="form-text text-muted">How often agents publish server status
                                            snapshots.</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label asp-for="AgentName" class="form-label"></label>
                                            <input asp-for="AgentName" class="form-control" maxlength="120" />
                                            <span asp-validation-for="AgentName" class="text-danger"></span>
                                            <small class="form-text text-muted">Prefix prepended to automated broadcast
                                                messages. Use CoD color tokens if desired.</small>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="mb-3">
                                                <label asp-for="AgentRconSyncIntervalSeconds" class="form-label"></label>
                                                <input asp-for="AgentRconSyncIntervalSeconds" class="form-control" type="number" />
                                                <span asp-validation-for="AgentRconSyncIntervalSeconds" class="text-danger"></span>
                                                <small class="form-text text-muted">How often agents query game servers via
                                                    RCON/Query.</small>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="mb-3">
                                                    <label asp-for="AgentOffsetSaveIntervalSeconds" class="form-label"></label>
                                                    <input asp-for="AgentOffsetSaveIntervalSeconds" class="form-control"
                                                           type="number" />
                                                    <span asp-validation-for="AgentOffsetSaveIntervalSeconds"
                                                          class="text-danger"></span>
                                                    <small class="form-text text-muted">How often agents persist log file read
                                                        position.</small>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    @* Ban File Sync Defaults *@
                                    <div class="ibox">
                                        <div class="ibox-title">
                                            <h5><i class="fa-solid fa-fw fa-ban" aria-hidden="true"></i> Ban File Sync Defaults</h5>
                                        </div>
                                        <div class="ibox-content">
                                            <div class="row">
                                                <div class="col-md-6">
                                                    <div class="mb-3">
                                                        <label asp-for="BanFileSyncCheckIntervalSeconds" class="form-label"></label>
                                                        <input asp-for="BanFileSyncCheckIntervalSeconds" class="form-control"
                                                               type="number" />
                                                        <span asp-validation-for="BanFileSyncCheckIntervalSeconds"
                                                              class="text-danger"></span>
                                                        <small class="form-text text-muted">How often agents check ban files for new
                                                            entries.</small>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        @* Moderation Defaults *@
                                        <div class="ibox">
                                            <div class="ibox-title">
                                                <h5><i class="fa-solid fa-fw fa-shield" aria-hidden="true"></i> Chat Moderation Defaults</h5>
                                            </div>
                                            <div class="ibox-content">
                                                <div class="row">
                                                    <div class="col-md-6">
                                                        <div class="mb-3">
                                                            <label asp-for="ModerationHateSeverityThreshold" class="form-label"></label>
                                                            <select asp-for="ModerationHateSeverityThreshold" class="form-select"
                                                                    asp-items="XtremeIdiots.Portal.Web.ViewModels.GlobalSettingsViewModel.BuildSeverityOptions(false)"></select>
                                                            <span asp-validation-for="ModerationHateSeverityThreshold"
                                                                  class="text-danger"></span>
                                                            <small class="form-text text-muted">Minimum hate severity (0–6) that triggers
                                                                moderation, or Disabled.</small>
                                                            </div>
                                                        </div>
                                                        <div class="col-md-6">
                                                            <div class="mb-3">
                                                                <label asp-for="ModerationViolenceSeverityThreshold" class="form-label"></label>
                                                                <select asp-for="ModerationViolenceSeverityThreshold" class="form-select"
                                                                        asp-items="XtremeIdiots.Portal.Web.ViewModels.GlobalSettingsViewModel.BuildSeverityOptions(false)"></select>
                                                                <span asp-validation-for="ModerationViolenceSeverityThreshold"
                                                                      class="text-danger"></span>
                                                                <small class="form-text text-muted">Minimum violence severity (0–6) that triggers
                                                                    moderation, or Disabled.</small>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="row">
                                                            <div class="col-md-6">
                                                                <div class="mb-3">
                                                                    <label asp-for="ModerationSexualSeverityThreshold" class="form-label"></label>
                                                                    <select asp-for="ModerationSexualSeverityThreshold" class="form-select"
                                                                            asp-items="XtremeIdiots.Portal.Web.ViewModels.GlobalSettingsViewModel.BuildSeverityOptions(false)"></select>
                                                                    <span asp-validation-for="ModerationSexualSeverityThreshold"
                                                                          class="text-danger"></span>
                                                                    <small class="form-text text-muted">Minimum sexual severity (0–6) that triggers
                                                                        moderation, or Disabled.</small>
                                                                    </div>
                                                                </div>
                                                                <div class="col-md-6">
                                                                    <div class="mb-3">
                                                                        <label asp-for="ModerationSelfHarmSeverityThreshold" class="form-label"></label>
                                                                        <select asp-for="ModerationSelfHarmSeverityThreshold" class="form-select"
                                                                                asp-items="XtremeIdiots.Portal.Web.ViewModels.GlobalSettingsViewModel.BuildSeverityOptions(false)"></select>
                                                                        <span asp-validation-for="ModerationSelfHarmSeverityThreshold"
                                                                              class="text-danger"></span>
                                                                        <small class="form-text text-muted">Minimum self-harm severity (0–6) that triggers
                                                                            moderation, or Disabled.</small>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <div class="row">
                                                                    <div class="col-md-6">
                                                                        <div class="mb-3">
                                                                            <label asp-for="ModerationMinMessageLength" class="form-label"></label>
                                                                            <input asp-for="ModerationMinMessageLength" class="form-control" type="number" />
                                                                            <span asp-validation-for="ModerationMinMessageLength" class="text-danger"></span>
                                                                            <small class="form-text text-muted">Messages shorter than this skip content safety
                                                                                analysis.</small>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>

                                                            @* Event Processing Defaults *@
                                                            <div class="ibox">
                                                                <div class="ibox-title">
                                                                    <h5><i class="fa-solid fa-fw fa-timeline" aria-hidden="true"></i> Event Processing Defaults</h5>
                                                                </div>
                                                                <div class="ibox-content">
                                                                    <div class="row">
                                                                        <div class="col-md-6">
                                                                            <div class="mb-3">
                                                                                <label asp-for="EventsStaleThresholdSeconds" class="form-label"></label>
                                                                                <input asp-for="EventsStaleThresholdSeconds" class="form-control" type="number" />
                                                                                <span asp-validation-for="EventsStaleThresholdSeconds" class="text-danger"></span>
                                                                                <small class="form-text text-muted">Events older than this are logged as
                                                                                    warnings.</small>
                                                                                </div>
                                                                            </div>
                                                                            <div class="col-md-6">
                                                                                <div class="mb-3">
                                                                                    <label asp-for="EventsPlayerCacheExpirationSeconds" class="form-label"></label>
                                                                                    <input asp-for="EventsPlayerCacheExpirationSeconds" class="form-control"
                                                                                           type="number" />
                                                                                    <span asp-validation-for="EventsPlayerCacheExpirationSeconds"
                                                                                          class="text-danger"></span>
                                                                                    <small class="form-text text-muted">How long player data is cached before
                                                                                        re-fetch.</small>
                                                                                    </div>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                    </div>

                                                                    @await Html.PartialAsync("_ChatCommandsConfiguration", Model)

                                                                    @await Html.PartialAsync("_WelcomeMessagesConfiguration", Model)

                                                                    @* Save Button *@
                                                                    <div class="ibox">
                                                                        <div class="ibox-content">
                                                                            <button type="submit" class="btn btn-primary">
                                                                                <i class="fa-solid fa-fw fa-floppy-disk" aria-hidden="true"></i> Save Settings
                                                                            </button>
                                                                        </div>
                                                                    </div>

                                                                </div>
                                                            </div>
                                                        </form>
                                                    </div>

                                                    @section Scripts {
                                                        @{
                                                            await Html.RenderPartialAsync("_ValidationScriptsPartial");
                                                        }
                                                        <script>
                                                            function renderCodPreview(previewElement, text) {
                                                                var colors = {
                                                                    '1': '#ff4d4f',
                                                                    '2': '#52c41a',
                                                                    '3': '#ffd666',
                                                                    '4': '#40a9ff',
                                                                    '5': '#69c0ff',
                                                                    '6': '#fa8c16',
                                                                    '7': '#f0f0f0',
                                                                    '8': '#000000',
                                                                    '9': '#ff85c0',
                                                                    '0': '#ffffff'
                                                                };

                                                                previewElement.textContent = '';

                                                                var currentColor = colors['0'];
                                                                var lastIndex = 0;
                                                                var regex = /\^([0-9])/g;
                                                                var match;

                                                                while ((match = regex.exec(text)) !== null) {
                                                                    var segment = text.substring(lastIndex, match.index);
                                                                    if (segment.length) {
                                                                        var span = document.createElement('span');
                                                                        span.style.color = currentColor;
                                                                        span.textContent = segment;
                                                                        previewElement.appendChild(span);
                                                                    }

                                                                    currentColor = colors[match[1]] || currentColor;
                                                                    lastIndex = regex.lastIndex;
                                                                }

                                                                var tail = text.substring(lastIndex);
                                                                if (tail.length) {
                                                                    var tailSpan = document.createElement('span');
                                                                    tailSpan.style.color = currentColor;
                                                                    tailSpan.textContent = tail;
                                                                    previewElement.appendChild(tailSpan);
                                                                }
                                                            }

                                                            function updateGlobalChatCommandRowPreview(row, agentName) {
                                                                var input = row.querySelector('[data-field="message"]');
                                                                var preview = row.querySelector('[data-field="preview"]');
                                                                var count = row.querySelector('[data-field="char-count"]');
                                                                if (!input || !preview || !count) return;

                                                                var value = input.value || '';
                                                                count.textContent = value.length.toString();

                                                                var previewText = value.replaceAll('{name}', 'PlayerName');
                                                                if (agentName.length > 0) {
                                                                    previewText = previewText.length > 0 ? (agentName + ' ' + previewText) : agentName;
                                                                }

                                                                if (!previewText.length) {
                                                                    preview.textContent = '(preview)';
                                                                    return;
                                                                }

                                                                renderCodPreview(preview, previewText);
                                                            }

                                                            function reindexGlobalChatCommandRows(container) {
                                                                var fieldNamePrefix = container.dataset.fieldNamePrefix;
                                                                var normalizedPrefix = fieldNamePrefix.replaceAll('.', '_').replaceAll('[', '_').replaceAll(']', '');

                                                                container.querySelectorAll('[data-message-row]').forEach(function (row, index) {
                                                                    var enabledHidden = row.querySelector('[data-field="enabled-hidden"]');
                                                                    var enabled = row.querySelector('[data-field="enabled"]');
                                                                    var enabledLabel = row.querySelector('[data-field="enabled-label"]');
                                                                    var message = row.querySelector('[data-field="message"]');
                                                                    var validation = row.querySelector('[data-field="validation"]');

                                                                    if (enabledHidden) enabledHidden.name = fieldNamePrefix + '[' + index + '].Enabled';
                                                                    if (enabled) {
                                                                        enabled.name = fieldNamePrefix + '[' + index + '].Enabled';
                                                                        enabled.id = normalizedPrefix + '_' + index + '__Enabled';
                                                                    }
                                                                    if (enabledLabel && enabled) enabledLabel.htmlFor = enabled.id;
                                                                    if (message) {
                                                                        message.name = fieldNamePrefix + '[' + index + '].Message';
                                                                        message.id = normalizedPrefix + '_' + index + '__Message';
                                                                    }
                                                                    if (validation) {
                                                                        validation.setAttribute('data-valmsg-for', fieldNamePrefix + '[' + index + '].Message');
                                                                    }
                                                                });
                                                            }

                                                            function updateGlobalChatCommandEmptyState(container) {
                                                                var emptyState = document.getElementById(container.dataset.emptyStateId);
                                                                if (!emptyState) return;
                                                                emptyState.classList.toggle('d-none', container.querySelectorAll('[data-message-row]').length > 0);
                                                            }

                                                            function wireGlobalChatCommandRow(row, container, agentNameProvider) {
                                                                var removeButton = row.querySelector('[data-action="remove"]');
                                                                var moveUpButton = row.querySelector('[data-action="move-up"]');
                                                                var moveDownButton = row.querySelector('[data-action="move-down"]');
                                                                var messageInput = row.querySelector('[data-field="message"]');
                                                                var enabledHidden = row.querySelector('[data-field="enabled-hidden"]');
                                                                var enabled = row.querySelector('[data-field="enabled"]');

                                                                function syncEnabledState() {
                                                                    if (!enabledHidden || !enabled) return;
                                                                    enabledHidden.disabled = enabled.checked;
                                                                }

                                                                if (removeButton) {
                                                                    removeButton.addEventListener('click', function () {
                                                                        row.remove();
                                                                        reindexGlobalChatCommandRows(container);
                                                                        updateGlobalChatCommandEmptyState(container);
                                                                    });
                                                                }

                                                                if (moveUpButton) {
                                                                    moveUpButton.addEventListener('click', function () {
                                                                        var previous = row.previousElementSibling;
                                                                        if (!previous) return;
                                                                        container.insertBefore(row, previous);
                                                                        reindexGlobalChatCommandRows(container);
                                                                    });
                                                                }

                                                                if (moveDownButton) {
                                                                    moveDownButton.addEventListener('click', function () {
                                                                        var next = row.nextElementSibling;
                                                                        if (!next) return;
                                                                        container.insertBefore(next, row);
                                                                        reindexGlobalChatCommandRows(container);
                                                                    });
                                                                }

                                                                if (messageInput) {
                                                                    messageInput.addEventListener('input', function () {
                                                                        updateGlobalChatCommandRowPreview(row, agentNameProvider());
                                                                    });
                                                                }

                                                                if (enabled) {
                                                                    enabled.addEventListener('change', syncEnabledState);
                                                                }

                                                                updateGlobalChatCommandRowPreview(row, agentNameProvider());
                                                                syncEnabledState();
                                                            }

                                                            (function initializeGlobalChatCommandMessages() {
                                                                var containers = document.querySelectorAll('[data-chat-command-messages-container]');
                                                                if (!containers.length) return;

                                                                var agentNameInput = document.getElementById('AgentName');
                                                                var template = document.getElementById('global-chat-command-message-template');
                                                                if (!template) return;

                                                                function getAgentName() {
                                                                    return (agentNameInput?.value || '').trim();
                                                                }

                                                                containers.forEach(function (container) {
                                                                    container.querySelectorAll('[data-message-row]').forEach(function (row) {
                                                                        wireGlobalChatCommandRow(row, container, getAgentName);
                                                                    });

                                                                    var addButton = document.getElementById(container.dataset.addButtonId);
                                                                    if (addButton) {
                                                                        addButton.addEventListener('click', function () {
                                                                            var row = template.content.firstElementChild.cloneNode(true);
                                                                            wireGlobalChatCommandRow(row, container, getAgentName);
                                                                            container.appendChild(row);
                                                                            reindexGlobalChatCommandRows(container);
                                                                            updateGlobalChatCommandEmptyState(container);
                                                                        });
                                                                    }

                                                                    reindexGlobalChatCommandRows(container);
                                                                    updateGlobalChatCommandEmptyState(container);
                                                                });

                                                                if (agentNameInput) {
                                                                    agentNameInput.addEventListener('input', function () {
                                                                        containers.forEach(function (container) {
                                                                            container.querySelectorAll('[data-message-row]').forEach(function (row) {
                                                                                updateGlobalChatCommandRowPreview(row, getAgentName());
                                                                            });
                                                                        });
                                                                    });
                                                                }

                                                                var form = document.querySelector('form[method="post"]');
                                                                if (form) {
                                                                    form.addEventListener('submit', function () {
                                                                        containers.forEach(function (container) {
                                                                            reindexGlobalChatCommandRows(container);
                                                                            container.querySelectorAll('[data-message-row]').forEach(function (row) {
                                                                                var enabledHidden = row.querySelector('[data-field="enabled-hidden"]');
                                                                                var enabled = row.querySelector('[data-field="enabled"]');

                                                                                if (!enabledHidden || !enabled) return;
                                                                                enabledHidden.disabled = enabled.checked;
                                                                            });
                                                                        });
                                                                    });
                                                                }
                                                            })();

                                                            function updateWelcomeRuleCharCount(row) {
                                                                var messageTemplate = row.querySelector('[data-field="message-template"]');
                                                                var charCount = row.querySelector('[data-field="char-count"]');
                                                                if (!messageTemplate || !charCount) return;
                                                                charCount.textContent = (messageTemplate.value || '').length.toString();
                                                            }

                                                            function updateWelcomeRuleRequiredTagsVisibility(row) {
                                                                var overrideToggle = row.querySelector('[data-field="required-tags-override"]');
                                                                var tagsWrapper = row.querySelector('[data-field="required-tags-wrapper"]');
                                                                var overrideHidden = row.querySelector('[data-field="required-tags-override-hidden"]');

                                                                if (overrideHidden && overrideToggle) {
                                                                    overrideHidden.disabled = overrideToggle.checked;
                                                                }

                                                                if (!overrideToggle || !tagsWrapper) return;
                                                                tagsWrapper.classList.toggle('d-none', !overrideToggle.checked);
                                                            }

                                                            function updateWelcomeRulesEmptyState(container) {
                                                                var emptyStateId = container.dataset.emptyStateId;
                                                                if (!emptyStateId) return;

                                                                var emptyState = document.getElementById(emptyStateId);
                                                                if (!emptyState) return;

                                                                emptyState.classList.toggle('d-none', container.querySelectorAll('[data-welcome-rule-row]').length > 0);
                                                            }

                                                            function reindexWelcomeRules(container) {
                                                                var fieldNamePrefix = container.dataset.fieldNamePrefix;
                                                                var validationPrefix = container.dataset.validationPrefix || fieldNamePrefix;
                                                                var normalizedPrefix = fieldNamePrefix.replaceAll('.', '_').replaceAll('[', '_').replaceAll(']', '');
                                                                var priorityMode = container.dataset.priorityMode || 'none';
                                                                var startPriority = parseInt(container.dataset.priorityStart || '1000', 10);

                                                                var rows = Array.from(container.querySelectorAll('[data-welcome-rule-row]'));

                                                                rows.forEach(function (row, index) {
                                                                    var id = row.querySelector('[data-field="id"]');
                                                                    var priority = row.querySelector('[data-field="priority"]');
                                                                    var visibility = row.querySelector('[data-field="visibility"]');
                                                                    var messageTemplate = row.querySelector('[data-field="message-template"]');
                                                                    var requiredTags = row.querySelector('[data-field="required-tags"]');
                                                                    var connectionDelay = row.querySelector('[data-field="connection-delay"]');
                                                                    var enabledHidden = row.querySelector('[data-field="enabled-hidden"]');
                                                                    var enabled = row.querySelector('[data-field="enabled"]');
                                                                    var enabledLabel = row.querySelector('[data-field="enabled-label"]');
                                                                    var requiredTagsOverride = row.querySelector('[data-field="required-tags-override"]');
                                                                    var requiredTagsOverrideLabel = row.querySelector('[data-field="required-tags-override-label"]');
                                                                    var requiredTagsOverrideHidden = row.querySelector('[data-field="required-tags-override-hidden"]');

                                                                    if (id) {
                                                                        id.name = fieldNamePrefix + '[' + index + '].Id';
                                                                        id.id = normalizedPrefix + '_' + index + '__Id';
                                                                    }

                                                                    if (priority) {
                                                                        priority.name = fieldNamePrefix + '[' + index + '].Priority';
                                                                        priority.id = normalizedPrefix + '_' + index + '__Priority';
                                                                        if (priorityMode === 'descending') {
                                                                            priority.value = (startPriority - index).toString();
                                                                        }
                                                                    }

                                                                    if (visibility) {
                                                                        visibility.name = fieldNamePrefix + '[' + index + '].Visibility';
                                                                        visibility.id = normalizedPrefix + '_' + index + '__Visibility';
                                                                    }

                                                                    if (messageTemplate) {
                                                                        messageTemplate.name = fieldNamePrefix + '[' + index + '].MessageTemplate';
                                                                        messageTemplate.id = normalizedPrefix + '_' + index + '__MessageTemplate';
                                                                    }

                                                                    if (requiredTags) {
                                                                        requiredTags.name = fieldNamePrefix + '[' + index + '].RequiredTagsCsv';
                                                                        requiredTags.id = normalizedPrefix + '_' + index + '__RequiredTagsCsv';
                                                                    }

                                                                    if (connectionDelay) {
                                                                        connectionDelay.name = fieldNamePrefix + '[' + index + '].ConnectionDelaySeconds';
                                                                        connectionDelay.id = normalizedPrefix + '_' + index + '__ConnectionDelaySeconds';
                                                                    }

                                                                    if (enabledHidden) {
                                                                        enabledHidden.name = fieldNamePrefix + '[' + index + '].Enabled';
                                                                    }

                                                                    if (enabled) {
                                                                        enabled.name = fieldNamePrefix + '[' + index + '].Enabled';
                                                                        enabled.id = normalizedPrefix + '_' + index + '__Enabled';
                                                                        if (enabledHidden) {
                                                                            enabledHidden.disabled = enabled.checked;
                                                                        }
                                                                    }

                                                                    if (enabledLabel && enabled) {
                                                                        enabledLabel.htmlFor = enabled.id;
                                                                    }

                                                                    if (requiredTagsOverrideHidden) {
                                                                        requiredTagsOverrideHidden.name = fieldNamePrefix + '[' + index + '].OverrideRequiredTags';
                                                                    }

                                                                    if (requiredTagsOverride) {
                                                                        requiredTagsOverride.name = fieldNamePrefix + '[' + index + '].OverrideRequiredTags';
                                                                        requiredTagsOverride.id = normalizedPrefix + '_' + index + '__OverrideRequiredTags';
                                                                        if (requiredTagsOverrideHidden) {
                                                                            requiredTagsOverrideHidden.disabled = requiredTagsOverride.checked;
                                                                        }
                                                                    }

                                                                    if (requiredTagsOverrideLabel && requiredTagsOverride) {
                                                                        requiredTagsOverrideLabel.htmlFor = requiredTagsOverride.id;
                                                                    }

                                                                    var idValidation = row.querySelector('[data-field="id-validation"]');
                                                                    if (idValidation) {
                                                                        idValidation.setAttribute('data-valmsg-for', validationPrefix + '[' + index + '].Id');
                                                                    }

                                                                    var priorityValidation = row.querySelector('[data-field="priority-validation"]');
                                                                    if (priorityValidation) {
                                                                        priorityValidation.setAttribute('data-valmsg-for', validationPrefix + '[' + index + '].Priority');
                                                                    }

                                                                    var messageTemplateValidation = row.querySelector('[data-field="message-template-validation"]');
                                                                    if (messageTemplateValidation) {
                                                                        messageTemplateValidation.setAttribute('data-valmsg-for', validationPrefix + '[' + index + '].MessageTemplate');
                                                                    }

                                                                    var requiredTagsValidation = row.querySelector('[data-field="required-tags-validation"]');
                                                                    if (requiredTagsValidation) {
                                                                        requiredTagsValidation.setAttribute('data-valmsg-for', validationPrefix + '[' + index + '].RequiredTagsCsv');
                                                                    }

                                                                    var connectionDelayValidation = row.querySelector('[data-field="connection-delay-validation"]');
                                                                    if (connectionDelayValidation) {
                                                                        connectionDelayValidation.setAttribute('data-valmsg-for', validationPrefix + '[' + index + '].ConnectionDelaySeconds');
                                                                    }

                                                                    updateWelcomeRuleCharCount(row);
                                                                    updateWelcomeRuleRequiredTagsVisibility(row);
                                                                });
                                                            }

                                                            function wireWelcomeRuleRow(row, container) {
                                                                var moveUpButton = row.querySelector('[data-action="move-up"]');
                                                                var moveDownButton = row.querySelector('[data-action="move-down"]');
                                                                var removeButton = row.querySelector('[data-action="remove"]');
                                                                var messageTemplate = row.querySelector('[data-field="message-template"]');
                                                                var enabled = row.querySelector('[data-field="enabled"]');
                                                                var enabledHidden = row.querySelector('[data-field="enabled-hidden"]');
                                                                var requiredTagsOverride = row.querySelector('[data-field="required-tags-override"]');

                                                                if (moveUpButton) {
                                                                    moveUpButton.addEventListener('click', function () {
                                                                        var previous = row.previousElementSibling;
                                                                        if (!previous) return;
                                                                        container.insertBefore(row, previous);
                                                                        reindexWelcomeRules(container);
                                                                    });
                                                                }

                                                                if (moveDownButton) {
                                                                    moveDownButton.addEventListener('click', function () {
                                                                        var next = row.nextElementSibling;
                                                                        if (!next) return;
                                                                        container.insertBefore(next, row);
                                                                        reindexWelcomeRules(container);
                                                                    });
                                                                }

                                                                if (removeButton) {
                                                                    removeButton.addEventListener('click', function () {
                                                                        row.remove();
                                                                        reindexWelcomeRules(container);
                                                                        updateWelcomeRulesEmptyState(container);
                                                                    });
                                                                }

                                                                if (messageTemplate) {
                                                                    messageTemplate.addEventListener('input', function () {
                                                                        updateWelcomeRuleCharCount(row);
                                                                    });
                                                                }

                                                                if (enabled && enabledHidden) {
                                                                    enabled.addEventListener('change', function () {
                                                                        enabledHidden.disabled = enabled.checked;
                                                                    });
                                                                }

                                                                if (requiredTagsOverride) {
                                                                    requiredTagsOverride.addEventListener('change', function () {
                                                                        updateWelcomeRuleRequiredTagsVisibility(row);
                                                                    });
                                                                }

                                                                updateWelcomeRuleCharCount(row);
                                                                updateWelcomeRuleRequiredTagsVisibility(row);
                                                            }

                                                            function initializeWelcomeRuleEditor(containerId, addButtonId) {
                                                                var container = document.getElementById(containerId);
                                                                if (!container) return;

                                                                var templateId = container.dataset.templateId;
                                                                var template = document.getElementById(templateId);
                                                                if (!template) return;

                                                                container.querySelectorAll('[data-welcome-rule-row]').forEach(function (row) {
                                                                    wireWelcomeRuleRow(row, container);
                                                                });

                                                                var addButton = document.getElementById(addButtonId);
                                                                if (addButton) {
                                                                    addButton.addEventListener('click', function () {
                                                                        var row = template.content.firstElementChild.cloneNode(true);
                                                                        wireWelcomeRuleRow(row, container);
                                                                        container.appendChild(row);
                                                                        reindexWelcomeRules(container);
                                                                        updateWelcomeRulesEmptyState(container);
                                                                    });
                                                                }

                                                                reindexWelcomeRules(container);
                                                                updateWelcomeRulesEmptyState(container);

                                                                var form = document.querySelector('form[method="post"]');
                                                                if (form) {
                                                                    form.addEventListener('submit', function () {
                                                                        reindexWelcomeRules(container);
                                                                    });
                                                                }
                                                            }

                                                            initializeWelcomeRuleEditor('global-welcome-rules-container', 'add-global-welcome-rule');
                                                        </script>
                                                    }
