@model XtremeIdiots.Portal.Web.ViewModels.GlobalSettingsViewModel

@{
    var rules = Model.WelcomeMessages.Rules ?? [];
}

<div class="ibox">
    <div class="ibox-title">
        <h5><i class="fa-solid fa-fw fa-hand-wave" aria-hidden="true"></i> Welcome Message Defaults</h5>
    </div>
    <div class="ibox-content">
        <p class="text-muted mb-3">
            Configure global welcome-message behavior and rule ordering. Rules are evaluated by priority.
        </p>

        <div class="row">
            <div class="col-md-3">
                <input type="hidden" name="WelcomeMessages.Enabled" value="false" />
                <div class="form-check mb-3 mt-4">
                    @if (Model.WelcomeMessages.Enabled)
                    {
                        <input class="form-check-input" type="checkbox" id="WelcomeMessages_Enabled"
                               name="WelcomeMessages.Enabled" value="true" checked="checked" />
                    }
                    else
                    {
                        <input class="form-check-input" type="checkbox" id="WelcomeMessages_Enabled"
                               name="WelcomeMessages.Enabled" value="true" />
                    }
                    <label class="form-check-label" for="WelcomeMessages_Enabled">@Html.DisplayNameFor(m =>
                        m.WelcomeMessages.Enabled)</label>
                </div>
            </div>
            <div class="col-md-3">
                <div class="mb-3">
                    <label asp-for="WelcomeMessages.StaleThresholdSeconds" class="form-label"></label>
                    <input asp-for="WelcomeMessages.StaleThresholdSeconds" class="form-control" type="number" />
                    <span asp-validation-for="WelcomeMessages.StaleThresholdSeconds" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-3">
                <div class="mb-3">
                    <label asp-for="WelcomeMessages.DefaultConnectionDelaySeconds" class="form-label"></label>
                    <input asp-for="WelcomeMessages.DefaultConnectionDelaySeconds" class="form-control" type="number" />
                    <span asp-validation-for="WelcomeMessages.DefaultConnectionDelaySeconds" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-3">
                <div class="mb-3">
                    <label asp-for="WelcomeMessages.CountryFallback" class="form-label"></label>
                    <input asp-for="WelcomeMessages.CountryFallback" class="form-control" />
                    <span asp-validation-for="WelcomeMessages.CountryFallback" class="text-danger"></span>
                </div>
            </div>
        </div>

        <hr />

        <div class="d-flex justify-content-between align-items-center mb-2">
            <div>
                <h6 class="mb-1">Rules</h6>
                <p class="text-muted mb-0">Use arrow buttons to reorder. Highest row is highest priority.</p>
            </div>
            <button type="button" class="btn btn-outline-secondary btn-sm" id="add-global-welcome-rule">
                <i class="fa-solid fa-fw fa-plus" aria-hidden="true"></i> Add rule
            </button>
        </div>

        <p id="global-welcome-rules-empty" class="text-muted @(rules.Count > 0 ? "d-none" : string.Empty)">
            No welcome-message rules configured.
        </p>

        <div id="global-welcome-rules-container"
             data-field-name-prefix="WelcomeMessages.Rules"
             data-empty-state-id="global-welcome-rules-empty"
             data-priority-start="1000"
             data-template-id="global-welcome-rule-template"
             data-priority-mode="descending"
             data-hidden-required-tags-override="false"
             data-validation-prefix="WelcomeMessages.Rules">
            @for (var i = 0; i < rules.Count; i++)
            {
                <div class="border rounded p-3 mb-3" data-welcome-rule-row>
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div class="form-check mb-0">
                            <input type="hidden" data-field="enabled-hidden" name="WelcomeMessages.Rules[@i].Enabled" value="false" />
                            @if (rules[i].Enabled)
                            {
                                <input class="form-check-input" data-field="enabled" type="checkbox"
                                       id="WelcomeMessages_Rules_@(i)__Enabled" name="WelcomeMessages.Rules[@i].Enabled" value="true" checked="checked" />
                            }
                            else
                            {
                                <input class="form-check-input" data-field="enabled" type="checkbox"
                                       id="WelcomeMessages_Rules_@(i)__Enabled" name="WelcomeMessages.Rules[@i].Enabled" value="true" />
                            }
                            <label class="form-check-label" data-field="enabled-label" for="WelcomeMessages_Rules_@(i)__Enabled">Enabled</label>
                        </div>
                        <div class="btn-group btn-group-sm" role="group" aria-label="Welcome rule ordering">
                            <button type="button" class="btn btn-outline-secondary" data-action="move-up" aria-label="Move rule up">
                                <i class="fa-solid fa-fw fa-arrow-up" aria-hidden="true"></i>
                            </button>
                            <button type="button" class="btn btn-outline-secondary" data-action="move-down" aria-label="Move rule down">
                                <i class="fa-solid fa-fw fa-arrow-down" aria-hidden="true"></i>
                            </button>
                            <button type="button" class="btn btn-outline-danger" data-action="remove" aria-label="Remove rule">
                                <i class="fa-solid fa-fw fa-trash" aria-hidden="true"></i>
                            </button>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-lg-4">
                            <div class="mb-3">
                                <label asp-for="WelcomeMessages.Rules[i].Id" class="form-label"></label>
                                <input asp-for="WelcomeMessages.Rules[i].Id" data-field="id" class="form-control" maxlength="120" />
                                <span class="text-danger" data-field="id-validation"
                                      data-valmsg-for="WelcomeMessages.Rules[@i].Id" data-valmsg-replace="true"></span>
                            </div>
                        </div>
                        <div class="col-lg-2">
                            <div class="mb-3">
                                <label asp-for="WelcomeMessages.Rules[i].Priority" class="form-label"></label>
                                <input asp-for="WelcomeMessages.Rules[i].Priority" data-field="priority" class="form-control" type="number" />
                                <span class="text-danger" data-field="priority-validation"
                                      data-valmsg-for="WelcomeMessages.Rules[@i].Priority" data-valmsg-replace="true"></span>
                            </div>
                        </div>
                        <div class="col-lg-3">
                            <div class="mb-3">
                                <label asp-for="WelcomeMessages.Rules[i].Visibility" class="form-label"></label>
                                <select asp-for="WelcomeMessages.Rules[i].Visibility" data-field="visibility" class="form-select">
                                    <option value="Private">Private</option>
                                    <option value="Public">Public</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-lg-3">
                            <div class="mb-3">
                                <label asp-for="WelcomeMessages.Rules[i].ConnectionDelaySeconds" class="form-label"></label>
                                <input asp-for="WelcomeMessages.Rules[i].ConnectionDelaySeconds" data-field="connection-delay" class="form-control" type="number" />
                                <span class="text-danger" data-field="connection-delay-validation"
                                      data-valmsg-for="WelcomeMessages.Rules[@i].ConnectionDelaySeconds" data-valmsg-replace="true"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-lg-12">
                            <div class="mb-3">
                                <label asp-for="WelcomeMessages.Rules[i].MessageTemplate" class="form-label"></label>
                                <textarea asp-for="WelcomeMessages.Rules[i].MessageTemplate" data-field="message-template" class="form-control" rows="3"></textarea>
                                <small class="form-text text-muted"><span data-field="char-count">0</span>/@XtremeIdiots.Portal.Web.ViewModels.WelcomeMessageSettingsViewModelConstants.MaxMessageTemplateLength characters</small>
                                <span class="text-danger" data-field="message-template-validation"
                                      data-valmsg-for="WelcomeMessages.Rules[@i].MessageTemplate" data-valmsg-replace="true"></span>
                            </div>
                        </div>
                    </div>

                    <div class="mb-0">
                        <label asp-for="WelcomeMessages.Rules[i].RequiredTagsCsv" class="form-label"></label>
                        <input asp-for="WelcomeMessages.Rules[i].RequiredTagsCsv" data-field="required-tags" class="form-control" />
                        <small class="form-text text-muted">Comma-separated tags. Leave blank for no tag requirements.</small>
                        <span class="text-danger" data-field="required-tags-validation"
                              data-valmsg-for="WelcomeMessages.Rules[@i].RequiredTagsCsv" data-valmsg-replace="true"></span>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<template id="global-welcome-rule-template">
    <div class="border rounded p-3 mb-3" data-welcome-rule-row>
        <div class="d-flex justify-content-between align-items-center mb-2">
            <div class="form-check mb-0">
                <input type="hidden" data-field="enabled-hidden" name="WelcomeMessages.Rules[0].Enabled" value="false" />
                <input class="form-check-input" data-field="enabled" id="WelcomeMessages_Rules_0__Enabled" name="WelcomeMessages.Rules[0].Enabled" type="checkbox" value="true" checked="checked" />
                <label class="form-check-label" data-field="enabled-label" for="WelcomeMessages_Rules_0__Enabled">Enabled</label>
            </div>
            <div class="btn-group btn-group-sm" role="group" aria-label="Welcome rule ordering">
                <button type="button" class="btn btn-outline-secondary" data-action="move-up" aria-label="Move rule up">
                    <i class="fa-solid fa-fw fa-arrow-up" aria-hidden="true"></i>
                </button>
                <button type="button" class="btn btn-outline-secondary" data-action="move-down" aria-label="Move rule down">
                    <i class="fa-solid fa-fw fa-arrow-down" aria-hidden="true"></i>
                </button>
                <button type="button" class="btn btn-outline-danger" data-action="remove" aria-label="Remove rule">
                    <i class="fa-solid fa-fw fa-trash" aria-hidden="true"></i>
                </button>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-4">
                <div class="mb-3">
                    <label class="form-label" data-field="id-label" for="WelcomeMessages_Rules_0__Id">Rule Id</label>
                    <input id="WelcomeMessages_Rules_0__Id" name="WelcomeMessages.Rules[0].Id" data-field="id" class="form-control" maxlength="120" />
                    <span class="text-danger" data-field="id-validation" data-valmsg-for="WelcomeMessages.Rules[0].Id" data-valmsg-replace="true"></span>
                </div>
            </div>
            <div class="col-lg-2">
                <div class="mb-3">
                    <label class="form-label" data-field="priority-label" for="WelcomeMessages_Rules_0__Priority">Priority</label>
                    <input id="WelcomeMessages_Rules_0__Priority" name="WelcomeMessages.Rules[0].Priority" data-field="priority" class="form-control" type="number" />
                    <span class="text-danger" data-field="priority-validation" data-valmsg-for="WelcomeMessages.Rules[0].Priority" data-valmsg-replace="true"></span>
                </div>
            </div>
            <div class="col-lg-3">
                <div class="mb-3">
                    <label class="form-label" data-field="visibility-label" for="WelcomeMessages_Rules_0__Visibility">Visibility</label>
                    <select id="WelcomeMessages_Rules_0__Visibility" name="WelcomeMessages.Rules[0].Visibility" data-field="visibility" class="form-select">
                        <option value="Private">Private</option>
                        <option value="Public">Public</option>
                    </select>
                </div>
            </div>
            <div class="col-lg-3">
                <div class="mb-3">
                    <label class="form-label" data-field="connection-delay-label" for="WelcomeMessages_Rules_0__ConnectionDelaySeconds">Delay Override (seconds)</label>
                    <input id="WelcomeMessages_Rules_0__ConnectionDelaySeconds" name="WelcomeMessages.Rules[0].ConnectionDelaySeconds" data-field="connection-delay" class="form-control" type="number" />
                    <span class="text-danger" data-field="connection-delay-validation" data-valmsg-for="WelcomeMessages.Rules[0].ConnectionDelaySeconds" data-valmsg-replace="true"></span>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-12">
                <div class="mb-3">
                    <label class="form-label" data-field="message-template-label" for="WelcomeMessages_Rules_0__MessageTemplate">Message Template</label>
                    <textarea id="WelcomeMessages_Rules_0__MessageTemplate" name="WelcomeMessages.Rules[0].MessageTemplate" data-field="message-template" class="form-control" rows="3"></textarea>
                    <small class="form-text text-muted"><span data-field="char-count">0</span>/@XtremeIdiots.Portal.Web.ViewModels.WelcomeMessageSettingsViewModelConstants.MaxMessageTemplateLength characters</small>
                    <span class="text-danger" data-field="message-template-validation" data-valmsg-for="WelcomeMessages.Rules[0].MessageTemplate" data-valmsg-replace="true"></span>
                </div>
            </div>
        </div>

        <div class="mb-0">
            <label class="form-label" data-field="required-tags-label" for="WelcomeMessages_Rules_0__RequiredTagsCsv">Required Tags</label>
            <input id="WelcomeMessages_Rules_0__RequiredTagsCsv" name="WelcomeMessages.Rules[0].RequiredTagsCsv" data-field="required-tags" class="form-control" />
            <small class="form-text text-muted">Comma-separated tags. Leave blank for no tag requirements.</small>
            <span class="text-danger" data-field="required-tags-validation" data-valmsg-for="WelcomeMessages.Rules[0].RequiredTagsCsv" data-valmsg-replace="true"></span>
        </div>
    </div>
</template>

@section Scripts {
    <script src="~/js/welcome-rules-manager.js"></script>
}
