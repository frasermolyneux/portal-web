@using XtremeIdiots.Portal.Web.ViewModels
@model GlobalSettingsViewModel
@{
    var broadcastMessages = Model.BroadcastMessages ?? [];
}

<div class="ibox">
    <div class="ibox-title">
        <h5><i class="fa-solid fa-fw fa-bullhorn" aria-hidden="true"></i> Broadcasts</h5>
    </div>
    <div class="ibox-content">
        <div class="form-check mb-3">
            <input class="form-check-input" asp-for="BroadcastsEnabled" />
            <label class="form-check-label" asp-for="BroadcastsEnabled"></label>
            <small class="form-text text-muted d-block">Fleet-wide default for periodic server broadcast
                messages.</small>
            </div>

            <div class="mb-3">
                <label asp-for="BroadcastsIntervalSeconds" class="form-label"></label>
                <input asp-for="BroadcastsIntervalSeconds" class="form-control" type="number" min="1" max="86400" />
                <span asp-validation-for="BroadcastsIntervalSeconds" class="text-danger"></span>
                <small class="form-text text-muted">Default interval between broadcasts in seconds.</small>
            </div>
        </div>
    </div>

    <div class="ibox">
        <div class="ibox-title d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Broadcast Messages</h5>
            <button type="button" class="btn btn-outline-secondary btn-sm" id="add-global-broadcast-message">
                <i class="fa-solid fa-fw fa-plus" aria-hidden="true"></i> Add message
            </button>
        </div>
        <div class="ibox-content">
            <p id="global-broadcast-messages-empty"
               class="text-muted @(broadcastMessages.Count > 0 ? "d-none" : string.Empty)">
                No broadcast messages configured.
            </p>

            <div id="global-broadcast-messages-container" data-chat-command-messages-container
                 data-field-name-prefix="BroadcastMessages" data-empty-state-id="global-broadcast-messages-empty"
                 data-add-button-id="add-global-broadcast-message" data-template-id="global-broadcast-message-template">
                @for (var i = 0; i < broadcastMessages.Count; i++)
                {
                    <div class="border rounded p-3 mb-3" data-message-row="broadcast">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div class="form-check mb-0">
                                @if (broadcastMessages[i].Enabled)
                                {
                                    <input class="form-check-input" data-field="enabled" type="checkbox"
                                           name="BroadcastMessages[@i].Enabled" value="true" id="BroadcastMessages_@(i)__Enabled"
                                           checked="checked" />
                                }
                                else
                                {
                                    <input class="form-check-input" data-field="enabled" type="checkbox"
                                           name="BroadcastMessages[@i].Enabled" value="true" id="BroadcastMessages_@(i)__Enabled" />
                                }
                                <input type="hidden" data-field="enabled-hidden" name="BroadcastMessages[@i].Enabled"
                                       value="false" />
                                <label class="form-check-label" data-field="enabled-label"
                                       for="BroadcastMessages_@(i)__Enabled">Enabled</label>
                            </div>
                            <div class="btn-group btn-group-sm" role="group" aria-label="Broadcast message ordering">
                                <button type="button" class="btn btn-outline-secondary" data-action="move-up"
                                        aria-label="Move message up">
                                    <i class="fa-solid fa-fw fa-arrow-up" aria-hidden="true"></i>
                                </button>
                                <button type="button" class="btn btn-outline-secondary" data-action="move-down"
                                        aria-label="Move message down">
                                    <i class="fa-solid fa-fw fa-arrow-down" aria-hidden="true"></i>
                                </button>
                                <button type="button" class="btn btn-outline-danger" data-action="remove"
                                        aria-label="Remove message">
                                    <i class="fa-solid fa-fw fa-trash" aria-hidden="true"></i>
                                </button>
                            </div>
                        </div>
                        <input class="form-control" data-field="message" asp-for="BroadcastMessages[i].Message" />
                        <div class="cod-message-preview is-empty mt-1" data-field="preview" aria-live="polite"></div>
                        <span class="text-danger" data-field="validation"
                              asp-validation-for="BroadcastMessages[i].Message"></span>
                    </div>
                }
            </div>
        </div>
    </div>

    <template id="global-broadcast-message-template">
        <div class="border rounded p-3 mb-3" data-message-row="broadcast">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="form-check mb-0">
                    <input class="form-check-input" data-field="enabled" type="checkbox" value="true" checked="checked" />
                    <input type="hidden" data-field="enabled-hidden" value="false" />
                    <label class="form-check-label" data-field="enabled-label">Enabled</label>
                </div>
                <div class="btn-group btn-group-sm" role="group" aria-label="Broadcast message ordering">
                    <button type="button" class="btn btn-outline-secondary" data-action="move-up"
                            aria-label="Move message up">
                        <i class="fa-solid fa-fw fa-arrow-up" aria-hidden="true"></i>
                    </button>
                    <button type="button" class="btn btn-outline-secondary" data-action="move-down"
                            aria-label="Move message down">
                        <i class="fa-solid fa-fw fa-arrow-down" aria-hidden="true"></i>
                    </button>
                    <button type="button" class="btn btn-outline-danger" data-action="remove" aria-label="Remove message">
                        <i class="fa-solid fa-fw fa-trash" aria-hidden="true"></i>
                    </button>
                </div>
            </div>
            <input class="form-control" data-field="message" />
            <div class="cod-message-preview is-empty mt-1" data-field="preview" aria-live="polite"></div>
            <span class="text-danger" data-field="validation"></span>
        </div>
    </template>