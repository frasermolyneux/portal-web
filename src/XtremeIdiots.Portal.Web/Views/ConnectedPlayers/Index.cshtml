@using XtremeIdiots.Portal.Repository.Abstractions.Constants.V1
@model XtremeIdiots.Portal.Web.ViewModels.ConnectedPlayersAdminViewModel

@{
    ViewData["Title"] = "Connected Players";
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox">
                <div class="ibox-title">
                    <h5>Connected Players Index</h5>
                </div>
                <div class="ibox-content">
                    <div class="list-filters mb-2" id="connectedPlayersFilters">
                        <div class="filter-group">
                            <label class="form-label" for="gameType">Game</label>
                            <select class="form-select" id="gameType">
                                <option value="">All</option>
                                @foreach (var game in Enum.GetValues<GameType>().Where(x => x != GameType.Unknown))
                                {
                                    <option value="@game">@game</option>
                                }
                            </select>
                        </div>
                        <div class="filter-group">
                            <label class="form-label" for="isActive">Status</label>
                            <select class="form-select" id="isActive">
                                <option value="" selected>All</option>
                                <option value="Active">Active</option>
                                <option value="Inactive">Inactive</option>
                            </select>
                        </div>
                        <div class="filter-group">
                            <label class="form-label" for="resetFilters">Reset</label>
                            <button type="button" id="resetFilters" class="btn btn-outline-secondary btn-sm">Reset
                                Filters</button>
                            </div>

                            <div class="table-responsive">
                                <table id="dataTable" class="table table-striped table-hover w-100"
                                       data-can-unlink="@Model.IsSeniorAdmin.ToString().ToLowerInvariant()">
                                    <thead>
                                        <tr>
                                            <th scope="col">Game</th>
                                            <th scope="col">Username</th>
                                            <th scope="col">Website Profile</th>
                                            <th scope="col">Method</th>
                                            <th scope="col">Status</th>
                                            <th scope="col" class="table-date-col">Linked At</th>
                                            <th scope="col" class="table-date-col">Unlinked At</th>
                                            <th scope="col" class="table-action-col">Actions</th>
                                        </tr>
                                    </thead>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @if (Model.IsSeniorAdmin)
            {
                <div class="row">
                    <div class="col-lg-12">
                        <div class="ibox">
                            <div class="ibox-title">
                                <h5>Manual Link (Senior Admin)</h5>
                            </div>
                            <div class="ibox-content">
                                <form asp-action="CreateManualLink" method="post" id="manualLinkForm">
                                    @Html.AntiForgeryToken()

                                    <div class="list-filters mb-2" id="manualLinkFilters">
                                        <div class="filter-group">
                                            <label class="form-label" for="manualLinkGameType">Game</label>
                                            <select class="form-select" id="manualLinkGameType">
                                                <option value="">Select game</option>
                                                @foreach (var game in Enum.GetValues<GameType>().Where(x => x != GameType.Unknown))
                                                {
                                                    <option value="@game">@game</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="filter-group">
                                            <label class="form-label" for="manualLinkUserSearch">Website Profile</label>
                                            <input class="form-control" id="manualLinkUserSearch" autocomplete="off" placeholder="Search website profile..." />
                                            <input type="hidden" id="manualLinkUserProfileId" name="UserProfileId" />
                                        </div>
                                        <div class="filter-group">
                                            <label class="form-label" for="manualLinkPlayerSearch">Player</label>
                                            <input class="form-control" id="manualLinkPlayerSearch" autocomplete="off" placeholder="Search player username..." />
                                            <input type="hidden" id="manualLinkPlayerId" name="PlayerId" />
                                        </div>
                                    </div>

                                    <div id="manualLinkPreview" class="manual-link-preview d-none" aria-live="polite">
                                        <div class="preview-panel">
                                            <h6 class="preview-title">Website Profile</h6>
                                            <dl class="detail-fields row mb-0">
                                                <div class="detail-field col-12">
                                                    <dt class="detail-label">Display Name</dt>
                                                    <dd class="detail-value" data-field="user-display-name"></dd>
                                                </div>
                                                <div class="detail-field col-12">
                                                    <dt class="detail-label">Email</dt>
                                                    <dd class="detail-value" data-field="user-email"></dd>
                                                </div>
                                                <div class="detail-field col-12">
                                                    <dt class="detail-label">Forum Id</dt>
                                                    <dd class="detail-value" data-field="user-forum-id"></dd>
                                                </div>
                                                <div class="detail-field col-12">
                                                    <dt class="detail-label">Profile Id</dt>
                                                    <dd class="detail-value" data-field="user-profile-id"></dd>
                                                </div>
                                            </dl>
                                        </div>

                                        <div class="preview-arrow" aria-hidden="true">
                                            <i class="fa-solid fa-fw fa-arrow-right" aria-hidden="true"></i>
                                        </div>

                                        <div class="preview-panel">
                                            <h6 class="preview-title">Player</h6>
                                            <dl class="detail-fields row mb-0">
                                                <div class="detail-field col-12">
                                                    <dt class="detail-label">Username</dt>
                                                    <dd class="detail-value" data-field="player-username"></dd>
                                                </div>
                                                <div class="detail-field col-12">
                                                    <dt class="detail-label">Guid</dt>
                                                    <dd class="detail-value" data-field="player-guid"></dd>
                                                </div>
                                                <div class="detail-field col-12">
                                                    <dt class="detail-label">IP Address</dt>
                                                    <dd class="detail-value" data-field="player-ip"></dd>
                                                </div>
                                                <div class="detail-field col-12">
                                                    <dt class="detail-label">Game</dt>
                                                    <dd class="detail-value" data-field="player-game-type"></dd>
                                                </div>
                                                <div class="detail-field col-12">
                                                    <dt class="detail-label">Last Seen</dt>
                                                    <dd class="detail-value" data-field="player-last-seen"></dd>
                                                </div>
                                                <div class="detail-field col-12">
                                                    <dt class="detail-label">Player Id</dt>
                                                    <dd class="detail-value" data-field="player-id"></dd>
                                                </div>
                                            </dl>
                                        </div>
                                    </div>

                                    <div id="manualLinkPreviewStatus" class="alert d-none mt-3 mb-3" role="status"></div>

                                    <div class="mb-3">
                                        <button type="submit" class="btn btn-primary" id="manualLinkCreateBtn" disabled>
                                            <i class="fa-solid fa-fw fa-link" aria-hidden="true"></i>
                                            Create Manual Link
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @section Scripts {
            <form id="__af" method="post" style="display:none">@Html.AntiForgeryToken()</form>
            <script src="~/js/connected-players-index.js" asp-append-version="true"></script>
        }
