@using XtremeIdiots.Portal.Repository.Abstractions.Constants.V1
@model XtremeIdiots.Portal.Web.ViewModels.ConnectedPlayersAdminViewModel

@{
    ViewData["Title"] = "Connected Players";
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox">
                <div class="ibox-title">
                    <h5>Connected Players Index</h5>
                </div>
                <div class="ibox-content">
                    <div class="list-filters mb-2" id="connectedPlayersFilters">
                        <div class="filter-group">
                            <label class="form-label" for="gameType">Game</label>
                            <select class="form-select" id="gameType">
                                <option value="">All</option>
                                @foreach (var game in Enum.GetValues<GameType>().Where(x => x != GameType.Unknown))
                                {
                                    <option value="@game">@game</option>
                                }
                            </select>
                        </div>
                        <div class="filter-group">
                            <label class="form-label" for="isActive">Status</label>
                            <select class="form-select" id="isActive">
                                <option value="" selected>All</option>
                                <option value="Active">Active</option>
                                <option value="Inactive">Inactive</option>
                            </select>
                        </div>
                        <div class="filter-group">
                            <label class="form-label" for="resetFilters">Reset</label>
                            <button type="button" id="resetFilters" class="btn btn-outline-secondary btn-sm">Reset
                                Filters</button>
                            </div>

                            <div class="table-responsive">
                                <table id="dataTable" class="table table-striped table-hover w-100"
                                       data-can-unlink="@Model.IsSeniorAdmin.ToString().ToLowerInvariant()">
                                    <thead>
                                        <tr>
                                            <th scope="col">Game</th>
                                            <th scope="col">Username</th>
                                            <th scope="col">Website Profile</th>
                                            <th scope="col">Method</th>
                                            <th scope="col">Status</th>
                                            <th scope="col" class="table-date-col">Linked At</th>
                                            <th scope="col" class="table-date-col">Unlinked At</th>
                                            <th scope="col" class="table-action-col">Actions</th>
                                        </tr>
                                    </thead>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @if (Model.IsSeniorAdmin)
            {
                <div class="row">
                    <div class="col-lg-12">
                        <div class="ibox">
                            <div class="ibox-title">
                                <h5>Manual Link (Senior Admin)</h5>
                            </div>
                            <div class="ibox-content">
                                <form asp-action="CreateManualLink" method="post">
                                    @Html.AntiForgeryToken()
                                    <div class="mb-3">
                                        <label class="form-label" for="PlayerId">Player Id</label>
                                        <input class="form-control" id="PlayerId" name="PlayerId"
                                               placeholder="00000000-0000-0000-0000-000000000000" />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label" for="UserProfileId">User Profile Id</label>
                                        <input class="form-control" id="UserProfileId" name="UserProfileId"
                                               placeholder="00000000-0000-0000-0000-000000000000" />
                                    </div>
                                    <button type="submit" class="btn btn-primary">
                                        <i class="fa-solid fa-fw fa-link" aria-hidden="true"></i>
                                        Create Manual Link
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @section Scripts {
            <form id="__af" method="post" style="display:none">@Html.AntiForgeryToken()</form>
            <script src="~/js/connected-players-index.js" asp-append-version="true"></script>
        }
