@using XtremeIdiots.Portal.Web.Extensions
@using XtremeIdiots.Portal.Web.Models
@model ProfileManageViewModel
@{
    ViewData["Title"] = "Manage Profile";

    var activeLinks = Model.LinkedPlayers.Where(x => x.IsActive).OrderByDescending(x => x.LinkedAtUtc).ToList();
    var inactiveLinks = Model.LinkedPlayers.Where(x => !x.IsActive).OrderByDescending(x => x.LinkedAtUtc).ToList();
}

<div class="wrapper wrapper-content animated fadeInRight">

    <div class="row">
        <div class="col-12">

            <div class="container text-center">
                <img src="@(User.PhotoUrl())" alt="Avatar" class="profile-avatar-large">
                <h1 class="display-4">@User.Username()</h1>
            </div>

        </div>
    </div>

    <div class="row">
        <div class="col-12">

            <div class="container-fluid">
                <div class="ibox">
                    <div class="ibox-title">
                        <h5>Profile Info</h5>
                    </div>
                    <div class="ibox-content">
                        <div class="table-responsive">
                            <table class="table w-100">
                                <tbody>
                                    <tr>
                                        <td>Email</td>
                                        <td>@User.Email()</td>
                                    </tr>
                                    <tr>
                                        <td>XtremeIdiots Profile</td>
                                        <td>
                                            <a href="https://www.xtremeidiots.com/profile/@(User.XtremeIdiotsId())-@(User.Username())/"
                                                target="_blank">XtremeIdiots Profile</a>
                                        </td>
                                    </tr>
                                </tbody>
                        </table>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <div class="row">
        <div class="col-12">

            <div class="container-fluid">
                <div class="ibox">
                    <div class="ibox-title">
                        <h5>Connected Player Linking</h5>
                    </div>
                    <div class="ibox-content">
                        @if (Model.UserProfileId is null)
                        {
                            <div class="alert alert-warning mb-0">
                                Your portal profile could not be resolved. Sign out and sign back in, then retry.
                            </div>
                        }
                        else
                        {
                            <p class="text-muted mb-3">
                                Generate a website activation code, then in game run <strong>!register CODE</strong>. You can run <strong>!commands</strong> in game to list available commands.
                            </p>

                            <div class="row g-3 mb-3">
                                <div class="col-12 col-lg-8">
                                    <div class="border rounded p-3">
                                        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                                            <div>
                                                <div class="text-muted small">Current Activation Code</div>
                                                @if (Model.ActiveActivationCode is null)
                                                {
                                                    <div class="fw-semibold">No active code</div>
                                                }
                                                else
                                                {
                                                    <div class="fw-bold fs-4">@Model.ActiveActivationCode.Code</div>
                                                    <div class="small text-muted">
                                                        Expires <time user-time utc="@Model.ActiveActivationCode.ExpiresAtUtc"></time>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-12 col-lg-4">
                                    <div class="border rounded p-3 h-100">
                                        <div class="text-muted small">Linked Players</div>
                                        <div class="fw-bold fs-4">@activeLinks.Count</div>
                                        <div class="small text-muted">Active linked game identities in current view</div>
                                    </div>
                                </div>
                            </div>

                            @if (activeLinks.Count == 0)
                            {
                                @if (Model.IsLinkedPlayersCapped)
                                {
                                    <div class="alert alert-warning mb-0">
                                        No active linked players were found in the current view. Older records may still contain active links.
                                    </div>
                                }
                                else
                                {
                                    <div class="alert alert-info mb-0">
                                        No active linked players yet. Generate a code and run <strong>!register CODE</strong> in game.
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="table-responsive">
                                    <table class="table table-striped table-hover w-100">
                                        <thead>
                                            <tr>
                                                <th scope="col">Game</th>
                                                <th scope="col">Username</th>
                                                <th scope="col">Link Method</th>
                                                <th scope="col" class="table-date-col">Linked At</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var link in activeLinks)
                                            {
                                                <tr>
                                                    <td>@link.GameType</td>
                                                    <td>@link.Username</td>
                                                    <td>@link.LinkMethod</td>
                                                    <td><time user-time utc="@link.LinkedAtUtc"></time></td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }

                            @if (inactiveLinks.Count > 0)
                            {
                                <hr />
                                <h6 class="mb-2">Previous Links</h6>
                                <div class="table-responsive">
                                    <table class="table table-striped table-hover w-100">
                                        <thead>
                                            <tr>
                                                <th scope="col">Game</th>
                                                <th scope="col">Username</th>
                                                <th scope="col">Status</th>
                                                <th scope="col" class="table-date-col">Linked At</th>
                                                <th scope="col" class="table-date-col">Unlinked At</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var link in inactiveLinks)
                                            {
                                                <tr>
                                                    <td>@link.GameType</td>
                                                    <td>@link.Username</td>
                                                    <td><span class="badge bg-secondary">Inactive</span></td>
                                                    <td><time user-time utc="@link.LinkedAtUtc"></time></td>
                                                    <td>
                                                        @if (link.UnlinkedAtUtc.HasValue)
                                                        {
                                                            <time user-time utc="@link.UnlinkedAtUtc.Value"></time>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }

                            @if (Model.IsLinkedPlayersCapped)
                            {
                                <div class="alert alert-warning mt-3 mb-0">
                                    Showing the most recent @Model.LinkedPlayers.Count linked players out of @Model.TotalLinkedPlayers total records.
                                </div>
                            }
                        }
                    </div>
                    @if (Model.UserProfileId is not null)
                    {
                        <div class="ibox-footer d-flex justify-content-end">
                            <form asp-action="ActivateConnectedPlayerCode" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-primary">
                                    <i class="fa-solid fa-fw fa-arrows-rotate" aria-hidden="true"></i>
                                    Generate New Code
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>

    <div class="row">
        <div class="col-12">

            <div class="container-fluid">
                <p>
                    <button class="btn btn-primary" type="button" data-bs-toggle="collapse"
                        data-bs-target="#claimsDebug" aria-expanded="false" aria-controls="claimsDebug">
                        Claims Debug Info
                    </button>
                </p>
                <div class="collapse" id="claimsDebug">
                    <div class="ibox">
                        <div class="ibox-title">
                            <h5>Claims Debug Info</h5>
                        </div>
                        <div class="ibox-content">
                            <div class="table-responsive">
                                <table class="table w-100">
                                    <thead>
                                        <tr>
                                            <th scope="col">Type</th>
                                            <th scope="col">Value</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var claim in User.Claims)
                                        {
                                            <tr>
                                                <td>@claim.Type</td>
                                                <td>@claim.Value</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

</div>