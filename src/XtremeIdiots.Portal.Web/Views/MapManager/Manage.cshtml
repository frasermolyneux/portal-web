@using XtremeIdiots.Portal.Web.Extensions
@using XtremeIdiots.Portal.Web.ViewModels
@using XtremeIdiots.Portal.Repository.Abstractions.Constants.V1
@model ManageMapsViewModel

@{
    ViewData["Title"] = "Map Manager";
}

<div class="wrapper wrapper-content animated fadeInRight">

    <div class="row">
        <div class="col-sm-2">

            <div class="ibox">
                <div class="ibox-title">
                    <h5><server-name title="@Model.GameServer.Title" live-title="@Model.GameServer.LiveTitle"></server-name></h5>
                </div>

                <div class="ibox-content">
                    <div class="table-responsive">
                        <table class="table w-100">
                            <tbody>
                                <tr>
                                    <td>
                                        <strong>Hostname</strong>
                                    </td>
                                    <td><server-host host="@Model.GameServer.Hostname" port="@Model.GameServer.QueryPort"></server-host></td>
                                </tr>

                                @if (!string.IsNullOrWhiteSpace(Model.GameServer.LiveMod))
                                {
                                    <tr>
                                        <td>
                                            <strong>Mod</strong>
                                        </td>
                                        <td>@Model.GameServer.LiveMod</td>
                                    </tr>
                                }

                                @if (!string.IsNullOrWhiteSpace(Model.GameServer.LiveMap))
                            {
                                <tr>
                                    <td>
                                        <strong>Map</strong>
                                    </td>
                                    <td>@Model.GameServer.LiveMap</td>
                                </tr>
                            }

                            @if (Model.GameServer.LiveCurrentPlayers != 0 && Model.GameServer.LiveMaxPlayers != 0)
                            {
                                <tr>
                                    <td>
                                        <strong>Player Count</strong>
                                    </td>
                                    <td>@Model.GameServer.LiveCurrentPlayers / @Model.GameServer.LiveMaxPlayers</td>
                                </tr>
                            }

                            <tr>
                                <td>
                                    <strong>Connect</strong>
                                </td>
                                <td>
                                    <server-link type="gametracker" host="@Model.GameServer.Hostname" port="@Model.GameServer.QueryPort"></server-link>
                                    <server-link type="steam" game="@Model.GameServer.GameType" host="@Model.GameServer.Hostname" port="@Model.GameServer.QueryPort"></server-link>
                                    <server-link type="hlsw" game="@Model.GameServer.GameType" host="@Model.GameServer.Hostname" port="@Model.GameServer.QueryPort"></server-link>
                                </td>
                            </tr>


                        </tbody>
                    </table>
                    </div>
                </div>
            </div>

            <partial name="PushMapToRemotePartial"
                model="@(new PushMapToRemoteViewModel(Model.GameServer.GameServerId))"></partial>

            <div class="ibox">
                <div class="ibox-title">
                    <h5>Map Rotations (@Model.RotationAssignments.Count)</h5>
                    <div class="ibox-tools">
                        <a asp-controller="MapRotations" asp-action="Index" asp-route-gameType="@Model.GameServer.GameType" class="btn btn-outline-secondary btn-sm me-1">
                            <i class="fa-solid fa-fw fa-list"></i> All Rotations
                        </a>
                    </div>
                </div>

                <div class="ibox-content">
                    @if (Model.RotationAssignments.Count == 0)
                    {
                        <div class="text-center text-muted py-3">
                            <i class="fa-solid fa-rotate fa-2x mb-2 d-block"></i>
                            <p>No map rotations assigned to this server.</p>
                            <a asp-controller="MapRotations" asp-action="Index" asp-route-gameType="@Model.GameServer.GameType" class="btn btn-outline-primary btn-sm">
                                <i class="fa-solid fa-fw fa-plus"></i> Manage Rotations
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Rotation</th>
                                        <th style="width: 80px;">Mode</th>
                                        <th style="width: 90px;">Deploy</th>
                                        <th style="width: 90px;">Active</th>
                                        <th style="width: 80px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var assignment in Model.RotationAssignments)
                                    {
                                        Model.Rotations.TryGetValue(assignment.MapRotationId, out var rotation);
                                        <tr>
                                            <td>
                                                <a asp-controller="MapRotations" asp-action="Details" asp-route-id="@assignment.MapRotationId">
                                                    <strong>@(rotation?.Title ?? "Unknown")</strong>
                                                </a>
                                                <br />
                                                <small class="text-muted">
                                                    <code>@assignment.ConfigVariableName</code>
                                                    @if (rotation?.MapRotationMaps != null)
                                                    {
                                                        <span>· @rotation.MapRotationMaps.Count maps</span>
                                                    }
                                                </small>
                                            </td>
                                            <td><span class="badge bg-info">@(rotation?.GameMode ?? "—")</span></td>
                                            <td>
                                                @switch (assignment.DeploymentState)
                                                {
                                                    case DeploymentState.Pending:
                                                        <span class="badge bg-warning text-dark">Pending</span>
                                                        break;
                                                    case DeploymentState.Syncing:
                                                        <span class="badge bg-info">Syncing</span>
                                                        break;
                                                    case DeploymentState.Synced:
                                                        <span class="badge bg-success">Synced</span>
                                                        break;
                                                    case DeploymentState.Failed:
                                                        <span class="badge bg-danger">Failed</span>
                                                        break;
                                                    default:
                                                        <span class="badge bg-secondary">@assignment.DeploymentState</span>
                                                        break;
                                                }
                                            </td>
                                            <td>
                                                @switch (assignment.ActivationState)
                                                {
                                                    case ActivationState.Active:
                                                        <span class="badge bg-success">Active</span>
                                                        break;
                                                    case ActivationState.Activating:
                                                        <span class="badge bg-info">Activating</span>
                                                        break;
                                                    case ActivationState.Inactive:
                                                        <span class="badge bg-secondary">Inactive</span>
                                                        break;
                                                    case ActivationState.Failed:
                                                        <span class="badge bg-danger">Failed</span>
                                                        break;
                                                    default:
                                                        <span class="badge bg-secondary">@assignment.ActivationState</span>
                                                        break;
                                                }
                                            </td>
                                            <td>
                                                <a asp-controller="MapRotations" asp-action="AssignmentStatus" asp-route-id="@assignment.MapRotationServerAssignmentId"
                                                   class="btn btn-outline-secondary btn-xs" title="View Status">
                                                    <i class="fa-solid fa-fw fa-eye"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

        </div>

        <div class="col-sm-6">

            <div class="ibox">
                <div class="ibox-title">
                    <h5>Current Map Rotation - sv_mapRotation</h5>
                </div>

                <div class="ibox-content">
                    <div class="table-responsive">
                        <table id="mapRotationTable" class="table table-striped table-hover w-100">
                        <thead>
                        <tr>
                            <th>
                                @Html.Label("Name")
                            </th>
                            <th>
                                @Html.Label("Game Type")
                            </th>
                            <th>
                                @Html.Label("Files")
                            </th>
                            <th>
                                @Html.Label("Remote Status")
                            </th>
                            <th>
                                @Html.Label("Popularity")
                            </th>
                            <th>
                            </th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model.RconMaps.OrderBy(x => x.MapName))
{
    var map = Model.Maps.FirstOrDefault(x => x.MapName == item.MapName);

                        <tr>
                            <td>
                                @Html.DisplayFor(modelItem => item.MapName)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.GameType)
                            </td>
                            <td>
                                @{
    if (map != null)
    {
        foreach (var mapFile in map.MapFiles)
        {
                                    <li>
                                        <a href="@mapFile.Url">@mapFile.FileName</a>
                                    </li>
        }
    }
    else
    {
                                    <strong>No files found on redirect</strong>
    }
                                }
                            </td>
                            <td>
                                @{
    var remoteMatch = Model.ServerMaps.FirstOrDefault(x => x.Name == item.MapName);
    if (remoteMatch != null)
    {
                                    <span class="badge bg-success">On Host</span>
    }
    else
    {
                                    <span class="badge bg-danger">Not On Host</span>
    }
                                }
                            </td>
                            <td>
                                @if (map != null)
    {
                                <map-popularity name="@item.MapName" like-percentage="@map.LikePercentage" dislike-percentage="@map.DislikePercentage" total-likes="@map.TotalLikes" total-dislikes="@map.TotalDislikes" votes="@map.TotalVotes"></map-popularity>
    }
    else
    {
                                <strong>No popularity data found</strong>
    }
                            </td>
                            <td>
                                @if (map != null)
    {
                                <map-image uri="@map.MapImageUri"></map-image>
    }
                            </td>
                        </tr>
}
                        </tbody>
                    </table>
                    </div>
                </div>
            </div>

        </div>

        <div class="col-sm-4">

            <div class="ibox">
                <div class="ibox-title">
                    <h5>Remote Server Maps</h5>
                </div>

                <div class="ibox-content">
                    <div class="table-responsive">
                        <table id="remoteMapsTable" class="table table-striped table-hover w-100">
                        <tr>
                            <th>
                                @Html.Label("Name")
                            </th>
                            <th>
                                @Html.Label("Path")
                            </th>
                            <th>
                                @Html.Label("Rotation Status")
                            </th>
                            <th>
                                @Html.Label("Modified")
                            </th>
                            <th></th
                        </tr>

                        @foreach (var item in Model.ServerMaps)
{
                        <tr>
                            <td>
                                @Html.DisplayFor(modelItem => item.Name)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.FullName)
                            </td>
                            <td>
                                @{
    if (Model.RconMaps.Any(x => x.MapName == item.Name))
    {
                                    <span class="badge bg-success">In Rotation</span>
    }
    else
    {
                                    <span class="badge bg-danger">Not In Rotation</span>
    }
                                }
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Modified)
                            </td>
                            <td>
                                <partial name="DeleteMapFromHostPartial" model="@(new DeleteMapFromHostModel(Model.GameServer.GameServerId, item.Name))"></partial>
                            </td>
                        </tr>
}

                    </table>
                    </div>
                </div>
            </div>

        </div>

    </div>

</div>

@section Scripts {
    <script src="~/js/map-manager.js" asp-append-version="true"></script>
}
