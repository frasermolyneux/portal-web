@using XtremeIdiots.Portal.Web.Extensions
@using XtremeIdiots.Portal.Web.ViewModels
@using XtremeIdiots.Portal.Repository.Abstractions.Constants.V1
@model ManageMapsViewModel

@{
    ViewData["Title"] = "Map Manager";
}

<div class="wrapper wrapper-content animated fadeInRight">

    <input type="hidden" id="pushMapGameType" value="@Model.GameServer.GameType" />

    <div class="ibox">
        <div class="ibox-title">
            <h5><server-name title="@Model.GameServer.Title" live-title="@Model.LiveStatus?.Title"></server-name> — Map Manager</h5>
            <div class="ibox-tools">
                <span class="badge bg-info me-1">@Model.GameServer.GameType</span>
                @if (Model.LiveStatus != null && Model.LiveStatus.CurrentPlayers != 0)
                {
                    <span class="badge bg-secondary me-1">@Model.LiveStatus.CurrentPlayers / @Model.LiveStatus.MaxPlayers players</span>
                }
                @if (!string.IsNullOrWhiteSpace(Model.LiveStatus?.Map))
                {
                    <span class="badge bg-secondary me-1">@Model.LiveStatus.Map</span>
                }
                @if (!string.IsNullOrWhiteSpace(Model.LiveStatus?.Mod))
                {
                    <span class="badge bg-secondary me-1">@Model.LiveStatus.Mod</span>
                }
                <server-host host="@Model.GameServer.Hostname" port="@Model.GameServer.QueryPort"></server-host>
            </div>
        </div>
        <div class="ibox-content">
            <ul class="nav nav-tabs" id="mapManagerTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="rotation-tab-btn" data-bs-toggle="tab"
                        data-bs-target="#rotation-tab" type="button" role="tab"
                        aria-controls="rotation-tab" aria-selected="true">
                        <i class="fa-solid fa-fw fa-rotate me-1"></i>Current Rotation
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="remote-tab-btn" data-bs-toggle="tab"
                        data-bs-target="#remote-tab" type="button" role="tab"
                        aria-controls="remote-tab" aria-selected="false">
                        <i class="fa-solid fa-fw fa-server me-1"></i>Maps on Server
                        <span class="badge bg-secondary ms-1">@Model.ServerMaps.Count</span>
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="assignments-tab-btn" data-bs-toggle="tab"
                        data-bs-target="#assignments-tab" type="button" role="tab"
                        aria-controls="assignments-tab" aria-selected="false">
                        <i class="fa-solid fa-fw fa-list me-1"></i>Map Rotations
                        <span class="badge bg-secondary ms-1">@Model.RotationAssignments.Count</span>
                    </button>
                </li>
            </ul>

            <div class="tab-content pt-3">
                @{
                    var mapsById = Model.Maps.ToDictionary(m => m.MapId);
                    var mapsByName = Model.Maps.ToDictionary(m => m.MapName, StringComparer.OrdinalIgnoreCase);
                    var serverMapNames = Model.ServerMaps.Select(m => m.Name).ToHashSet(StringComparer.OrdinalIgnoreCase);
                    var serverMapsByName = Model.ServerMaps.ToDictionary(m => m.Name, StringComparer.OrdinalIgnoreCase);

                    var activeRotMaps = Model.ActiveRotation?.MapRotationMaps ?? [];
                    var missingFromHost = activeRotMaps.Count(rm =>
                    {
                        var mn = mapsById.TryGetValue(rm.MapId, out var m) ? m.MapName : null;
                        return mn != null && !serverMapNames.Contains(mn);
                    });
                    var problematicCount = activeRotMaps.Count(rm => mapsById.TryGetValue(rm.MapId, out var m) && m.MapStatus == MapHealthStatus.Problematic);
                    var blacklistedCount = activeRotMaps.Count(rm => mapsById.TryGetValue(rm.MapId, out var m) && m.MapStatus == MapHealthStatus.Blacklisted);
                    var sortedRotMaps = Model.ActiveRotation?.MapRotationMaps?.OrderBy(m => m.SortOrder).ToList() ?? [];
                }

                @* Tab 1: Current Rotation *@
                <div class="tab-pane fade show active" id="rotation-tab" role="tabpanel" aria-labelledby="rotation-tab-btn">
                    @if (Model.ActiveRotation != null)
                    {
                        <div class="mb-3">
                            <h6>
                                <a asp-controller="MapRotations" asp-action="Details" asp-route-id="@Model.ActiveRotation.MapRotationId">@Model.ActiveRotation.Title</a>
                            </h6>
                            <span class="badge bg-info">@Model.ActiveRotation.GameMode</span>
                            <span class="badge bg-success">Active</span>
                            <small class="text-muted ms-2">
                                <code>@Model.ActiveAssignment?.ConfigVariableName</code>
                                @if (!string.IsNullOrEmpty(Model.ActiveAssignment?.ConfigFilePath))
                                {
                                    <span>in <code>@Model.ActiveAssignment.ConfigFilePath</code></span>
                                }
                                · @(Model.ActiveRotation.MapRotationMaps?.Count ?? 0) maps · Version @Model.ActiveRotation.Version
                            </small>
                        </div>
                        @if (missingFromHost > 0 || problematicCount > 0 || blacklistedCount > 0)
                        {
                            <div class="alert alert-warning py-2 mb-3">
                                <i class="fa-solid fa-triangle-exclamation me-1"></i>
                                <strong>Health warnings:</strong>
                                @if (missingFromHost > 0)
                                {
                                    <span class="ms-2"><span class="badge bg-danger"><i class="fa-solid fa-cloud-arrow-up"></i> @missingFromHost Not On Host</span></span>
                                }
                                @if (blacklistedCount > 0)
                                {
                                    <span class="ms-2"><span class="badge bg-danger"><i class="fa-solid fa-ban"></i> @blacklistedCount Blacklisted</span></span>
                                }
                                @if (problematicCount > 0)
                                {
                                    <span class="ms-2"><span class="badge bg-warning text-dark"><i class="fa-solid fa-triangle-exclamation"></i> @problematicCount Problematic</span></span>
                                }
                            </div>
                        }
                        <div class="table-responsive">
                            <table id="mapRotationTable" class="table table-striped table-hover w-100">
                                <thead>
                                    <tr>
                                        <th style="width: 40px;">#</th>
                                        <th>Name</th>
                                        <th>Map Files</th>
                                        <th style="width: 110px;">Remote Status</th>
                                        <th style="width: 120px;">Popularity</th>
                                        <th style="width: 80px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (var i = 0; i < sortedRotMaps.Count; i++)
                                    {
                                        var rotMap = sortedRotMaps[i];
                                        mapsById.TryGetValue(rotMap.MapId, out var map);
                                        var mapName = map?.MapName ?? rotMap.MapId.ToString();
                                        var remoteMatch = serverMapsByName.ContainsKey(mapName);
                                        <tr>
                                            <td><small class="text-muted">@(i + 1)</small></td>
                                            <td>
                                                @mapName
                                                @if (map?.MapStatus == MapHealthStatus.Blacklisted)
                                                {
                                                    <span class="badge bg-danger ms-1" title="This map is blacklisted"><i class="fa-solid fa-ban"></i> Blacklisted</span>
                                                }
                                                else if (map?.MapStatus == MapHealthStatus.Problematic)
                                                {
                                                    <span class="badge bg-warning text-dark ms-1" title="This map has known issues"><i class="fa-solid fa-triangle-exclamation"></i> Problematic</span>
                                                }
                                            </td>
                                            <td>
                                                @if (map?.MapFiles != null && map.MapFiles.Count > 0)
                                                {
                                                    <ul class="list-unstyled mb-0 map-files">
                                                        @foreach (var file in map.MapFiles)
                                                        {
                                                            <li><a href="@file.Url">@file.FileName</a></li>
                                                        }
                                                    </ul>
                                                }
                                                else if (BuiltInMaps.IsBuiltIn(Model.GameServer.GameType, map?.MapName ?? ""))
                                                {
                                                    <span class="badge bg-info">Built-in</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">No Map Files</span>
                                                }
                                            </td>
                                            <td>
                                                @if (remoteMatch)
                                                {
                                                    <span class="badge bg-success">On Host</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger"><i class="fa-solid fa-cloud-arrow-up"></i> Not On Host</span>
                                                }
                                            </td>
                                            <td>
                                                @if (map != null)
                                                {
                                                    <map-popularity name="@mapName" like-percentage="@map.LikePercentage" dislike-percentage="@map.DislikePercentage" total-likes="@map.TotalLikes" total-dislikes="@map.TotalDislikes" votes="@map.TotalVotes"></map-popularity>
                                                }
                                            </td>
                                            <td>
                                                @if (map != null)
                                                {
                                                    <map-image uri="@map.MapImageUri"></map-image>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else if (Model.RconMaps.Count > 0)
                    {
                        <div class="mb-3">
                            <h6>sv_mapRotation (from RCON)</h6>
                            <small class="text-muted">No portal-managed rotation is active. Showing maps parsed from RCON.</small>
                        </div>
                        <div class="table-responsive">
                            <table id="mapRotationTable" class="table table-striped table-hover w-100">
                                <thead>
                                    <tr>
                                        <th style="width: 40px;">#</th>
                                        <th>Name</th>
                                        <th>Map Files</th>
                                        <th style="width: 110px;">Remote Status</th>
                                        <th style="width: 120px;">Popularity</th>
                                        <th style="width: 80px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{ var rconIndex = 0; }
                                    @foreach (var item in Model.RconMaps.OrderBy(x => x.MapName))
                                    {
                                        rconIndex++;
                                        mapsByName.TryGetValue(item.MapName, out var map);
                                        var remoteMatch = serverMapsByName.ContainsKey(item.MapName);
                                        <tr>
                                            <td><small class="text-muted">@rconIndex</small></td>
                                            <td>
                                                @item.MapName
                                                @if (map?.MapStatus == MapHealthStatus.Blacklisted)
                                                {
                                                    <span class="badge bg-danger ms-1" title="This map is blacklisted"><i class="fa-solid fa-ban"></i> Blacklisted</span>
                                                }
                                                else if (map?.MapStatus == MapHealthStatus.Problematic)
                                                {
                                                    <span class="badge bg-warning text-dark ms-1" title="This map has known issues"><i class="fa-solid fa-triangle-exclamation"></i> Problematic</span>
                                                }
                                            </td>
                                            <td>
                                                @if (map?.MapFiles != null && map.MapFiles.Count > 0)
                                                {
                                                    <ul class="list-unstyled mb-0 map-files">
                                                        @foreach (var file in map.MapFiles)
                                                        {
                                                            <li><a href="@file.Url">@file.FileName</a></li>
                                                        }
                                                    </ul>
                                                }
                                                else if (BuiltInMaps.IsBuiltIn(Model.GameServer.GameType, map?.MapName ?? ""))
                                                {
                                                    <span class="badge bg-info">Built-in</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">No Map Files</span>
                                                }
                                            </td>
                                            <td>
                                                @if (remoteMatch)
                                                {
                                                    <span class="badge bg-success">On Host</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger"><i class="fa-solid fa-cloud-arrow-up"></i> Not On Host</span>
                                                }
                                            </td>
                                            <td>
                                                @if (map != null)
                                                {
                                                    <map-popularity name="@item.MapName" like-percentage="@map.LikePercentage" dislike-percentage="@map.DislikePercentage" total-likes="@map.TotalLikes" total-dislikes="@map.TotalDislikes" votes="@map.TotalVotes"></map-popularity>
                                                }
                                            </td>
                                            <td>
                                                @if (map != null)
                                                {
                                                    <map-image uri="@map.MapImageUri"></map-image>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">
                            <i class="fa-solid fa-rotate fa-2x mb-2 d-block"></i>
                            <p>No map rotation data available.</p>
                            <a asp-controller="MapRotations" asp-action="Index" asp-route-gameType="@Model.GameServer.GameType" class="btn btn-outline-primary btn-sm">
                                <i class="fa-solid fa-fw fa-plus"></i> Set Up a Rotation
                            </a>
                        </div>
                    }
                </div>

                @* Tab 2: Maps on Server *@
                <div class="tab-pane fade" id="remote-tab" role="tabpanel" aria-labelledby="remote-tab-btn">
                    <div class="row">
                        <div class="col-md-9">
                            <div class="table-responsive">
                                <table id="remoteMapsTable" class="table table-striped table-hover w-100">
                                    <thead>
                                        <tr>
                                            <th>Name</th>
                                            <th>Path</th>
                                            <th style="width: 110px;">Rotation Status</th>
                                            <th style="width: 100px;">Health</th>
                                            <th style="width: 120px;">Modified</th>
                                            <th style="width: 60px;"></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model.ServerMaps)
                                        {
                                            mapsByName.TryGetValue(item.Name, out var portalMap);
                                            <tr>
                                                <td>@item.Name</td>
                                                <td><small class="text-muted">@item.FullName</small></td>
                                                <td>
                                                    @{
                                                        var inPortalRotation = Model.ActiveRotationMapNames.Contains(item.Name);
                                                        var inRconRotation = Model.RconMaps.Any(x => x.MapName == item.Name);
                                                        if (inPortalRotation || inRconRotation)
                                                        {
                                                            <span class="badge bg-success">In Rotation</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-danger">Not In Rotation</span>
                                                        }
                                                    }
                                                </td>
                                                <td>
                                                    @if (portalMap?.MapStatus == MapHealthStatus.Blacklisted)
                                                    {
                                                        <span class="badge bg-danger" title="This map is blacklisted"><i class="fa-solid fa-ban"></i> Blacklisted</span>
                                                    }
                                                    else if (portalMap?.MapStatus == MapHealthStatus.Problematic)
                                                    {
                                                        <span class="badge bg-warning text-dark" title="This map has known issues"><i class="fa-solid fa-triangle-exclamation"></i> Problematic</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-light text-muted">OK</span>
                                                    }
                                                </td>
                                                <td><small>@item.Modified.ToString("yyyy-MM-dd")</small></td>
                                                <td>
                                                    <partial name="DeleteMapFromHostPartial" model="@(new DeleteMapFromHostModel(Model.GameServer.GameServerId, item.Name))"></partial>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <partial name="PushMapToRemotePartial"
                                model="@(new PushMapToRemoteViewModel(Model.GameServer.GameServerId))"></partial>
                        </div>
                    </div>
                </div>

                @* Tab 3: Map Rotations *@
                <div class="tab-pane fade" id="assignments-tab" role="tabpanel" aria-labelledby="assignments-tab-btn">
                    @if (Model.RotationAssignments.Count == 0)
                    {
                        <div class="text-center text-muted py-4">
                            <i class="fa-solid fa-rotate fa-2x mb-2 d-block"></i>
                            <p>No map rotations assigned to this server.</p>
                            <a asp-controller="MapRotations" asp-action="Index" asp-route-gameType="@Model.GameServer.GameType" class="btn btn-outline-primary btn-sm">
                                <i class="fa-solid fa-fw fa-plus"></i> Manage Rotations
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="mb-2">
                            <a asp-controller="MapRotations" asp-action="Index" asp-route-gameType="@Model.GameServer.GameType" class="btn btn-outline-secondary btn-sm">
                                <i class="fa-solid fa-fw fa-list"></i> All Rotations
                            </a>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th>Rotation</th>
                                        <th style="width: 80px;">Mode</th>
                                        <th style="width: 80px;">Health</th>
                                        <th style="width: 90px;">Deploy</th>
                                        <th style="width: 90px;">Active</th>
                                        <th style="width: 80px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var assignment in Model.RotationAssignments)
                                    {
                                        Model.Rotations.TryGetValue(assignment.MapRotationId, out var rotation);
                                        <tr>
                                            <td>
                                                <a asp-controller="MapRotations" asp-action="Details" asp-route-id="@assignment.MapRotationId">
                                                    <strong>@(rotation?.Title ?? "Unknown")</strong>
                                                </a>
                                                <br />
                                                <small class="text-muted">
                                                    <code>@assignment.ConfigVariableName</code>
                                                    @if (rotation?.MapRotationMaps != null)
                                                    {
                                                        <span>· @rotation.MapRotationMaps.Count maps</span>
                                                    }
                                                </small>
                                            </td>
                                            <td><span class="badge bg-info">@(rotation?.GameMode ?? "—")</span></td>
                                            <td>
                                                @{
                                                    var rotMaps = rotation?.MapRotationMaps ?? [];
                                                    var healthIssues = rotMaps.Count(rm => mapsById.TryGetValue(rm.MapId, out var m) && m.MapStatus != MapHealthStatus.OK);
                                                    var notOnHost = rotMaps.Count(rm => mapsById.TryGetValue(rm.MapId, out var m) && m.MapName != null && !serverMapNames.Contains(m.MapName));
                                                    var totalWarnings = healthIssues + notOnHost;
                                                }
                                                @if (totalWarnings > 0)
                                                {
                                                    <span class="badge bg-warning text-dark" title="@healthIssues health issue(s), @notOnHost not on host">
                                                        <i class="fa-solid fa-triangle-exclamation"></i> @totalWarnings
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-light text-muted">OK</span>
                                                }
                                            </td>
                                            <td>
                                                @switch (assignment.DeploymentState)
                                                {
                                                    case DeploymentState.Pending: <span class="badge bg-warning text-dark">Pending</span> break;
                                                    case DeploymentState.Syncing: <span class="badge bg-info">Syncing</span> break;
                                                    case DeploymentState.Synced: <span class="badge bg-success">Synced</span> break;
                                                    case DeploymentState.PartiallyDeployed: <span class="badge bg-warning text-dark">Partially Deployed</span> break;
                                                    case DeploymentState.Failed: <span class="badge bg-danger">Failed</span> break;
                                                    default: <span class="badge bg-secondary">@assignment.DeploymentState</span> break;
                                                }
                                            </td>
                                            <td>
                                                @switch (assignment.ActivationState)
                                                {
                                                    case ActivationState.Active: <span class="badge bg-success">Active</span> break;
                                                    case ActivationState.Activating: <span class="badge bg-info">Activating</span> break;
                                                    case ActivationState.Inactive: <span class="badge bg-secondary">Inactive</span> break;
                                                    case ActivationState.Failed: <span class="badge bg-danger">Failed</span> break;
                                                    default: <span class="badge bg-secondary">@assignment.ActivationState</span> break;
                                                }
                                            </td>
                                            <td>
                                                <a asp-controller="MapRotations" asp-action="AssignmentStatus" asp-route-id="@assignment.MapRotationServerAssignmentId"
                                                   class="btn btn-outline-secondary btn-sm" title="View Status">
                                                    <i class="fa-solid fa-fw fa-eye"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>

            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script src="~/js/map-manager.js" asp-append-version="true"></script>
}
