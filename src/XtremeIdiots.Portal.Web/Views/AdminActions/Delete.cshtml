@using XtremeIdiots.Portal.Repository.Abstractions.Models.V1.AdminActions
@model AdminActionDto

@{
    ViewData["Title"] = $"Delete {Model?.Type.ToString() ?? "Admin Action"}";
    ViewData["Description"] = "Delete admin action confirmation page";
}

<div class="wrapper wrapper-content animated FadeInRight">
    <div class="alert alert-primary" role="alert">
        <i class="fa-solid fa-fw fa-circle-info" aria-hidden="true"></i>
        Admin actions should only be deleted for data correction or to remove test data.
    </div>

    <div class="row">
        <div class="col-12">
            <div class="ibox">
                <div class="ibox-title">
                    <h5>@ViewData["Title"]</h5>
                </div>
                <div class="ibox-content">
                    <p>Are you sure you want to delete this admin action?</p>
                    <div class="alert alert-warning mb-3">
                        <i class="fa-solid fa-fw fa-triangle-exclamation" aria-hidden="true"></i>
                        This action cannot be undone. The admin action record will be permanently deleted. Any associated forum topic will not be removed.
                    </div>
                    <dl class="detail-fields row">
                        <div class="detail-field col-sm-6">
                            <dt class="detail-label">@Html.DisplayNameFor(model => model.Type)</dt>
                            <dd class="detail-value">@Html.DisplayFor(model => model.Type)</dd>
                        </div>
                        <div class="detail-field col-sm-6">
                            <dt class="detail-label">@Html.DisplayNameFor(model => model.Player.Username)</dt>
                            <dd class="detail-value"><player-name value="@Model.Player?.Username"></player-name></dd>
                        </div>
                        <div class="detail-field col-sm-12">
                            <dt class="detail-label">@Html.DisplayNameFor(model => model.Text)</dt>
                            <dd class="detail-value">@Html.Raw(Model?.Text ?? string.Empty)</dd>
                        </div>
                    </dl>
                </div>
                <div class="ibox-footer">
                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="AdminActionId" />
                        <input type="hidden" asp-for="PlayerId" />
                        <a class="btn btn-outline-secondary" asp-controller="Players" asp-action="Details"
                            asp-route-id="@Model?.PlayerId" aria-label="Return to player details">
                            Cancel
                        </a>
                        <button type="submit" class="btn btn-danger" aria-label="Confirm deletion">
                            <i class="fa-solid fa-fw fa-trash"></i> Delete Admin Action
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
