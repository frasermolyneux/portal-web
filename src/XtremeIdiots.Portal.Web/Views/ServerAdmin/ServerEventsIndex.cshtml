@using XtremeIdiots.Portal.Repository.Abstractions.Constants.V1
@using XtremeIdiots.Portal.Repository.Abstractions.Extensions.V1
@{
    ViewData["Title"] = "Server Events";
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="row">
        <div class="col-12">
            <div class="admin-actions-filters mb-2" id="serverEventsFilters">
                <div class="filter-group">
                    <label for="filterGameType" class="form-label">Game Type</label>
                    <select id="filterGameType" class="form-select">
                        <option value="">All Games</option>
                        @foreach (var gt in Enum.GetValues<GameType>())
                        {
                            <option value="@gt">@gt.DisplayName()</option>
                        }
                    </select>
                </div>
                <div class="filter-group">
                    <label for="filterGameServer" class="form-label">Server</label>
                    <select id="filterGameServer" class="form-select">
                        <option value="">All Servers</option>
                    </select>
                </div>
                <div class="filter-group reset-group">
                    <label class="form-label" for="resetFilters">Reset</label>
                    <button type="button" id="resetFilters" class="btn btn-outline-secondary btn-sm">Clear Filters</button>
                </div>
            </div>

            <div class="ibox">
                <div class="ibox-title">
                    <i class="fa-solid fa-timeline"></i> @ViewData["Title"]
                </div>
                <div class="ibox-content">
                    <div class="table-responsive">
                        <table id="dataTable" class="table table-striped table-hover w-100">
                            <thead>
                                <tr>
                                    <th>Timestamp</th>
                                    <th>Event Type</th>
                                    <th>Server</th>
                                    <th>Event Data</th>
                                </tr>
                            </thead>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <form id="__af" method="post" style="display:none">@Html.AntiForgeryToken()</form>
    <script src="~/js/server-events-index.js" asp-append-version="true"></script>
}
