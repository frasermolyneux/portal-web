@using XtremeIdiots.Portal.Web.Extensions
@using XtremeIdiots.Portal.Web.Services
@using XtremeIdiots.Portal.Web.ViewModels
@using XtremeIdiots.Portal.Repository.Abstractions.Constants.V1
@using XtremeIdiots.Portal.Settings.Contracts.V1.Contracts.Cod4xPlugin
@model ServerDetailViewModel

@{
    ViewData["Title"] = "Server Detail - " + (string.IsNullOrWhiteSpace(Model.LiveStatus?.Title) ? Model.GameServer.Title : Model.LiveStatus.Title);

    var gs = Model.GameServer;
    var liveStatus = Model.LiveStatus;
    var serverTitle = string.IsNullOrWhiteSpace(liveStatus?.Title) ? gs.Title : liveStatus.Title;
    var serverId = gs.GameServerId;
    var selectedCod4xTargetVersion = !string.IsNullOrWhiteSpace(Model.Cod4xOperationRequestTargetVersion)
        ? Model.Cod4xOperationRequestTargetVersion
        : Model.Cod4xRuntimeCurrentVersion;
}

<div class="wrapper wrapper-content animated fadeInRight">

    @* ─── Server Header ─── *@
    <div class="row mb-3">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <h4 class="mb-0">
                    <game-type-icon game="@gs.GameType" size="24" class="me-2" />
                    <server-name title="@gs.Title" live-title="@liveStatus?.Title" />
                    @if (liveStatus != null)
                    {
                        <small class="text-muted ms-2">@liveStatus.CurrentPlayers / @liveStatus.MaxPlayers players</small>
                    }
                </h4>
                <div>
                    @if (Model.CanEditServer)
                    {
                        <a asp-controller="GameServers" asp-action="Edit" asp-route-id="@serverId"
                           class="btn btn-sm btn-outline-secondary" title="Server configuration">
                            <i class="fa-solid fa-fw fa-gear"></i> Settings
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>

    @* ─── Tabs ─── *@
    <ul class="nav nav-tabs" id="serverDetailTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="overview-tab" data-bs-toggle="tab" data-bs-target="#overview"
                    type="button" role="tab" aria-controls="overview" aria-selected="true">
                <i class="fa-solid fa-fw fa-circle-info"></i> Overview
            </button>
        </li>
        @if (Model.CanViewRcon)
        {
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="mapcontrol-tab" data-bs-toggle="tab" data-bs-target="#mapcontrol"
                        type="button" role="tab" aria-controls="mapcontrol" aria-selected="false">
                    <i class="fa-solid fa-fw fa-map"></i> Map Control
                </button>
            </li>
        }
        @if (Model.CanViewStatus)
        {
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="agentstatus-tab" data-bs-toggle="tab" data-bs-target="#agentstatus"
                        type="button" role="tab" aria-controls="agentstatus" aria-selected="false">
                    <i class="fa-solid fa-fw fa-robot"></i> Agent & Ban File
                </button>
            </li>
        }
        <li class="nav-item" role="presentation" policy="@AuthPolicies.Dashboard_Read">
            <button class="nav-link" id="analytics-tab" data-bs-toggle="tab" data-bs-target="#analytics"
                    type="button" role="tab" aria-controls="analytics" aria-selected="false">
                <i class="fa-solid fa-fw fa-chart-line"></i> Analytics
            </button>
        </li>
    </ul>

    <div class="tab-content pt-3" id="serverDetailTabContent">

        @* ═══ OVERVIEW TAB (merged with Live Players) ═══ *@
        <div class="tab-pane fade show active" id="overview" role="tabpanel" aria-labelledby="overview-tab">
            <div class="row">
                <div class="col-md-4">
                    <div class="ibox">
                        <div class="ibox-title"><h5>Server Info</h5></div>
                        <div class="ibox-content">
                            <dl class="row mb-0">
                                <dt class="col-5">Hostname</dt>
                                <dd class="col-7"><server-host host="@gs.Hostname" port="@gs.QueryPort"></server-host></dd>
                                <dt class="col-5">Game</dt>
                                <dd class="col-7"><game-type-icon game="@gs.GameType" size="16" /> @gs.GameType</dd>
                                <dt class="col-5">Platform</dt>
                                <dd class="col-7">@gs.Platform</dd>
                                @if (!string.IsNullOrWhiteSpace(liveStatus?.Map))
                                {
                                    <dt class="col-5">Current Map</dt>
                                    <dd class="col-7">@liveStatus.Map</dd>
                                }
                                @if (!string.IsNullOrWhiteSpace(liveStatus?.Mod))
                                {
                                    <dt class="col-5">Mod</dt>
                                    <dd class="col-7">@liveStatus.Mod</dd>
                                }
                                <dt class="col-5">Players</dt>
                                <dd class="col-7">@(liveStatus?.CurrentPlayers ?? 0) / @(liveStatus?.MaxPlayers ?? 0)</dd>
                                @if (liveStatus?.LastUpdated.HasValue == true)
                                {
                                    <dt class="col-5">Last Updated</dt>
                                    <dd class="col-7">
                                        @{
                                            var elapsed = DateTime.UtcNow - liveStatus.LastUpdated.Value;
                                            var freshness = elapsed.TotalMinutes < 2 ? "text-success" : elapsed.TotalMinutes < 5 ? "text-warning" : "text-danger";
                                        }
                                        <span class="@freshness">
                                            @if (elapsed.TotalMinutes < 1) { @($"{(int)elapsed.TotalSeconds}s ago") }
                                            else if (elapsed.TotalHours < 1) { @($"{(int)elapsed.TotalMinutes}m ago") }
                                            else { @($"{(int)elapsed.TotalHours}h ago") }
                                        </span>
                                    </dd>
                                }
                            </dl>
                        </div>
                    </div>

                    @* Agent Status Card *@
                    <div class="ibox">
                        <div class="ibox-title"><h5>Agent Status</h5></div>
                        <div class="ibox-content">
                            @if (Model.AgentStatus is not null)
                            {
                                var statusClass = Model.AgentStatus.ActivityStatus switch
                                {
                                    AgentActivityStatus.Active => "bg-success",
                                    AgentActivityStatus.Idle => "bg-info",
                                    AgentActivityStatus.Offline => "bg-danger",
                                    _ => "bg-secondary"
                                };
                                <p><span class="badge @statusClass">@Model.AgentStatus.ActivityStatus</span></p>
                                <dl class="row mb-0">
                                    <dt class="col-6">Events/Hour</dt>
                                    <dd class="col-6">@Model.AgentStatus.EventsLastHour</dd>
                                    <dt class="col-6">Chat/Hour</dt>
                                    <dd class="col-6">@Model.AgentStatus.ChatMessagesLastHour</dd>
                                    @if (Model.AgentStatus.LastEventReceived.HasValue)
                                    {
                                        <dt class="col-6">Last Event</dt>
                                        <dd class="col-6">
                                            @{
                                                var agentElapsed = DateTime.UtcNow - Model.AgentStatus.LastEventReceived.Value;
                                            }
                                            @if (agentElapsed.TotalMinutes < 1) { @($"{(int)agentElapsed.TotalSeconds}s ago") }
                                            else if (agentElapsed.TotalHours < 1) { @($"{(int)agentElapsed.TotalMinutes}m ago") }
                                            else { <span class="text-danger">@($"{(int)agentElapsed.TotalHours}h ago")</span> }
                                        </dd>
                                    }
                                </dl>
                            }
                            else
                            {
                                <p class="text-muted">Agent telemetry unavailable</p>
                            }
                        </div>
                    </div>

                    @* Player Count Chart *@
                    @if (Model.GameServerStats.Any())
                    {
                        <div class="ibox">
                            <div class="ibox-title"><h5>Player Count <small class="text-muted">(48h)</small></h5></div>
                            <div class="ibox-content">
                                <div id="sd-playerCountChart" style="height: 200px; width: 100%;"></div>
                            </div>
                        </div>
                    }

                    @* Quick Actions + Server Control *@
                    <div class="ibox">
                        <div class="ibox-title"><h5>Server Control</h5></div>
                        <div class="ibox-content">
                            <div class="d-grid gap-2">
                                @if (Model.CanRestartServer)
                                {
                                    <button id="sd-restartServer" class="btn btn-danger btn-sm" type="button">
                                        <i class="fa-solid fa-fw fa-arrows-rotate"></i> Restart Server
                                    </button>
                                }
                                @if (Model.CanEditServer)
                                {
                                    <a asp-controller="GameServers" asp-action="Edit" asp-route-id="@serverId"
                                       class="btn btn-outline-secondary btn-sm">
                                        <i class="fa-solid fa-fw fa-gear"></i> Server Settings
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                @* Live Players (merged into Overview) *@
                <div class="col-md-8">
                    @if (Model.CanViewChatLog)
                    {
                        <div class="ibox">
                            <div class="ibox-title">
                                <h5>
                                    Server Feed
                                    <span class="badge bg-secondary ms-2" id="sd-feedPendingCount" style="display: none;">0 new</span>
                                    <span class="badge bg-warning text-dark ms-1" id="sd-feedOverrunIndicator" style="display: none;" title="Feed volume is high — some items may be truncated"><i class="fa-solid fa-fw fa-triangle-exclamation"></i> High volume</span>
                                </h5>
                                <div class="ibox-tools d-flex align-items-center gap-2">
                                    <div class="form-check form-check-inline mb-0">
                                        <input class="form-check-input" type="checkbox" id="sd-feedToggleChat" checked>
                                        <label class="form-check-label" for="sd-feedToggleChat">Chat</label>
                                    </div>
                                    <div class="form-check form-check-inline mb-0">
                                        <input class="form-check-input" type="checkbox" id="sd-feedToggleEvents" @(Model.CanViewFeedEvents ? "checked" : "") @(!Model.CanViewFeedEvents ? "disabled" : "")>
                                        <label class="form-check-label" for="sd-feedToggleEvents">Events</label>
                                    </div>
                                    <input type="text" id="sd-feedEventFilter" class="form-control form-control-sm" placeholder="Filter event type" style="width: 180px;" @(Model.CanViewFeedEvents ? "" : "disabled") />
                                    <button id="sd-toggleRefresh" class="btn btn-sm btn-outline-info" type="button">
                                        <i class="fa-solid fa-fw fa-pause"></i> Pause
                                    </button>
                                </div>
                            </div>
                            <div class="ibox-content" style="max-height: 420px; overflow-y: auto;" id="sd-feedContainer" role="log">
                                <div id="sd-feedItems">
                                    <p class="text-muted text-center"><i class="fa-solid fa-fw fa-spinner fa-spin"></i> Loading server feed...</p>
                                </div>
                            </div>
                            <div class="ibox-footer">
                                @if (!Model.CanViewFeedEvents)
                                {
                                    <small class="text-muted me-3">Event entries are unavailable for your role on this server.</small>
                                }

                                @if (Model.CanSay)
                                {
                                    <form id="sd-sayForm" class="d-flex gap-2">
                                        <input type="text" id="sd-sayMessage" class="form-control form-control-sm"
                                               placeholder="Type a message to send to server...">
                                        <button type="submit" class="btn btn-sm btn-primary">
                                            <i class="fa-solid fa-fw fa-paper-plane"></i> Send
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    }

                    @if (Model.CanViewRcon)
                    {
                        <div class="ibox">
                            <div class="ibox-title">
                                <h5>Connected Players</h5>
                                @if (!Model.CanViewChatLog)
                                {
                                    <div class="ibox-tools">
                                        <button id="sd-toggleRefresh" class="btn btn-sm btn-outline-info" type="button">
                                            <i class="fa-solid fa-fw fa-pause"></i> Pause
                                        </button>
                                    </div>
                                }
                            </div>
                            <div class="ibox-content">
                                <div class="table-responsive">
                                    <table id="sd-playersTable" class="table table-striped table-hover w-100">
                                        <thead>
                                            <tr>
                                                <th scope="col">#</th>
                                                <th scope="col">Username</th>
                                                <th scope="col">Guid</th>
                                                <th scope="col">IP Address</th>
                                                <th scope="col">Rate</th>
                                                <th scope="col">Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody></tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    }

                </div>
            </div>
        </div>

        @* ═══ MAP CONTROL TAB (with timeline + current map highlight) ═══ *@
        @if (Model.CanViewRcon)
        {
            <div class="tab-pane fade" id="mapcontrol" role="tabpanel" aria-labelledby="mapcontrol-tab">
                <div class="row">
                    <div class="col-lg-8">
                        @* Current Map Display *@
                        <div class="ibox">
                            <div class="ibox-title"><h5>Current Map</h5></div>
                            <div class="ibox-content">
                                <div class="d-flex align-items-center">
                                    <div class="me-3">
                                        <img id="sd-currentMapImage" src="/images/noimage.jpg" alt="Current Map"
                                             class="img-fluid" style="max-height: 100px; width: auto;">
                                    </div>
                                    <div>
                                        <h5 class="mb-1" id="sd-currentMapName">@(liveStatus?.Map ?? "Loading...")</h5>
                                        <small class="text-muted">
                                            <span id="sd-playerCount">@(liveStatus?.CurrentPlayers ?? 0)</span> / <span id="sd-maxPlayers">@(liveStatus?.MaxPlayers ?? 0)</span> players
                                        </small>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @* Map Rotation Carousel *@
                        <div class="ibox">
                            <div class="ibox-title"><h5>Map Rotation</h5></div>
                            <div class="ibox-content">
                                <div id="sd-mapRotationContainer" style="display: none;">
                                    <div id="sd-mapRotationCarousel" class="d-flex overflow-auto gap-2 pb-2" style="scroll-behavior: smooth;"></div>
                                </div>
                                <div id="sd-mapRotationLoading" class="text-center text-muted">
                                    <i class="fa fa-spinner fa-spin"></i> Loading map rotation...
                                </div>
                                <div id="sd-mapRotationError" class="text-center text-danger" style="display: none;"></div>
                            </div>
                        </div>

                        @* Map Timeline (Google Charts) *@
                        @if (Model.MapTimelineDataPoints.Any())
                        {
                            <div class="ibox">
                                <div class="ibox-title"><h5>Map Timeline <small class="text-muted">(24h)</small></h5></div>
                                <div class="ibox-content">
                                    @{
                                        var mapTimelineHeight = Model.GameServerStats.GroupBy(m => m.MapName).ToList().Count * 41 + 50;
                                    }
                                    <div id="sd-mapsTimeline" style="height: @(mapTimelineHeight)px; width: 100%;"></div>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="col-lg-4">
                        <div class="ibox">
                            <div class="ibox-title"><h5>Map Actions</h5></div>
                            <div class="ibox-content">
                                <div class="d-grid gap-2">
                                    @if (Model.CanChangeMap)
                                    {
                                    <button id="sd-restartMap" class="btn btn-primary" type="button">
                                        <i class="fa-solid fa-fw fa-arrows-rotate"></i> Restart Map
                                    </button>
                                    <button id="sd-fastRestartMap" class="btn btn-primary" type="button">
                                        <i class="fa-solid fa-fw fa-arrows-rotate"></i> Fast Restart
                                    </button>
                                    <button id="sd-nextMap" class="btn btn-primary" type="button">
                                        <i class="fa-solid fa-fw fa-forward"></i> Next Map
                                    </button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        @* ═══ AGENT & BAN FILE TAB ═══ *@
        @if (Model.CanViewStatus)
        {
            <div class="tab-pane fade" id="agentstatus" role="tabpanel" aria-labelledby="agentstatus-tab">
                <div class="row">
                    <div class="col-md-6">
                        <div class="ibox">
                            <div class="ibox-title"><h5>Agent Telemetry</h5></div>
                            <div class="ibox-content">
                                @if (Model.AgentStatus is not null)
                                {
                                    var statusClass2 = Model.AgentStatus.ActivityStatus switch
                                    {
                                        AgentActivityStatus.Active => "bg-success",
                                        AgentActivityStatus.Idle => "bg-info",
                                        AgentActivityStatus.Offline => "bg-danger",
                                        _ => "bg-secondary"
                                    };
                                    <dl class="row mb-0">
                                        <dt class="col-6">Status</dt>
                                        <dd class="col-6"><span class="badge @statusClass2">@Model.AgentStatus.ActivityStatus</span></dd>
                                        <dt class="col-6">Events/Hour</dt>
                                        <dd class="col-6">@Model.AgentStatus.EventsLastHour</dd>
                                        <dt class="col-6">Players Connected/Hour</dt>
                                        <dd class="col-6">@Model.AgentStatus.PlayersConnectedLastHour</dd>
                                        <dt class="col-6">Chat Messages/Hour</dt>
                                        <dd class="col-6">@Model.AgentStatus.ChatMessagesLastHour</dd>
                                        <dt class="col-6">Bans Detected (24h)</dt>
                                        <dd class="col-6">@Model.AgentStatus.BansDetectedLast24h</dd>
                                        <dt class="col-6">Moderation Triggers (24h)</dt>
                                        <dd class="col-6">@Model.AgentStatus.ModerationTriggersLast24h</dd>
                                        @if (Model.AgentStatus.LastMapChange.HasValue)
                                        {
                                            <dt class="col-6">Last Map Change</dt>
                                            <dd class="col-6">@Model.AgentStatus.LastMapChange.Value.ToString("dd MMM HH:mm")</dd>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(Model.AgentStatus.LastMapName))
                                        {
                                            <dt class="col-6">Last Map</dt>
                                            <dd class="col-6">@Model.AgentStatus.LastMapName</dd>
                                        }
                                    </dl>
                                }
                                else
                                {
                                    <div class="alert alert-warning mb-0">
                                        <i class="fa-solid fa-fw fa-triangle-exclamation"></i> Agent telemetry is unavailable for this server.
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="ibox">
                            <div class="ibox-title"><h5>Ban File Monitors</h5></div>
                            <div class="ibox-content">
                                @if (Model.BanFileMonitors.Any())
                                {
                                    <div class="table-responsive">
                                        <table class="table table-sm w-100">
                                            <thead><tr><th>Watching</th><th>Last Check</th><th>Last Push</th></tr></thead>
                                            <tbody>
                                                @foreach (var bfm in Model.BanFileMonitors)
                                                {
                                                    <tr>
                                                        <td>
                                                            <small>@(bfm.RemoteFilePath ?? "(awaiting first check)")</small>
                                                        </td>
                                                        <td>
                                                            @if (bfm.LastCheckUtc.HasValue)
                                                            {
                                                                var checkElapsed = DateTime.UtcNow - bfm.LastCheckUtc.Value;
                                                                var checkClass = checkElapsed.TotalMinutes < 15 ? "text-success" : checkElapsed.TotalHours < 1 ? "text-warning" : "text-danger";
                                                                <small class="@checkClass">@bfm.LastCheckUtc.Value.ToString("dd MMM HH:mm")</small>
                                                            }
                                                            else
                                                            {
                                                                <small class="text-muted">Never</small>
                                                            }
                                                        </td>
                                                        <td>
                                                            @if (bfm.LastPushUtc.HasValue)
                                                            {
                                                                <small>@bfm.LastPushUtc.Value.ToString("dd MMM HH:mm")</small>
                                                            }
                                                            else
                                                            {
                                                                <small class="text-muted">Never</small>
                                                            }
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                                else
                                {
                                    <p class="text-muted mb-0">No ban file monitors configured for this server.</p>
                                }
                            </div>
                        </div>

                        @if (Model.GameServer.GameType == GameType.CallOfDuty4x)
                        {
                            <div class="ibox">
                                <div class="ibox-title"><h5>CoD4x Plugin Lifecycle</h5></div>
                                <div class="ibox-content">
                                    <dl class="row mb-3">
                                        <dt class="col-5">Plugin Enabled</dt>
                                        <dd class="col-7">@(Model.Cod4xPluginEnabled.HasValue ? (Model.Cod4xPluginEnabled.Value ? "Enabled" : "Disabled") : "Inherited")</dd>

                                        <dt class="col-5">Plugin Root</dt>
                                        <dd class="col-7">@(string.IsNullOrWhiteSpace(Model.Cod4xPluginRootDirectory) ? "-" : Model.Cod4xPluginRootDirectory)</dd>

                                        <dt class="col-5">Current Version</dt>
                                        <dd class="col-7">@(Model.Cod4xRuntimeCurrentVersion ?? "-")</dd>

                                        <dt class="col-5">Known Good</dt>
                                        <dd class="col-7">@(Model.Cod4xRuntimePreviousKnownGoodVersion ?? "-")</dd>

                                        <dt class="col-5">Last Status</dt>
                                        <dd class="col-7" id="sd-cod4x-lastStatus">@Model.Cod4xRuntimeLastOperationStatus</dd>

                                        <dt class="col-5">Last Operation</dt>
                                        <dd class="col-7">@(Model.Cod4xRuntimeLastOperationId ?? "-")</dd>

                                        <dt class="col-5">Last Updated</dt>
                                        <dd class="col-7">@(Model.Cod4xRuntimeLastOperationUtc?.ToString("u") ?? "-")</dd>

                                        <dt class="col-5">Pending Request</dt>
                                        <dd class="col-7">
                                            @if (Model.Cod4xOperationRequestAction != Cod4xPluginOperationAction.Unknown)
                                            {
                                                <span>@Model.Cod4xOperationRequestAction</span>
                                                @if (!string.IsNullOrWhiteSpace(Model.Cod4xOperationRequestTargetVersion))
                                                {
                                                    <span> (@Model.Cod4xOperationRequestTargetVersion)</span>
                                                }
                                            }
                                            else
                                            {
                                                <span>-</span>
                                            }
                                        </dd>
                                    </dl>

                                    @if (!string.IsNullOrWhiteSpace(Model.Cod4xRuntimeLastError))
                                    {
                                        <div class="alert alert-warning mb-3">
                                            <strong>Last Error:</strong> @Model.Cod4xRuntimeLastError
                                        </div>
                                    }

                                    @if (Model.CanManageCoD4xPluginLifecycle)
                                    {
                                        <div class="mb-2">
                                            <label for="sd-cod4x-targetVersion" class="form-label">Target Version (for Install)</label>
                                            @if (Model.Cod4xAvailableVersions.Any())
                                            {
                                                <select id="sd-cod4x-targetVersion" class="form-select">
                                                    <option value="">Select a published version...</option>
                                                    @foreach (var availableVersion in Model.Cod4xAvailableVersions)
                                                    {
                                                        if (string.Equals(availableVersion, selectedCod4xTargetVersion, StringComparison.OrdinalIgnoreCase))
                                                        {
                                                            <option value="@availableVersion" selected>@availableVersion</option>
                                                        }
                                                        else
                                                        {
                                                            <option value="@availableVersion">@availableVersion</option>
                                                        }
                                                    }
                                                </select>
                                            }
                                            else
                                            {
                                                <input id="sd-cod4x-targetVersion"
                                                       type="text"
                                                       class="form-control"
                                                       value="@selectedCod4xTargetVersion"
                                                       placeholder="e.g. v1.2.4" />
                                                <small class="form-text text-muted">Published versions were not discovered, so enter the target version manually.</small>
                                            }
                                        </div>
                                        <div class="d-grid gap-2">
                                            <button id="sd-cod4x-install" type="button" class="btn btn-primary btn-sm">
                                                <i class="fa-solid fa-fw fa-download" aria-hidden="true"></i> Request Install
                                            </button>
                                            <button id="sd-cod4x-rollback" type="button" class="btn btn-outline-secondary btn-sm">
                                                <i class="fa-solid fa-fw fa-rotate-left" aria-hidden="true"></i> Request Rollback
                                            </button>
                                            <button id="sd-cod4x-unload" type="button" class="btn btn-outline-danger btn-sm">
                                                <i class="fa-solid fa-fw fa-eject" aria-hidden="true"></i> Request Unload
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <p class="text-muted mb-0">You do not have permission to request plugin lifecycle operations.</p>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        <div class="tab-pane fade" id="analytics" role="tabpanel" aria-labelledby="analytics-tab" policy="@AuthPolicies.Dashboard_Read">
            <div class="ibox" id="analytics-embed-server" data-server-id="@Model.GameServer.GameServerId" data-mode="full">
                <div class="ibox-title d-flex justify-content-between align-items-center">
                    <h5><i class="fa-solid fa-fw fa-chart-line" aria-hidden="true"></i> Analytics &mdash; last 30 days</h5>
                    <a asp-controller="Analytics" asp-action="Server" asp-route-id="@Model.GameServer.GameServerId" class="btn btn-outline-secondary btn-sm">
                        <i class="fa-solid fa-fw fa-arrow-up-right-from-square" aria-hidden="true"></i> Open in Analytics
                    </a>
                </div>
                <div class="ibox-content">
                    <div id="analytics-embed-server-summary" class="mb-2"></div>
                    <div style="position: relative; height: 260px;"><canvas id="analytics-embed-server-trend"></canvas></div>
                    <pre id="analytics-embed-server-trend-fallback" class="mt-2 analytics-fallback"></pre>
                    <div class="row mt-3">
                        <div class="col-md-6"><h6>Events by type</h6><div id="analytics-embed-server-events"></div></div>
                        <div class="col-md-6"><h6>Top chatters</h6><div id="analytics-embed-server-chat"></div></div>
                    </div>
                    <div class="row mt-3">
                        <div class="col-md-6"><h6>Map rotation</h6><div id="analytics-embed-server-maps"></div></div>
                        <div class="col-md-6"><h6>Chat commands</h6><div id="analytics-embed-server-chat-commands"></div></div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {

    <environment names="Development">
        <script src="~/lib/toastr/toastr.js"></script>
    </environment>
    <environment names="Staging,Production">
        <script src="~/lib/toastr/toastr.min.js"></script>
    </environment>

    <script src="~/js/rcon-utils.js"></script>
    <script src="~/js/rcon-server-status.js"></script>
    <script src="~/js/rcon-players.js"></script>
    <script src="~/js/server-feed.js"></script>
    <script src="~/js/rcon-map-control.js"></script>

    <div policy="@AuthPolicies.Dashboard_Read">
        <script src="~/lib/chart.js/dist/chart.umd.js" asp-append-version="true"></script>
        <script src="~/js/analytics-common.js" asp-append-version="true"></script>
        <script src="~/js/analytics-embed-server.js" asp-append-version="true"></script>
    </div>

    <form id="__af" method="post" style="display:none">@Html.AntiForgeryToken()</form>

    @* Google Charts for timeline + player count *@
    <script type="text/javascript" src="https://www.gstatic.com/charts/loader.js"></script>

    <script type="text/javascript">
        var antiForgeryToken = $('input[name="__RequestVerificationToken"]').val();
        var serverId = '@Model.GameServer.GameServerId';
        var currentMap = '@(liveStatus?.Map ?? "")';
        var refreshEnabled = true;
        var modulesStarted = { players: false, serverFeed: false, mapcontrol: false };

        // Initialize modules (players start immediately since they're on the overview tab)
        @if (Model.CanViewRcon)
        {
            <text>
            RconServerStatus.init({
                serverId: serverId,
                antiForgeryToken: antiForgeryToken,
                mapNameSelector: '#sd-currentMapName',
                mapImageSelector: '#sd-currentMapImage',
                playerCountSelector: '#sd-playerCount',
                onUpdated: highlightCurrentMap
            });
            RconPlayers.init({
                serverId: serverId,
                antiForgeryToken: antiForgeryToken,
                tableSelector: '#sd-playersTable'
            });
            RconMapControl.init({
                serverId: serverId,
                antiForgeryToken: antiForgeryToken,
                carouselSelector: '#sd-mapRotationCarousel',
                containerSelector: '#sd-mapRotationContainer',
                loadingSelector: '#sd-mapRotationLoading',
                errorSelector: '#sd-mapRotationError',
                restartMapSelector: '#sd-restartMap',
                fastRestartMapSelector: '#sd-fastRestartMap',
                nextMapSelector: '#sd-nextMap',
                restartServerSelector: '#sd-restartServer',
                canChangeMap: @Model.CanChangeMap.ToString().ToLower(),
                onMapChanged: function () { RconServerStatus.load(); }
            });

            // Start players immediately (visible on overview tab)
            RconPlayers.start(10000);
            RconServerStatus.start(10000);
            modulesStarted.players = true;
            </text>
        }
        @if (Model.CanViewChatLog)
        {
            <text>
            ServerFeed.init({
                serverId: serverId,
                antiForgeryToken: antiForgeryToken,
                containerSelector: '#sd-feedContainer',
                itemsSelector: '#sd-feedItems',
                pendingCountSelector: '#sd-feedPendingCount',
                overrunIndicatorSelector: '#sd-feedOverrunIndicator',
                chatToggleSelector: '#sd-feedToggleChat',
                eventsToggleSelector: '#sd-feedToggleEvents',
                eventTypeFilterSelector: '#sd-feedEventFilter',
                sayFormSelector: '#sd-sayForm',
                sayInputSelector: '#sd-sayMessage'
            });

            ServerFeed.start(15000);
            modulesStarted.serverFeed = true;
            </text>
        }

        // Toggle refresh
        $('#sd-toggleRefresh').click(function () {
            refreshEnabled = !refreshEnabled;
            $(this).html(refreshEnabled ? '<i class="fa-solid fa-fw fa-pause"></i> Pause' : '<i class="fa-solid fa-fw fa-play"></i> Resume');
            if (typeof RconPlayers !== 'undefined' && modulesStarted.players) RconPlayers.setRefreshEnabled(refreshEnabled);
            if (typeof ServerFeed !== 'undefined' && modulesStarted.serverFeed) ServerFeed.setRefreshEnabled(refreshEnabled);
            if (typeof RconServerStatus !== 'undefined') RconServerStatus.setRefreshEnabled(refreshEnabled);
        });

        function requestCod4xPluginOperation(action) {
            var targetVersion = $('#sd-cod4x-targetVersion').val();
            if (action === 'Install' && (!targetVersion || !String(targetVersion).trim())) {
                toastr.warning('Target version is required for install operations.');
                return;
            }

            $.ajax({
                url: '/ServerAdmin/RequestCod4xPluginOperation',
                type: 'POST',
                headers: { 'RequestVerificationToken': antiForgeryToken },
                data: {
                    id: serverId,
                    action: action,
                    targetVersion: targetVersion
                },
                success: function(response) {
                    if (response && response.success) {
                        toastr.success(response.message || 'CoD4x plugin operation requested.');
                        setTimeout(function () { window.location.reload(); }, 1200);
                        return;
                    }

                    toastr.error((response && response.message) || 'Failed to request CoD4x plugin operation.');
                },
                error: function(xhr) {
                    var responseMessage = xhr && xhr.responseJSON && xhr.responseJSON.message
                        ? xhr.responseJSON.message
                        : 'Failed to request CoD4x plugin operation.';
                    toastr.error(responseMessage);
                }
            });
        }

        $('#sd-cod4x-install').on('click', function () { requestCod4xPluginOperation('Install'); });
        $('#sd-cod4x-rollback').on('click', function () { requestCod4xPluginOperation('Rollback'); });
        $('#sd-cod4x-unload').on('click', function () { requestCod4xPluginOperation('Unload'); });

        // Start/stop modules on tab visibility
        $('button[data-bs-toggle="tab"]').on('shown.bs.tab', function (e) {
            var target = $(e.target).attr('data-bs-target');

            if (target === '#mapcontrol' && !modulesStarted.mapcontrol) {
                RconMapControl.start();
                modulesStarted.mapcontrol = true;

                // Highlight current map in rotation after load
                setTimeout(function() {
                    highlightCurrentMap();
                }, 1500);
            }
        });

        // Highlight current map in the rotation carousel
        function highlightCurrentMap() {
            var mapName = $('#sd-currentMapName').text().trim();

            // Clear existing highlights
            $('#sd-mapRotationCarousel .map-card').removeClass('border border-success border-2 rounded');
            $('#sd-mapRotationCarousel .map-card .map-card-title .badge.bg-success').remove();

            if (!mapName || mapName === 'Loading...' || mapName === 'Unknown') return;

            var carousel = document.getElementById('sd-mapRotationCarousel');

            $('#sd-mapRotationCarousel .map-card').each(function() {
                var btn = $(this).find('.load-map-btn');
                if (btn.data('map-name') === mapName) {
                    $(this).addClass('border border-success border-2 rounded');
                    $(this).find('.map-card-title').append(' <span class="badge bg-success">Current</span>');
                    // Scroll within the carousel only (not the page), and only if the map control tab is active
                    var mapControlTab = document.getElementById('mapcontrol');
                    if (carousel && mapControlTab && mapControlTab.classList.contains('active')) {
                        var cardRect = this.getBoundingClientRect();
                        var carouselRect = carousel.getBoundingClientRect();
                        var cardLeft = cardRect.left - carouselRect.left + carousel.scrollLeft;
                        var cardWidth = this.offsetWidth;
                        var carouselWidth = carousel.offsetWidth;
                        carousel.scrollTo({ left: cardLeft - (carouselWidth / 2) + (cardWidth / 2), behavior: 'smooth' });
                    }
                }
            });
        }

        // Cleanup
        window.addEventListener('beforeunload', function () {
            if (typeof RconServerStatus !== 'undefined') RconServerStatus.dispose();
            if (typeof RconPlayers !== 'undefined') RconPlayers.dispose();
            if (typeof ServerFeed !== 'undefined') ServerFeed.dispose();
            if (typeof RconMapControl !== 'undefined') RconMapControl.dispose();
        });

        // Google Charts: Player Count
        @if (Model.GameServerStats.Any())
        {
            <text>
            google.charts.load('current', { 'packages': ['corechart', 'timeline'] });
            google.charts.setOnLoadCallback(function() {
                var playerCountData = new google.visualization.DataTable();
                playerCountData.addColumn('datetime', 'Timestamp');
                playerCountData.addColumn('number', 'Player Count');
                playerCountData.addRows([
                    @foreach (var item in Model.GameServerStats)
                    {
                        <text>[new Date(@item.Timestamp.Year, @(item.Timestamp.Month-1), @item.Timestamp.Day, @item.Timestamp.Hour, @item.Timestamp.Minute, @item.Timestamp.Second), @item.PlayerCount],</text>
                    }
                ]);
                var chart = new google.visualization.LineChart(document.getElementById('sd-playerCountChart'));
                chart.draw(playerCountData, {
                    title: 'Player Count (Last 48 hours)',
                    curveType: 'function',
                    legend: { position: 'bottom' },
                    seriesType: 'line'
                });
            });
            </text>
        }

        // Google Charts: Map Timeline
        @if (Model.MapTimelineDataPoints.Any())
        {
            <text>
            google.charts.setOnLoadCallback(function() {
                // Only draw when map control tab is shown
                $('button[data-bs-target="#mapcontrol"]').on('shown.bs.tab', function() {
                    var container = document.getElementById('sd-mapsTimeline');
                    if (!container || container.dataset.drawn) return;

                    var chart = new google.visualization.Timeline(container);
                    var dataTable = new google.visualization.DataTable();
                    dataTable.addColumn({ type: 'string', id: 'Map Name' });
                    dataTable.addColumn({ type: 'datetime', id: 'Start' });
                    dataTable.addColumn({ type: 'datetime', id: 'End' });
                    dataTable.addRows([
                        @foreach (var dp in Model.MapTimelineDataPoints)
                        {
                            <text>['@dp.MapName', new Date(@dp.Start.Year, @(dp.Start.Month-1), @dp.Start.Day, @dp.Start.Hour, @dp.Start.Minute, @dp.Start.Second), new Date(@dp.End.Year, @(dp.End.Month-1), @dp.End.Day, @dp.End.Hour, @dp.End.Minute, @dp.End.Second)],</text>
                        }
                    ]);
                    chart.draw(dataTable);
                    container.dataset.drawn = 'true';
                });
            });
            </text>
        }
    </script>
}
