@inject IAuthorizationService AuthorizationService
@using Microsoft.AspNetCore.Authorization
@using XtremeIdiots.Portal.Web.Auth.Constants
@using XtremeIdiots.Portal.Web.Constants
@using XtremeIdiots.Portal.Web.Extensions
@using XtremeIdiots.Portal.Web.ViewModels
@model List<ServerAdminGameServerViewModel>

@{
    ViewData["Title"] = "Server Admin";
}

<div class="wrapper wrapper-content animated fadeInRight">

    <div class="row">
        <div class="col-12">

            <div class="container-fluid">
                <div class="ibox">
                    <div class="ibox-title"><h5>Server Admin</h5></div>
                    <div class="ibox-content">
                        <div class="table-responsive">
                            <table id="serverAdminTable" class="table table-striped table-hover w-100">
                                <thead>
                                    <tr>
                                        <th scope="col">Title</th>
                                        <th scope="col">Hostname</th>
                                        <th scope="col">Players</th>
                                        <th scope="col">Map</th>
                                        <th scope="col">Mod</th>
                                        <th scope="col">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            <game-type-icon game="@item.GameServer.GameType"></game-type-icon>
                                            <server-name title="@item.GameServer.Title"
                                                live-title="@item.LiveStatus?.Title"></server-name>
                                        </td>
                                        <td>
                                            <server-host host="@item.GameServer.Hostname"
                                                port="@item.GameServer.QueryPort"></server-host>
                                        </td>
                                        <td>
                                            @{
                                                double percentage = 0;
                                                if (item.LiveStatus != null &&
                                                item.LiveStatus.CurrentPlayers != 0 && item.LiveStatus.MaxPlayers != 0)
                                                {
                                                    percentage = (double)item.LiveStatus.CurrentPlayers /
                                                    item.LiveStatus.MaxPlayers * 100;
                                                }
                                            }

                                            <div class="progress" style="margin-right: 20px">
                                                <div style="width: @percentage%" aria-valuemax="100" aria-valuemin="0"
                                                    aria-valuenow="@percentage" role="progressbar" class="progress-bar">
                                                    <span class="visually-hidden">@percentage% Slots Filled</span>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            @item.LiveStatus?.Map
                                        </td>
                                        <td>
                                            @item.LiveStatus?.Mod
                                        </td>
                                        <td>
                                            <div class="btn-group btn-group-sm" role="group" aria-label="Server admin actions">
                                                <a class="btn btn-outline-secondary" asp-action="ServerDetail"
                                                    asp-route-id="@item.GameServer.GameServerId"
                                                    data-testid="server-@(item.GameServer.GameServerId)-detail">
                                                    <i class="fa-solid fa-fw fa-gauge" aria-hidden="true"></i> 
                                                    <span class="d-none d-sm-inline">Detail</span>
                                                </a>

                                                @if ((await AuthorizationService.AuthorizeAsync(User,
                                                                                            item.GameServer.GameType, AuthPolicies.ChatLog_ReadServer)).Succeeded
                                                                                            && ChatLogSupportedGames.Games.Contains(item.GameServer.GameType))
                                                {
                                                    <a class="btn btn-outline-secondary" asp-action="ServerChatLog"
                                                        asp-route-id="@item.GameServer.GameServerId"
                                                        data-testid="server-@(item.GameServer.GameServerId)-view-chatlog">
                                                        <i class="fa-solid fa-fw fa-comments" aria-hidden="true"></i> 
                                                        <span class="d-none d-sm-inline">View ChatLog</span>
                                                    </a>
                                                }

                                                @if ((await AuthorizationService.AuthorizeAsync(User,
                                                                                            item.GameServer.GameType, AuthPolicies.GameServers_Maps_Read)).Succeeded)
                                                {
                                                    <a class="btn btn-outline-secondary" asp-controller="MapManager"
                                                        asp-action="Manage" asp-route-id="@item.GameServer.GameServerId"
                                                        data-testid="server-@(item.GameServer.GameServerId)-manage-maps">
                                                        <i class="fa-solid fa-fw fa-map" aria-hidden="true"></i> 
                                                        <span class="d-none d-sm-inline">Manage Maps</span>
                                                    </a>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

</div>

@section Scripts {
    <script src="~/js/server-admin-index.js" asp-append-version="true"></script>
}