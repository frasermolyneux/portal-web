@model XtremeIdiots.Portal.Repository.Abstractions.Models.V1.Tags.PlayerTagDto

@{
    ViewData["Title"] = "Remove Player Tag";
    var player = ViewBag.Player as XtremeIdiots.Portal.Repository.Abstractions.Models.V1.Players.PlayerDto;
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox">
                <div class="ibox-title">
                    <h5>Remove Tag from Player: <player-name value="@player?.Username"></player-name></h5>
                </div>
                <div class="ibox-content">
                    <h3>Are you sure you want to remove this tag from the player?</h3>

                    <div class="row">
                        <div class="col-md-6">
                            <dl class="detail-fields">
                                <div class="detail-field">
                                    <dt class="detail-label">Tag</dt>
                                    <dd class="detail-value">@Model.Tag?.Name @Html.Raw(Model.Tag?.TagHtml)</dd>
                                </div>
                                <div class="detail-field">
                                    <dt class="detail-label">Assigned By</dt>
                                    <dd class="detail-value">@Model.UserProfile?.DisplayName</dd>
                                </div>
                                <div class="detail-field">
                                    <dt class="detail-label">Assigned On</dt>
                                    <dd class="detail-value"><time time-ago utc="@Model.Assigned"></time></dd>
                                </div>
                            </dl>
                        </div>
                    </div>

                    <form asp-controller="PlayerTags" asp-action="Remove" method="post" id="removeTagForm">
                        <input type="hidden" name="id" value="@Model.PlayerId" />
                        <input type="hidden" name="playerTagId" value="@Model.PlayerTagId" />
                    </form>
                </div>
                <div class="ibox-footer">
                    <a asp-action="Details" asp-controller="Players" asp-route-id="@Model.PlayerId"
                        class="btn btn-outline-secondary">
                        <i class="fa-solid fa-fw fa-arrow-left" aria-hidden="true"></i> Back to Player
                    </a>
                    <button type="submit" form="removeTagForm" class="btn btn-danger">
                        <i class="fa-solid fa-fw fa-xmark" aria-hidden="true"></i> Remove Tag
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
