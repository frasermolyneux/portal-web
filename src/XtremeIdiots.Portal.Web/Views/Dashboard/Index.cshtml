@using XtremeIdiots.Portal.Web.Services
@using XtremeIdiots.Portal.Web.ViewModels
@model DashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
    
    var summary = Model.Summary;
    var activeCount = Model.AgentStatuses.Count(a => a.ActivityStatus == AgentActivityStatus.Active);
    var idleCount = Model.AgentStatuses.Count(a => a.ActivityStatus == AgentActivityStatus.Idle);
    var offlineCount = Model.AgentStatuses.Count(a => a.ActivityStatus == AgentActivityStatus.Offline);
}

<div class="wrapper wrapper-content animated fadeInRight">

    @* ─── Summary Cards ─── *@
    <div class="row mb-4">
        <div class="col-lg-3 col-md-6 mb-3">
            <div class="ibox">
                <div class="ibox-content">
                    <h5 class="text-muted fw-normal mt-0">Servers</h5>
                    <h2 class="mt-2 mb-1">
                        <span class="text-success">@(summary?.OnlineServerCount ?? 0)</span>
                        <small class="text-muted fs-6">/ @(summary?.TotalServers ?? 0)</small>
                    </h2>
                    <div>
                        <span class="badge bg-success">@activeCount Active</span>
                        <span class="badge bg-info">@idleCount Idle</span>
                        @if (offlineCount > 0)
                        {
                            <span class="badge bg-danger">@offlineCount Offline</span>
                        }
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 mb-3">
            <div class="ibox">
                <div class="ibox-content">
                    <h5 class="text-muted fw-normal mt-0">Players Online</h5>
                    <h2 class="mt-2 mb-1">@(summary?.TotalPlayersOnline ?? 0)</h2>
                    <small class="text-muted">Across all servers</small>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 mb-3">
            <div class="ibox">
                <div class="ibox-content">
                    <h5 class="text-muted fw-normal mt-0">Unclaimed Bans</h5>
                    <h2 class="mt-2 mb-1 @(summary?.UnclaimedBanCount > 0 ? "text-warning" : "text-success")">
                        @(summary?.UnclaimedBanCount ?? 0)
                    </h2>
                    @if (summary?.UnclaimedBanCount > 0)
                    {
                        <a asp-controller="AdminActions" asp-action="Unclaimed" class="text-warning text-decoration-none">
                            <small><i class="fa-solid fa-arrow-right"></i> View unclaimed</small>
                        </a>
                    }
                    else
                    {
                        <small class="text-muted">All clear</small>
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 mb-3">
            <div class="ibox">
                <div class="ibox-content">
                    <h5 class="text-muted fw-normal mt-0">Open Reports</h5>
                    <h2 class="mt-2 mb-1 @(summary?.OpenReportCount > 0 ? "text-warning" : "text-success")">
                        @(summary?.OpenReportCount ?? 0)
                    </h2>
                    <small class="text-muted">Awaiting review</small>
                </div>
            </div>
        </div>
    </div>

    @* ─── Recent Actions (24h / 7d) ─── *@
    @if (summary?.RecentActions24h is not null && summary?.RecentActions7d is not null)
    {
        <div class="row mb-4">
            <div class="col-12">
                <div class="ibox">
                    <div class="ibox-title">
                        <h5>Moderation Activity</h5>
                    </div>
                    <div class="ibox-content">
                        <div class="row text-center">
                            <div class="col">
                                <small class="text-muted d-block mb-1">Last 24 hours</small>
                                <span class="badge bg-danger me-1" title="Bans">@summary.RecentActions24h.Bans Bans</span>
                                <span class="badge bg-warning text-dark me-1" title="TempBans">@summary.RecentActions24h.TempBans TempBans</span>
                                <span class="badge bg-info me-1" title="Kicks">@summary.RecentActions24h.Kicks Kicks</span>
                                <span class="badge bg-secondary me-1" title="Warnings">@summary.RecentActions24h.Warnings Warnings</span>
                                <span class="badge bg-light text-dark" title="Observations">@summary.RecentActions24h.Observations Obs</span>
                            </div>
                            <div class="col">
                                <small class="text-muted d-block mb-1">Last 7 days</small>
                                <span class="badge bg-danger me-1" title="Bans">@summary.RecentActions7d.Bans Bans</span>
                                <span class="badge bg-warning text-dark me-1" title="TempBans">@summary.RecentActions7d.TempBans TempBans</span>
                                <span class="badge bg-info me-1" title="Kicks">@summary.RecentActions7d.Kicks Kicks</span>
                                <span class="badge bg-secondary me-1" title="Warnings">@summary.RecentActions7d.Warnings Warnings</span>
                                <span class="badge bg-light text-dark" title="Observations">@summary.RecentActions7d.Observations Obs</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="row">
        @* ─── Server Health Table ─── *@
        <div class="col-lg-8 mb-4">
            <div class="ibox">
                <div class="ibox-title">
                    <h5>Server Health</h5>
                </div>
                <div class="ibox-content">
                    @if (Model.AgentTelemetryUnavailable)
                    {
                        <div class="alert alert-warning mb-3">
                            <i class="fa-solid fa-triangle-exclamation"></i> Agent telemetry is currently unavailable.
                        </div>
                    }

                    @if (Model.AgentStatuses.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover table-sm w-100">
                                <thead>
                                    <tr>
                                        <th>Server</th>
                                        <th>Status</th>
                                        <th>Players</th>
                                        <th>Map</th>
                                        <th>Last Event</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var server in Model.AgentStatuses)
                                    {
                                        var statusClass = server.ActivityStatus switch
                                        {
                                            AgentActivityStatus.Active => "bg-success",
                                            AgentActivityStatus.Idle => "bg-info",
                                            AgentActivityStatus.Offline => "bg-danger",
                                            _ => "bg-secondary"
                                        };
                                        <tr>
                                            <td>
                                                <a asp-controller="Servers" asp-action="ServerInfo" asp-route-id="@server.ServerId">
                                                    @server.ServerTitle
                                                </a>
                                            </td>
                                            <td><span class="badge @statusClass">@server.ActivityStatus</span></td>
                                            <td>@server.PlayerCount</td>
                                            <td><small>@server.CurrentMap</small></td>
                                            <td>
                                                @if (server.LastEventReceived.HasValue)
                                                {
                                                    var elapsed = DateTime.UtcNow - server.LastEventReceived.Value;
                                                    if (elapsed.TotalMinutes < 1)
                                                    {
                                                        <span>@((int)elapsed.TotalSeconds)s ago</span>
                                                    }
                                                    else if (elapsed.TotalHours < 1)
                                                    {
                                                        <span>@((int)elapsed.TotalMinutes)m ago</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-danger">@((int)elapsed.TotalHours)h ago</span>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="text-muted">—</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No agent-enabled servers found.</p>
                    }
                </div>
            </div>
        </div>

        @* ─── Admin Leaderboard ─── *@
        <div class="col-lg-4 mb-4">
            <div class="ibox">
                <div class="ibox-title">
                    <h5>Admin Leaderboard <small class="text-muted">(30 days)</small></h5>
                </div>
                <div class="ibox-content">
                    @if (Model.AdminLeaderboard.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm w-100">
                                <thead>
                                    <tr>
                                        <th>Admin</th>
                                        <th class="text-center">Actions</th>
                                        <th class="text-center">Bans</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var entry in Model.AdminLeaderboard.Take(10))
                                    {
                                        <tr>
                                            <td>@entry.DisplayName</td>
                                            <td class="text-center"><span class="badge bg-primary">@entry.Total</span></td>
                                            <td class="text-center"><span class="badge bg-danger">@(entry.Bans + entry.TempBans)</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No admin activity in the last 30 days.</p>
                    }
                </div>
            </div>
        </div>
    </div>

    @* ─── Server Utilization ─── *@
    @if (Model.ServerUtilization?.Servers?.Any() == true)
    {
        <div class="row mb-4">
            <div class="col-12">
                <div class="ibox">
                    <div class="ibox-title">
                        <h5>Server Utilization <small class="text-muted">(last 24h)</small></h5>
                        <span class="float-end">
                            <small class="text-muted">
                                Avg: @Model.ServerUtilization.TotalAvgPlayers players |
                                Peak: @Model.ServerUtilization.TotalPeakPlayers players
                            </small>
                        </span>
                    </div>
                    <div class="ibox-content">
                        <div class="table-responsive">
                            <table class="table table-striped table-sm w-100">
                                <thead>
                                    <tr>
                                        <th>Server</th>
                                        <th>Game</th>
                                        <th class="text-center">Avg Players</th>
                                        <th class="text-center">Peak</th>
                                        <th class="text-center">Max</th>
                                        <th>Utilization</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var server in Model.ServerUtilization.Servers.OrderByDescending(s => s.Utilization))
                                    {
                                        var utilizationPct = (int)(server.Utilization * 100);
                                        var barClass = utilizationPct switch
                                        {
                                            > 75 => "bg-success",
                                            > 40 => "bg-info",
                                            > 10 => "bg-warning",
                                            _ => "bg-secondary"
                                        };
                                        <tr>
                                            <td>
                                                <a asp-controller="Servers" asp-action="ServerInfo" asp-route-id="@server.ServerId">
                                                    @server.Title
                                                </a>
                                            </td>
                                            <td><small>@server.GameType</small></td>
                                            <td class="text-center">@server.AvgPlayers</td>
                                            <td class="text-center">@server.PeakPlayers</td>
                                            <td class="text-center">@server.MaxPlayers</td>
                                            <td>
                                                <div class="progress" style="height: 18px;">
                                                    <div class="progress-bar @barClass" role="progressbar"
                                                         style="width: @utilizationPct%"
                                                         aria-valuenow="@utilizationPct" aria-valuemin="0" aria-valuemax="100">
                                                        @utilizationPct%
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    @* ─── Moderation Trend ─── *@
    @if (Model.ModerationTrend.Any())
    {
        <div class="row mb-4">
            <div class="col-12">
                <div class="ibox">
                    <div class="ibox-title">
                        <h5>Moderation Trend <small class="text-muted">(30 days)</small></h5>
                    </div>
                    <div class="ibox-content">
                        <div class="table-responsive">
                            <table class="table table-sm table-striped w-100">
                                <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th class="text-center">Bans</th>
                                        <th class="text-center">TempBans</th>
                                        <th class="text-center">Kicks</th>
                                        <th class="text-center">Warnings</th>
                                        <th class="text-center">Observations</th>
                                        <th class="text-center">Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var day in Model.ModerationTrend.OrderByDescending(d => d.Date))
                                    {
                                        var total = day.Bans + day.TempBans + day.Kicks + day.Warnings + day.Observations;
                                        <tr>
                                            <td><time user-time utc="@day.Date"></time></td>
                                            <td class="text-center">
                                                @if (day.Bans > 0) { <span class="badge bg-danger">@day.Bans</span> } else { <span class="text-muted">0</span> }
                                            </td>
                                            <td class="text-center">
                                                @if (day.TempBans > 0) { <span class="badge bg-warning text-dark">@day.TempBans</span> } else { <span class="text-muted">0</span> }
                                            </td>
                                            <td class="text-center">
                                                @if (day.Kicks > 0) { <span class="badge bg-info">@day.Kicks</span> } else { <span class="text-muted">0</span> }
                                            </td>
                                            <td class="text-center">
                                                @if (day.Warnings > 0) { <span class="badge bg-secondary">@day.Warnings</span> } else { <span class="text-muted">0</span> }
                                            </td>
                                            <td class="text-center">@day.Observations</td>
                                            <td class="text-center"><strong>@total</strong></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

</div>
