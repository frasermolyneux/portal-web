@model XtremeIdiots.Portal.Web.ViewModels.EditMapRotationViewModel
@using XtremeIdiots.Portal.Repository.Abstractions.Constants.V1

@{
    ViewData["Title"] = "Edit Map Rotation - " + Model.Title;
}

<div class="wrapper wrapper-content animated fadeInRight">
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="@Model.MapRotationId" />
        <input type="hidden" asp-for="@Model.GameType" />
        <input type="hidden" asp-for="@Model.Version" />

        <div class="row">
            <div class="col-12">
                <div class="container-fluid">
                    <div class="ibox">
                        <div class="ibox-title">
                            <h5>@ViewData["Title"]</h5>
                            <div class="ibox-tools">
                                <span class="badge bg-secondary">Version @Model.Version</span>
                                <span class="badge bg-info">@Model.GameType</span>
                            </div>
                        </div>
                        <div class="ibox-content">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                            <div class="mb-3">
                                <label asp-for="@Model.Title" class="control-label"></label>
                                <input asp-for="@Model.Title" class="form-control" />
                                <span asp-validation-for="@Model.Title" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <label asp-for="@Model.Description" class="control-label"></label>
                                <textarea asp-for="@Model.Description" class="form-control" rows="3"></textarea>
                                <span asp-validation-for="@Model.Description" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <label asp-for="@Model.GameMode" class="control-label"></label>
                                <select asp-for="@Model.GameMode" class="form-select">
                                    <option value="">-- Select Mode --</option>
                                    <optgroup label="Standard Modes">
                                        <option value="dm">Free for All / Deathmatch (dm)</option>
                                        <option value="tdm">Team Deathmatch (tdm)</option>
                                        <option value="war">War / Team Deathmatch (war)</option>
                                        <option value="sd">Search &amp; Destroy (sd)</option>
                                        <option value="dom">Domination (dom)</option>
                                        <option value="sab">Sabotage (sab)</option>
                                        <option value="koth">Headquarters (koth)</option>
                                        <option value="ctf">Capture the Flag (ctf)</option>
                                    </optgroup>
                                    <optgroup label="OpenWarfare Modes">
                                        <option value="ftag">Freeze Tag (ftag)</option>
                                        <option value="ass">Assassination (ass)</option>
                                        <option value="bel">Behind Enemy Lines (bel)</option>
                                        <option value="ch">Capture and Hold (ch)</option>
                                        <option value="gr">Greed (gr)</option>
                                        <option value="gg">Gun Game (gg)</option>
                                        <option value="hns">Hide and Seek (hns)</option>
                                        <option value="lms">Last Man Standing (lms)</option>
                                        <option value="lts">Last Team Standing (lts)</option>
                                        <option value="oitc">One In The Chamber (oitc)</option>
                                        <option value="re">Retrieval (re)</option>
                                        <option value="ss">Sharp Shooter (ss)</option>
                                        <option value="tgr">Team Greed (tgr)</option>
                                        <option value="twar">War (twar)</option>
                                        <option value="cooperative">Cooperative / Zombie (cooperative)</option>
                                    </optgroup>
                                </select>
                                <span asp-validation-for="@Model.GameMode" class="text-danger"></span>
                            </div>
                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label asp-for="@Model.Status" class="control-label"></label>
                                    <select asp-for="@Model.Status" class="form-select">
                                        <option value="@MapRotationStatus.Draft">Draft</option>
                                        <option value="@MapRotationStatus.Testing">Testing</option>
                                        <option value="@MapRotationStatus.Active">Active</option>
                                        <option value="@MapRotationStatus.Archived">Archived</option>
                                    </select>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label asp-for="@Model.Category" class="control-label"></label>
                                    <input asp-for="@Model.Category" class="form-control" list="categorySuggestions"
                                           placeholder="e.g. Standard, Holiday/Xmas" />
                                    <datalist id="categorySuggestions">
                                        <option value="Standard"></option>
                                        <option value="Holiday/Halloween"></option>
                                        <option value="Holiday/Xmas"></option>
                                        <option value="Archive/Bad"></option>
                                    </datalist>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label asp-for="@Model.SequenceOrder" class="control-label"></label>
                                    <input asp-for="@Model.SequenceOrder" type="number" class="form-control" placeholder="Optional" />
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="control-label">Maps</label>
                                <input type="text" id="mapSearch" class="form-control" placeholder="Search for maps by name..." autocomplete="off" />
                                <small class="form-text text-muted">Type at least 2 characters to search. Use the <i class="fa-solid fa-grip-vertical"></i> handle to drag and reorder maps. Click × to remove.</small>
                            </div>
                            <div id="selectedMapsList" class="mb-3"></div>
                            <div id="mapIdsContainer">
                                @if (Model.MapIds.Count > 0)
                                {
                                    for (var i = 0; i < Model.MapIds.Count; i++)
                                    {
                                        <input type="hidden" name="MapIds[@i]" value="@Model.MapIds[i]" />
                                    }
                                }
                            </div>
                            <div class="mb-3">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fa-solid fa-save" aria-hidden="true"></i> Save Changes
                                </button>
                                <a asp-action="Details" asp-route-id="@Model.MapRotationId" class="btn btn-outline-secondary">Cancel</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/js/map-rotation-editor.js" asp-append-version="true"></script>
    <script>
        $(document).ready(function () {
            var initialMaps = @Html.Raw(ViewBag.InitialMaps ?? "[]");
            initMapRotationEditor({
                gameType: '@Model.GameType',
                initialMaps: initialMaps
            });
        });
    </script>
}
