@model XtremeIdiots.Portal.Web.ViewModels.CreateMapRotationAssignmentViewModel

@{
    ViewData["Title"] = "Assign Server to Map Rotation" + (ViewData["RotationTitle"] != null ? " - " + ViewData["RotationTitle"] : "");
}

<div class="wrapper wrapper-content animated fadeInRight">
    <form asp-action="CreateAssignment" method="post">
        <input type="hidden" asp-for="@Model.MapRotationId" />

        <div class="row">
            <div class="col-12">
                <div class="container-fluid">
                    <div class="ibox">
                        <div class="ibox-title">
                            <h5>@ViewData["Title"]</h5>
                        </div>
                        <div class="ibox-content">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                            <div class="mb-3">
                                <label asp-for="@Model.GameServerId" class="control-label"></label>
                                <select asp-for="@Model.GameServerId" class="form-select" id="GameServerIdSelect">
                                    <option value="">-- Select Server --</option>
                                    @foreach (var server in Model.AvailableServers)
                                    {
                                        <option value="@server.GameServerId" data-ftp-enabled="@server.FtpEnabled.ToString().ToLowerInvariant()">@server.Title</option>
                                    }
                                </select>
                                <span asp-validation-for="@Model.GameServerId" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <label asp-for="@Model.ConfigFilePath" class="control-label"></label>
                                <div class="input-group">
                                    <input asp-for="@Model.ConfigFilePath" class="form-control" id="ConfigFilePathInput"
                                           placeholder="e.g. /mods/mymod/configs/server/mapcontrol.cfg" />
                                    @if (Model.CanBrowseFtp)
                                    {
                                        <button class="btn btn-outline-secondary" type="button" id="ConfigFilePathBrowseBtn"
                                                style="display: none;" title="Browse server files via FTP">
                                            <i class="fa-solid fa-folder-open me-1"></i>Browse
                                        </button>
                                    }
                                </div>
                                <small class="form-text text-muted">Path to the config file on the game server. Use the Browse button to select via FTP.</small>
                                <span asp-validation-for="@Model.ConfigFilePath" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <label asp-for="@Model.ConfigVariableName" class="control-label"></label>
                                <input asp-for="@Model.ConfigVariableName" class="form-control" id="ConfigVariableNameInput"
                                       list="configVariableSuggestions"
                                       placeholder="e.g. sv_maprotation" />
                                <datalist id="configVariableSuggestions">
                                    <option value="sv_maprotation" label="Standard map rotation"></option>
                                    <option value="scr_aacp_maps_1" label="AACP map list (semicolon-separated)"></option>
                                    <option value="sv_maprotation_low" label="Load-based: low player count"></option>
                                    <option value="sv_maprotation_medium" label="Load-based: medium player count"></option>
                                    <option value="sv_maprotation_high" label="Load-based: high player count"></option>
                                </datalist>
                                <small class="form-text text-muted">The config variable to write the rotation string to. Type a custom name or select a suggestion.</small>
                                <span asp-validation-for="@Model.ConfigVariableName" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fa-solid fa-link" aria-hidden="true"></i> Assign Server
                                </button>
                                <a asp-action="Details" asp-route-id="@Model.MapRotationId" class="btn btn-outline-secondary">Cancel</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@if (Model.CanBrowseFtp)
{
    @await Html.PartialAsync("_FtpBrowserModal")
}

@section Scripts {
    @if (Model.CanBrowseFtp)
    {
        <script src="~/js/ftp-browser.js" asp-append-version="true"></script>
    }
    <script>
        $(document).ready(function () {
            var serverSelect = document.getElementById('GameServerIdSelect');
            var browseBtn = document.getElementById('ConfigFilePathBrowseBtn');

            if (browseBtn) {
                function updateBrowseButton() {
                    var selectedOption = serverSelect.options[serverSelect.selectedIndex];
                    var ftpEnabled = selectedOption && selectedOption.dataset.ftpEnabled === 'true';
                    browseBtn.style.display = ftpEnabled ? '' : 'none';
                }

                serverSelect.addEventListener('change', updateBrowseButton);
                updateBrowseButton();

                browseBtn.addEventListener('click', function () {
                    var gameServerId = serverSelect.value;
                    if (gameServerId) {
                        openFtpBrowser(gameServerId, 'ConfigFilePathInput', '.cfg');
                    }
                });
            }
        });
    </script>
}
