@model XtremeIdiots.Portal.Web.ViewModels.ImportMapRotationsPreviewViewModel

@{
    ViewData["Title"] = "Import Preview — " + Model.Rotations.Count + " rotation(s) found";
}

<div class="wrapper wrapper-content animated fadeInRight">
    <form asp-action="ImportConfirm" method="post">
        <input type="hidden" name="DraftId" value="@Model.DraftId" />

        <div class="row">
            <div class="col-12">
                <div class="container-fluid">

                    @if (Model.Warnings.Count > 0)
                    {
                        <div class="alert alert-warning">
                            <i class="fa-solid fa-fw fa-triangle-exclamation"></i>
                            <strong>Warnings:</strong>
                            <ul class="mb-0 mt-1">
                                @foreach (var warning in Model.Warnings)
                                {
                                    <li>@warning</li>
                                }
                            </ul>
                        </div>
                    }

                    <div class="ibox">
                        <div class="ibox-title">
                            <h5>Import Prefix</h5>
                        </div>
                        <div class="ibox-content">
                            <div class="row align-items-end">
                                <div class="col-md-6">
                                    <label for="ImportPrefix" class="form-label">
                                        Title Prefix <small class="text-muted">(optional — prepended to all titles on import)</small>
                                    </label>
                                    <input type="text" class="form-control" id="ImportPrefix" name="ImportPrefix"
                                           placeholder="e.g. COD4 - Knife Maps" />
                                </div>
                                <div class="col-md-6 mt-2 mt-md-0">
                                    <button type="button" class="btn btn-sm btn-outline-primary" id="applyPrefix">
                                        <i class="fa-solid fa-fw fa-pen"></i> Preview Prefix
                                    </button>
                                    <button type="button" class="btn btn-sm btn-outline-secondary" id="clearPrefix">
                                        <i class="fa-solid fa-fw fa-eraser"></i> Clear Prefix
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="ibox">
                        <div class="ibox-title d-flex justify-content-between align-items-center">
                            <h5>@ViewData["Title"]</h5>
                            <div>
                                <button type="button" class="btn btn-sm btn-outline-secondary" id="selectAll">Select All</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" id="selectNone">Select None</button>
                            </div>
                        </div>
                        <div class="ibox-content">
                            <div class="table-responsive">
                                <table class="table table-striped table-hover">
                                    <thead>
                                        <tr>
                                            <th style="width: 40px;"><i class="fa-solid fa-fw fa-check"></i></th>
                                            <th>Title / Description</th>
                                            <th>Mode</th>
                                            <th>Maps</th>
                                            <th>Variable</th>
                                            <th>Status</th>
                                            <th>Author</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @for (var i = 0; i < Model.Rotations.Count; i++)
                                        {
                                            var item = Model.Rotations[i];
                                            <tr class="@(item.IsDuplicate ? "table-warning" : "")">
                                                <td>
                                                    <input type="checkbox" name="SelectedIndices" value="@item.Index"
                                                           class="form-check-input rotation-checkbox"
                                                           @(item.Selected ? "checked" : "") />
                                                </td>
                                                <td>
                                                    <input type="hidden" name="Edits[@i].Index" value="@item.Index" />
                                                    <input type="text" name="Edits[@i].Title" value="@item.Title"
                                                           class="form-control form-control-sm mb-1 rotation-title"
                                                           data-original-title="@item.Title"
                                                           placeholder="Rotation title" />
                                                    <input type="text" name="Edits[@i].Description" value="@item.Description"
                                                           class="form-control form-control-sm rotation-description"
                                                           placeholder="Description (optional)" />
                                                    @if (item.DateText != null)
                                                    {
                                                        <small class="text-muted mt-1 d-inline-block">@item.DateText</small>
                                                    }
                                                    @if (item.IsDuplicate)
                                                    {
                                                        <br /><small class="text-warning"><i class="fa-solid fa-fw fa-triangle-exclamation"></i> @item.DuplicateWarning</small>
                                                    }
                                                </td>
                                                <td><span class="badge bg-info">@item.GameMode</span></td>
                                                <td>
                                                    <span class="badge bg-secondary">@item.MapCount maps</span>
                                                    <br />
                                                    <small class="text-muted" title="@string.Join(", ", item.MapNames)">
                                                        @string.Join(", ", item.MapNames.Take(5))@(item.MapNames.Count > 5 ? $" +{item.MapNames.Count - 5} more" : "")
                                                    </small>
                                                </td>
                                                <td><code>@item.ConfigVariableName</code></td>
                                                <td>
                                                    @if (item.IsActive)
                                                    {
                                                        <span class="badge bg-success">Active</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary">Inactive</span>
                                                    }
                                                </td>
                                                <td>@(item.Author ?? "—")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>

                            @if (Model.NewMapNames.Count > 0)
                            {
                                <div class="alert alert-info mt-3">
                                    <i class="fa-solid fa-fw fa-circle-info"></i>
                                    <strong>@Model.NewMapNames.Count new map(s)</strong> will be created in the database:
                                    <br />
                                    <small class="font-monospace">@string.Join(", ", Model.NewMapNames)</small>
                                </div>
                            }

                            <div class="mb-3 mt-3">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fa-solid fa-fw fa-file-import"></i> Import Selected Rotations
                                </button>
                                <a asp-action="Import" class="btn btn-outline-secondary">Back</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        document.getElementById('selectAll')?.addEventListener('click', function () {
            document.querySelectorAll('.rotation-checkbox').forEach(cb => cb.checked = true);
        });
        document.getElementById('selectNone')?.addEventListener('click', function () {
            document.querySelectorAll('.rotation-checkbox').forEach(cb => cb.checked = false);
        });

        document.getElementById('applyPrefix')?.addEventListener('click', function () {
            var prefix = document.getElementById('ImportPrefix').value.trim();
            if (!prefix) return;
            var separator = ' — ';
            document.querySelectorAll('.rotation-title').forEach(function (input) {
                var original = input.getAttribute('data-original-title');
                if (!input.value.startsWith(prefix + separator)) {
                    input.value = prefix + separator + original;
                }
            });
        });

        document.getElementById('clearPrefix')?.addEventListener('click', function () {
            document.getElementById('ImportPrefix').value = '';
            document.querySelectorAll('.rotation-title').forEach(function (input) {
                input.value = input.getAttribute('data-original-title');
            });
        });
    </script>
}
