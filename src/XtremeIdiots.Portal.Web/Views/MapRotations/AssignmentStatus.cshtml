@using XtremeIdiots.Portal.Repository.Abstractions.Constants.V1
@model XtremeIdiots.Portal.Web.ViewModels.AssignmentStatusViewModel

@{
    ViewData["Title"] = "Assignment Status - " + Model.GameServerDisplayName;
    var pendingInstanceId = TempData["PendingInstanceId"] as string;
    var hasPendingWithNoRow = !string.IsNullOrEmpty(pendingInstanceId)
        && !Model.Operations.Any(o => o.Status == AssignmentOperationStatus.InProgress
            && o.DurableFunctionInstanceId == pendingInstanceId);
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="row">
        <div class="col-12">
            <div class="container-fluid">

                <div class="mb-3">
                    <a asp-action="Details" asp-route-id="@Model.Rotation.MapRotationId" class="btn btn-outline-secondary btn-sm">
                        <i class="fa-solid fa-arrow-left"></i> Back to @Model.Rotation.Title
                    </a>
                </div>

                <div class="ibox">
                    <div class="ibox-title">
                        <h5>@Model.Rotation.Title → @Model.GameServerDisplayName</h5>
                    </div>
                    <div class="ibox-content">
                        <dl class="row mb-0">
                            <dt class="col-sm-3">Deployment State</dt>
                            <dd class="col-sm-9">
                                @await Html.PartialAsync("_AssignmentStatusBadge", ("Deployment", Model.Assignment.DeploymentState.ToString()))
                            </dd>

                            <dt class="col-sm-3">Activation State</dt>
                            <dd class="col-sm-9">
                                @await Html.PartialAsync("_AssignmentStatusBadge", ("Activation", Model.Assignment.ActivationState.ToString()))
                                @if (Model.IsActivationStale)
                                {
                                    <span class="text-warning" title="Activated version is behind rotation version">⚠️ Stale</span>
                                }
                            </dd>

                            <dt class="col-sm-3">Deployed Version</dt>
                            <dd class="col-sm-9">
                                @(Model.Assignment.DeployedVersion?.ToString() ?? "—")
                                @if (Model.IsStale)
                                {
                                    <span class="text-warning" title="Deployed version is behind rotation version">⚠️ Stale (rotation is v@(Model.Rotation.Version))</span>
                                }
                            </dd>

                            <dt class="col-sm-3">Activated Version</dt>
                            <dd class="col-sm-9">@(Model.Assignment.ActivatedVersion?.ToString() ?? "—")</dd>

                            <dt class="col-sm-3">Rotation Version</dt>
                            <dd class="col-sm-9">@Model.Rotation.Version</dd>

                            @if (!string.IsNullOrEmpty(Model.Assignment.ConfigFilePath))
                            {
                                <dt class="col-sm-3">Config File</dt>
                                <dd class="col-sm-9"><code>@Model.Assignment.ConfigFilePath</code></dd>
                            }

                            @if (!string.IsNullOrEmpty(Model.Assignment.ConfigVariableName))
                            {
                                <dt class="col-sm-3">Config Variable</dt>
                                <dd class="col-sm-9"><code>@Model.Assignment.ConfigVariableName</code></dd>
                            }

                            <dt class="col-sm-3">Created</dt>
                            <dd class="col-sm-9">@Model.Assignment.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>

                            <dt class="col-sm-3">Updated</dt>
                            <dd class="col-sm-9">@Model.Assignment.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</dd>

                            @if (Model.Assignment.UnassignedAt.HasValue)
                            {
                                <dt class="col-sm-3">Unassigned</dt>
                                <dd class="col-sm-9">@Model.Assignment.UnassignedAt.Value.ToString("yyyy-MM-dd HH:mm")</dd>
                            }
                        </dl>

                        @if (!string.IsNullOrEmpty(Model.Assignment.LastError))
                        {
                            <div class="alert alert-danger mt-3 mb-0">
                                <i class="fa-solid fa-exclamation-triangle"></i> <strong>Last Error</strong>
                                @if (Model.Assignment.LastErrorAt.HasValue)
                                {
                                    <small class="text-muted">(@Model.Assignment.LastErrorAt.Value.ToString("dd MMM yyyy HH:mm:ss"))</small>
                                }
                                <p class="mb-0 mt-1">@Model.Assignment.LastError</p>
                            </div>
                        }

                        <div class="mt-3">
                            @if (Model.Assignment.DeploymentState == DeploymentState.Pending || Model.Assignment.DeploymentState == DeploymentState.Failed)
                            {
                                <form policy="@AuthPolicies.ManageMapRotations" asp-action="SyncAssignment" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="assignmentId" value="@Model.Assignment.MapRotationServerAssignmentId" />
                                    <input type="hidden" name="mapRotationId" value="@Model.Rotation.MapRotationId" />
                                    <button type="submit" class="btn btn-outline-success btn-sm me-1">
                                        <i class="fa-solid fa-sync"></i> Sync
                                    </button>
                                </form>
                            }
                            @if (Model.IsStale && Model.Assignment.DeploymentState == DeploymentState.Synced)
                            {
                                <form policy="@AuthPolicies.ManageMapRotations" asp-action="SyncAssignment" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="assignmentId" value="@Model.Assignment.MapRotationServerAssignmentId" />
                                    <input type="hidden" name="mapRotationId" value="@Model.Rotation.MapRotationId" />
                                    <button type="submit" class="btn btn-outline-warning btn-sm me-1">
                                        <i class="fa-solid fa-sync"></i> Re-sync
                                    </button>
                                </form>
                            }
                            @if (Model.Assignment.DeploymentState == DeploymentState.Synced && !Model.IsStale && !string.IsNullOrEmpty(Model.Assignment.ConfigFilePath) && Model.Assignment.ActivationState != ActivationState.Active)
                            {
                                <form policy="@AuthPolicies.ManageMapRotations" asp-action="ActivateAssignment" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="assignmentId" value="@Model.Assignment.MapRotationServerAssignmentId" />
                                    <input type="hidden" name="mapRotationId" value="@Model.Rotation.MapRotationId" />
                                    <button type="submit" class="btn btn-outline-primary btn-sm me-1">
                                        <i class="fa-solid fa-play"></i> Activate
                                    </button>
                                </form>
                            }
                            @if (Model.Assignment.ActivationState == ActivationState.Active)
                            {
                                <form policy="@AuthPolicies.ManageMapRotations" asp-action="DeactivateAssignment" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="assignmentId" value="@Model.Assignment.MapRotationServerAssignmentId" />
                                    <input type="hidden" name="mapRotationId" value="@Model.Rotation.MapRotationId" />
                                    <button type="submit" class="btn btn-outline-secondary btn-sm me-1">
                                        <i class="fa-solid fa-stop"></i> Deactivate
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>

                <div class="ibox" id="operationsContainer"
                     data-poll-url="@Url.Action("GetSyncProgress", "MapRotations")"
                     @if (!string.IsNullOrEmpty(pendingInstanceId))
                     {
                         <text>data-pending-instance-id="@pendingInstanceId"</text>
                     }>
                    <div class="ibox-title">
                        <h5>Recent Operations (@Model.Operations.Count)</h5>
                    </div>
                    <div class="ibox-content">
                        @if (Model.Operations.Count == 0 && !hasPendingWithNoRow)
                        {
                            <p class="text-muted">No operations recorded for this assignment.</p>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-striped table-sm" id="operationsTable">
                                    <thead>
                                        <tr>
                                            <th>Operation</th>
                                            <th>Status</th>
                                            <th>Started</th>
                                            <th>Completed</th>
                                            <th>Duration</th>
                                            <th>Instance</th>
                                            <th>Error</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (hasPendingWithNoRow)
                                        {
                                            <tr class="table-info pending-bootstrap-row" data-instance-id="@pendingInstanceId">
                                                <td>—</td>
                                                <td><span class="badge bg-info"><i class="fa-solid fa-spinner fa-spin"></i> Starting...</span></td>
                                                <td colspan="3"><span class="text-muted">Operation is being initialized...</span></td>
                                                <td><code class="small" title="@pendingInstanceId">@(pendingInstanceId!.Length > 20 ? pendingInstanceId[..20] + "…" : pendingInstanceId)</code></td>
                                                <td></td>
                                                <td></td>
                                            </tr>
                                            <tr class="progress-detail-row">
                                                <td colspan="8" class="p-0 border-0">
                                                    <div class="px-3 py-2 bg-light">
                                                        <div class="d-flex justify-content-between mb-1">
                                                            <span class="progress-label">Waiting for orchestration to start...</span>
                                                            <span class="progress-percent"></span>
                                                        </div>
                                                        <div class="progress mb-2" style="height: 20px;">
                                                            <div class="progress-bar progress-bar-striped progress-bar-animated bg-info" role="progressbar" style="width: 0%"></div>
                                                        </div>
                                                        <div class="progress-map-list"></div>
                                                        <div class="progress-orchestration-status mt-2"></div>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                        @foreach (var op in Model.Operations)
                                        {
                                            var isInProgress = op.Status == AssignmentOperationStatus.InProgress;
                                            var elapsedMinutes = isInProgress ? (DateTime.UtcNow - op.StartedAt).TotalMinutes : 0;
                                            <tr class="@(op.Status == AssignmentOperationStatus.Failed ? "table-danger" : isInProgress ? "table-info" : "")"
                                                @if (isInProgress && !string.IsNullOrEmpty(op.DurableFunctionInstanceId))
                                                {
                                                    <text>data-instance-id="@op.DurableFunctionInstanceId"</text>
                                                }
                                                data-started-at="@op.StartedAt.ToString("o")">
                                                <td>@op.OperationType</td>
                                                <td>
                                                    @switch (op.Status)
                                                    {
                                                        case AssignmentOperationStatus.InProgress:
                                                            <span class="badge bg-info"><i class="fa-solid fa-spinner fa-spin"></i> In Progress</span>
                                                            if (elapsedMinutes > 15)
                                                            {
                                                                <span class="badge bg-warning text-dark stale-badge" title="This operation has been running for over 15 minutes and may be stuck">⚠️ Stale</span>
                                                            }
                                                            break;
                                                        case AssignmentOperationStatus.Succeeded:
                                                            <span class="badge bg-success">Succeeded</span>
                                                            break;
                                                        case AssignmentOperationStatus.Failed:
                                                            <span class="badge bg-danger">Failed</span>
                                                            break;
                                                        case AssignmentOperationStatus.Cancelled:
                                                            <span class="badge bg-warning">Cancelled</span>
                                                            break;
                                                    }
                                                </td>
                                                <td>@op.StartedAt.ToString("dd MMM yyyy HH:mm:ss")</td>
                                                <td>@(op.CompletedAt?.ToString("dd MMM yyyy HH:mm:ss") ?? "—")</td>
                                                <td>
                                                    @if (op.CompletedAt.HasValue)
                                                    {
                                                        var duration = op.CompletedAt.Value - op.StartedAt;
                                                        @($"{(int)duration.TotalMinutes}m {duration.Seconds}s")
                                                    }
                                                    else if (isInProgress)
                                                    {
                                                        <span class="elapsed-timer" data-started-at="@op.StartedAt.ToString("o")">Calculating...</span>
                                                    }
                                                </td>
                                                <td>
                                                    @if (!string.IsNullOrEmpty(op.DurableFunctionInstanceId))
                                                    {
                                                        <code class="small" title="@op.DurableFunctionInstanceId">@(op.DurableFunctionInstanceId.Length > 20 ? op.DurableFunctionInstanceId[..20] + "…" : op.DurableFunctionInstanceId)</code>
                                                    }
                                                    else if (isInProgress)
                                                    {
                                                        <span class="text-muted small">No tracking ID</span>
                                                    }
                                                </td>
                                                <td>
                                                    @if (!string.IsNullOrEmpty(op.Error))
                                                    {
                                                        <span class="text-danger" title="@op.Error">@(op.Error.Length > 60 ? op.Error[..60] + "..." : op.Error)</span>
                                                    }
                                                </td>
                                                <td>
                                                    @if (isInProgress)
                                                    {
                                                        <form policy="@AuthPolicies.ManageMapRotations" asp-action="CancelOperation" method="post" class="d-inline">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="operationId" value="@op.MapRotationAssignmentOperationId" />
                                                            <input type="hidden" name="assignmentId" value="@Model.Assignment.MapRotationServerAssignmentId" />
                                                            <input type="hidden" name="instanceId" value="@op.DurableFunctionInstanceId" />
                                                            <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Cancel this operation? The assignment state will be reset so you can retry.')">
                                                                <i class="fa-solid fa-ban"></i> Cancel
                                                            </button>
                                                        </form>
                                                    }
                                                    @if (op.Status is AssignmentOperationStatus.Cancelled or AssignmentOperationStatus.Failed && !string.IsNullOrEmpty(op.DurableFunctionInstanceId))
                                                    {
                                                        <form policy="@AuthPolicies.ManageMapRotations" asp-action="TerminateOrchestration" method="post" class="d-inline">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="instanceId" value="@op.DurableFunctionInstanceId" />
                                                            <input type="hidden" name="assignmentId" value="@Model.Assignment.MapRotationServerAssignmentId" />
                                                            <button type="submit" class="btn btn-outline-warning btn-sm" onclick="return confirm('Terminate the underlying orchestration? This clears the stuck durable function so you can re-trigger.')">
                                                                <i class="fa-solid fa-skull-crossbones"></i> Terminate
                                                            </button>
                                                        </form>
                                                    }
                                                </td>
                                            </tr>
                                            @if (isInProgress)
                                            {
                                                <tr class="progress-detail-row">
                                                    <td colspan="8" class="p-0 border-0">
                                                        <div class="px-3 py-2 bg-light">
                                                            @if (string.IsNullOrEmpty(op.DurableFunctionInstanceId))
                                                            {
                                                                <p class="text-muted mb-0"><i class="fa-solid fa-info-circle"></i> Live progress details are unavailable — no orchestration tracking ID recorded for this operation.</p>
                                                            }
                                                            else
                                                            {
                                                                <div class="d-flex justify-content-between mb-1">
                                                                    <span class="progress-label">Waiting for progress data...</span>
                                                                    <span class="progress-percent"></span>
                                                                </div>
                                                                <div class="progress mb-2" style="height: 20px;">
                                                                    <div class="progress-bar progress-bar-striped progress-bar-animated bg-info" role="progressbar" style="width: 0%"></div>
                                                                </div>
                                                                <div class="progress-map-list"></div>
                                                                <div class="progress-orchestration-status mt-2"></div>
                                                            }
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>

                <div class="ibox">
                    <div class="ibox-title">
                        <h5>Maps (@Model.Maps.Count)</h5>
                    </div>
                    <div class="ibox-content">
                        @if (Model.Maps.Count == 0)
                        {
                            <p class="text-muted">No maps in this rotation.</p>
                        }
                        else
                        {
                            <div class="row">
                                @{ var sortedMaps = Model.Rotation.MapRotationMaps?.OrderBy(m => m.SortOrder).ToList() ?? []; }
                                @for (var i = 0; i < sortedMaps.Count; i++)
                                {
                                    var rotationMap = sortedMaps[i];
                                    var mapDto = Model.Maps.FirstOrDefault(m => m.MapId == rotationMap.MapId);
                                    if (mapDto != null)
                                    {
                                        <div class="col-md-3 col-sm-4 col-6 mb-3 text-center">
                                            <img src="@(mapDto.MapImageUri ?? "/images/noimage.jpg")" class="map-image img-fluid" alt="Map image for @mapDto.MapName" loading="lazy" />
                                            <small class="text-muted">#@(i + 1)</small>
                                            <h6 class="mb-0">@mapDto.MapName</h6>
                                        </div>
                                    }
                                }
                            </div>
                        }
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/map-rotation-progress.js" asp-append-version="true"></script>
}
