@using XtremeIdiots.Portal.Repository.Abstractions.Constants.V1
@using XtremeIdiots.Portal.Repository.Abstractions.Models.V1.GameServers
@using XtremeIdiots.Portal.Repository.Abstractions.Models.V1.MapRotations
@model XtremeIdiots.Portal.Web.ViewModels.MapRotationDetailsViewModel

@{
    ViewData["Title"] = "Map Rotation - " + Model.Rotation.Title;
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="row">
        <div class="col-12">
            <div class="container-fluid">

                <div class="ibox">
                    <div class="ibox-title">
                        <h5>@Model.Rotation.Title</h5>
                        <div class="ibox-tools">
                            <span class="badge bg-info">@Model.Rotation.GameType</span>
                            <span class="badge bg-secondary">Version @Model.Rotation.Version</span>
                            @switch (Model.Rotation.Status)
                            {
                                case MapRotationStatus.Draft:
                                    <span class="badge bg-warning text-dark">Draft</span>
                                    break;
                                case MapRotationStatus.Testing:
                                    <span class="badge bg-primary">Testing</span>
                                    break;
                                case MapRotationStatus.Active:
                                    <span class="badge bg-success">Active</span>
                                    break;
                                case MapRotationStatus.Archived:
                                    <span class="badge bg-dark">Archived</span>
                                    break;
                            }
                            @if (!string.IsNullOrEmpty(Model.Rotation.Category))
                            {
                                <span class="badge bg-outline-secondary">@Model.Rotation.Category</span>
                            }
                            <a policy="@AuthPolicies.MapRotations_Write" policy-resource="@Model.Rotation.GameType" asp-action="Clone" asp-route-id="@Model.Rotation.MapRotationId" class="btn btn-outline-secondary btn-sm">
                                <i class="fa-solid fa-fw fa-clone"></i> Clone
                            </a>
                            <a policy="@AuthPolicies.MapRotations_Write" policy-resource="@Model.Rotation.GameType" asp-action="Edit" asp-route-id="@Model.Rotation.MapRotationId" class="btn btn-outline-primary btn-sm">
                                <i class="fa-solid fa-fw fa-pen-to-square"></i> Edit
                            </a>
                            <form policy="@AuthPolicies.MapRotations_Write" policy-resource="@Model.Rotation.GameType" asp-action="Delete" asp-route-id="@Model.Rotation.MapRotationId" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger btn-sm" data-confirm="Are you sure you want to delete this map rotation? This cannot be undone.">
                                    <i class="fa-solid fa-fw fa-trash"></i> Delete
                                </button>
                            </form>
                        </div>
                    </div>
                    <div class="ibox-content">
                        <dl class="detail-fields row mb-0">
                            <div class="detail-field col-sm-4">
                                <dt class="detail-label">Game Type</dt>
                                <dd class="detail-value">@Model.Rotation.GameType</dd>
                            </div>
                            <div class="detail-field col-sm-4">
                                <dt class="detail-label">Game Mode</dt>
                                <dd class="detail-value">@Model.Rotation.GameMode</dd>
                            </div>
                            <div class="detail-field col-sm-4">
                                <dt class="detail-label">Version</dt>
                                <dd class="detail-value">@Model.Rotation.Version</dd>
                            </div>

                            @if (!string.IsNullOrEmpty(Model.Rotation.Category))
                            {
                                <div class="detail-field col-sm-4">
                                    <dt class="detail-label">Category</dt>
                                    <dd class="detail-value">@Model.Rotation.Category</dd>
                                </div>
                            }

                            @if (Model.Rotation.SequenceOrder.HasValue)
                            {
                                <div class="detail-field col-sm-4">
                                    <dt class="detail-label">Sequence Order</dt>
                                    <dd class="detail-value">#@Model.Rotation.SequenceOrder</dd>
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(Model.Rotation.Description))
                            {
                                <div class="detail-field col-sm-8">
                                    <dt class="detail-label">Description</dt>
                                    <dd class="detail-value">@Model.Rotation.Description</dd>
                                </div>
                            }

                            <div class="detail-field col-sm-4">
                                <dt class="detail-label">Created</dt>
                                <dd class="detail-value">
                                    <time user-time utc="@Model.Rotation.CreatedAt"></time>
                                    @if (!string.IsNullOrEmpty(Model.Rotation.CreatedByDisplayName))
                                    {
                                        <small class="text-muted d-block">by @Model.Rotation.CreatedByDisplayName</small>
                                    }
                                </dd>
                            </div>
                            <div class="detail-field col-sm-4">
                                <dt class="detail-label">Updated</dt>
                                <dd class="detail-value">
                                    <time user-time utc="@Model.Rotation.UpdatedAt"></time>
                                    @if (!string.IsNullOrEmpty(Model.Rotation.LastModifiedByDisplayName))
                                    {
                                        <small class="text-muted d-block">by @Model.Rotation.LastModifiedByDisplayName</small>
                                    }
                                </dd>
                            </div>
                        </dl>
                    </div>
                </div>

                <div class="ibox">
                    <div class="ibox-title">
                        <h5>Maps (@Model.Maps.Count)</h5>
                    </div>
                    <div class="ibox-content">
                        @if (Model.Maps.Count == 0)
                        {
                            <div class="empty-state">
                                <i class="fa-regular fa-map empty-state-icon"></i>
                                <p class="empty-state-message">No maps in this rotation</p>
                                <div class="empty-state-action">
                                    <a policy="@AuthPolicies.MapRotations_Write" policy-resource="@Model.Rotation.GameType" asp-action="Edit" asp-route-id="@Model.Rotation.MapRotationId" class="btn btn-primary btn-sm">
                                        <i class="fa-solid fa-fw fa-plus"></i> Add maps
                                    </a>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="row g-2 map-image-grid">
                                @{ var sortedMaps = Model.Rotation.MapRotationMaps?.OrderBy(m => m.SortOrder).ToList() ?? []; }
                                @for (var i = 0; i < sortedMaps.Count; i++)
                                {
                                    var rotationMap = sortedMaps[i];
                                    var mapDto = Model.Maps.FirstOrDefault(m => m.MapId == rotationMap.MapId);
                                    if (mapDto != null)
                                    {
                                        <div class="col-xl-2 col-lg-3 col-md-4 col-sm-4 col-6 mb-2 text-center">
                                            <img src="@(mapDto.MapImageUri ?? "/images/noimage.jpg")" class="map-image img-fluid rounded" alt="Map image for @mapDto.MapName" loading="lazy" onerror="this.onerror=null;this.src='/images/noimage.jpg';" />
                                            <small class="text-muted d-block">#@(i + 1)</small>
                                            <small class="fw-bold">@mapDto.MapName</small>
                                        </div>
                                    }
                                }
                            </div>
                        }
                    </div>
                </div>

                <div class="ibox">
                    <div class="ibox-title">
                        <h5>Server Assignments (@(Model.Rotation.ServerAssignments?.Count ?? 0))</h5>
                        <div class="ibox-tools">
                            <a policy="@AuthPolicies.MapRotations_Deploy" policy-resource="@Model.Rotation.GameType" asp-action="CreateAssignment" asp-route-mapRotationId="@Model.Rotation.MapRotationId" class="btn btn-outline-primary btn-sm">
                                <i class="fa-solid fa-fw fa-plus"></i> Assign to Server
                            </a>
                        </div>
                    </div>
                    <div class="ibox-content">
                        @if (Model.Rotation.ServerAssignments == null || Model.Rotation.ServerAssignments.Count == 0)
                        {
                            <div class="empty-state">
                                <i class="fa-solid fa-fw fa-server empty-state-icon"></i>
                                <p class="empty-state-message">No servers assigned to this rotation</p>
                            </div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-striped table-hover">
                                    <thead>
                                        <tr>
                                            <th style="width: 20%;">Server</th>
                                            <th style="width: 25%;">Config Target</th>
                                            <th style="width: 10%;">Deployment</th>
                                            <th style="width: 10%;">Activation</th>
                                            <th style="width: 10%;">Deployed Ver.</th>
                                            <th style="width: 25%;">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var assignment in Model.Rotation.ServerAssignments)
                                        {
                                            var server = ViewData[$"Server_{assignment.GameServerId}"] as GameServerDto;
                                            var isStale = assignment.DeployedVersion.HasValue && assignment.DeployedVersion < Model.Rotation.Version;
                                            var isActivationStale = assignment.ActivatedVersion.HasValue && assignment.ActivatedVersion < Model.Rotation.Version;
                                            var latestOp = Model.AssignmentOperations.GetValueOrDefault(assignment.MapRotationServerAssignmentId)?.FirstOrDefault();
                                            <tr class="@(assignment.DeploymentState == DeploymentState.Removed ? "table-secondary opacity-75" : "")">
                                                <td>
                                                    @(server?.Title ?? assignment.GameServerId.ToString())
                                                    @if (assignment.UnassignedAt.HasValue)
                                                    {
                                                        var hoursAgo = (DateTime.UtcNow - assignment.UnassignedAt.Value).TotalHours;
                                                        <small class="text-muted d-block">Removed @((int)hoursAgo)h ago</small>
                                                    }
                                                </td>
                                                <td>
                                                    @if (!string.IsNullOrEmpty(assignment.ConfigFilePath))
                                                    {
                                                        <code>@assignment.ConfigFilePath</code>
                                                    }
                                                    @if (!string.IsNullOrEmpty(assignment.ConfigVariableName))
                                                    {
                                                        <br /><code>@assignment.ConfigVariableName</code>
                                                    }
                                                </td>
                                                <td>
                                                    @await Html.PartialAsync("_AssignmentStatusBadge", ("Deployment", assignment.DeploymentState.ToString()))
                                                    @if (!string.IsNullOrEmpty(assignment.LastError) && assignment.DeploymentState == DeploymentState.Failed)
                                                    {
                                                        <div class="text-danger small mt-1" title="@assignment.LastError">
                                                            <i class="fa-solid fa-fw fa-exclamation-triangle"></i> @(assignment.LastError.Length > 80 ? assignment.LastError[..80] + "..." : assignment.LastError)
                                                        </div>
                                                    }
                                                </td>
                                                <td>
                                                    @await Html.PartialAsync("_AssignmentStatusBadge", ("Activation", assignment.ActivationState.ToString()))
                                                    @if (isActivationStale)
                                                    {
                                                        <span class="text-warning" title="Activated version is behind rotation version">⚠️</span>
                                                    }
                                                </td>
                                                <td>
                                                    @(assignment.DeployedVersion?.ToString() ?? "—")
                                                    @if (isStale)
                                                    {
                                                        <span class="text-warning" title="Deployed version is behind rotation version">⚠️</span>
                                                    }
                                                    @if (latestOp != null)
                                                    {
                                                        <small class="text-muted d-block">
                                                            Last: @latestOp.OperationType (@latestOp.Status) — <time user-time utc="@latestOp.StartedAt"></time>
                                                        </small>
                                                    }
                                                </td>
                                                <td>
                                                    <a asp-action="AssignmentStatus" asp-route-id="@assignment.MapRotationServerAssignmentId" class="btn btn-outline-secondary btn-sm me-1">
                                                        <i class="fa-solid fa-fw fa-eye"></i> Status
                                                    </a>
                                                    <a policy="@AuthPolicies.MapRotations_Deploy" policy-resource="@Model.Rotation.GameType" asp-action="EditAssignment" asp-route-id="@assignment.MapRotationServerAssignmentId" class="btn btn-outline-secondary btn-sm me-1">
                                                        <i class="fa-solid fa-fw fa-edit"></i> Edit
                                                    </a>
                                                    <a policy="@AuthPolicies.GameServers_Maps_Read" policy-resource="@Model.Rotation.GameType" asp-controller="MapManager" asp-action="Manage" asp-route-id="@assignment.GameServerId" class="btn btn-outline-secondary btn-sm me-1" title="Manage maps on this server">
                                                        <i class="fa-solid fa-fw fa-hard-drive"></i> Maps
                                                    </a>
                                                    @if (assignment.DeploymentState == DeploymentState.Pending || assignment.DeploymentState == DeploymentState.Failed)
                                                    {
                                                        <form policy="@AuthPolicies.MapRotations_Deploy" policy-resource="@Model.Rotation.GameType" asp-action="SyncAssignment" method="post" class="d-inline">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="assignmentId" value="@assignment.MapRotationServerAssignmentId" />
                                                            <input type="hidden" name="mapRotationId" value="@Model.Rotation.MapRotationId" />
                                                            <button type="submit" class="btn btn-outline-primary btn-sm me-1">
                                                                <i class="fa-solid fa-fw fa-sync"></i> Sync
                                                            </button>
                                                        </form>
                                                    }
                                                    @if (isStale && assignment.DeploymentState == DeploymentState.Synced)
                                                    {
                                                        <form policy="@AuthPolicies.MapRotations_Deploy" policy-resource="@Model.Rotation.GameType" asp-action="SyncAssignment" method="post" class="d-inline">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="assignmentId" value="@assignment.MapRotationServerAssignmentId" />
                                                            <input type="hidden" name="mapRotationId" value="@Model.Rotation.MapRotationId" />
                                                            <button type="submit" class="btn btn-outline-warning btn-sm me-1">
                                                                <i class="fa-solid fa-fw fa-sync"></i> Re-sync
                                                            </button>
                                                        </form>
                                                    }
                                                    @if (assignment.DeploymentState == DeploymentState.Synced && !isStale && !string.IsNullOrEmpty(assignment.ConfigFilePath) && assignment.ActivationState != ActivationState.Active)
                                                    {
                                                        <form policy="@AuthPolicies.MapRotations_Deploy" policy-resource="@Model.Rotation.GameType" asp-action="ActivateAssignment" method="post" class="d-inline">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="assignmentId" value="@assignment.MapRotationServerAssignmentId" />
                                                            <input type="hidden" name="mapRotationId" value="@Model.Rotation.MapRotationId" />
                                                            <button type="submit" class="btn btn-outline-primary btn-sm me-1">
                                                                <i class="fa-solid fa-fw fa-play"></i> Activate
                                                            </button>
                                                        </form>
                                                    }
                                                    @if (assignment.ActivationState == ActivationState.Active)
                                                    {
                                                        <form policy="@AuthPolicies.MapRotations_Deploy" policy-resource="@Model.Rotation.GameType" asp-action="DeactivateAssignment" method="post" class="d-inline">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="assignmentId" value="@assignment.MapRotationServerAssignmentId" />
                                                            <input type="hidden" name="mapRotationId" value="@Model.Rotation.MapRotationId" />
                                                            <button type="submit" class="btn btn-outline-secondary btn-sm me-1">
                                                                <i class="fa-solid fa-fw fa-stop"></i> Deactivate
                                                            </button>
                                                        </form>
                                                    }
                                                    <form policy="@AuthPolicies.MapRotations_Deploy" policy-resource="@Model.Rotation.GameType" asp-action="DeleteAssignment" method="post" class="d-inline">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="assignmentId" value="@assignment.MapRotationServerAssignmentId" />
                                                        <input type="hidden" name="mapRotationId" value="@Model.Rotation.MapRotationId" />
                                                        <button type="submit" class="btn btn-outline-danger btn-sm" data-confirm="Are you sure you want to unassign this server? Maps will be removed from the server.">
                                                            <i class="fa-solid fa-fw fa-unlink"></i> Unassign
                                                        </button>
                                                    </form>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>
