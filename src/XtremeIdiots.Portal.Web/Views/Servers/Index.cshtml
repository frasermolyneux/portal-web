@using XtremeIdiots.Portal.Web.Extensions
@using XtremeIdiots.Portal.Web.ViewModels
@model List<ServersGameServerViewModel>

@{
    ViewData["Title"] = "Game Servers";
}

<div class="wrapper wrapper-content animated fadeInRight">

    <div class="row">
        <div class="col-12">
            <div class="container-fluid">
                <div class="ibox">
                    <div class="ibox-title"><h5>Game Servers</h5></div>
                    <div class="ibox-content">
                        <div class="table-responsive">
                            <table id="serversTable" class="table table-striped table-hover w-100">
                                <thead>
                                    <tr>
                                        <th scope="col">Game</th>
                                        <th scope="col">Title</th>
                                        <th scope="col">Hostname</th>
                                        <th scope="col">Links</th>
                                        <th scope="col">Players</th>
                                        <th scope="col">Map</th>
                                        <th scope="col">Mod</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            <game-type-icon game="@item.GameServer.GameType"></game-type-icon>
                                        </td>
                                        <td>
                                            <a asp-controller="Servers" asp-action="Details"
                                                asp-route-id="@item.GameServer.GameServerId">
                                                <server-name title="@item.GameServer.Title"
                                                    live-title="@item.LiveStatus?.Title"></server-name>
                                            </a>
                                        </td>
                                        <td>
                                            <server-host host="@item.GameServer.Hostname"
                                                port="@item.GameServer.QueryPort"></server-host>

                                        </td>
                                        <td>
                                            <server-link type="gametracker" host="@item.GameServer.Hostname"
                                                port="@item.GameServer.QueryPort"></server-link>
                                            <server-link type="steam" game="@item.GameServer.GameType"
                                                host="@item.GameServer.Hostname"
                                                port="@item.GameServer.QueryPort"></server-link>
                                            <server-link type="hlsw" game="@item.GameServer.GameType"
                                                host="@item.GameServer.Hostname"
                                                port="@item.GameServer.QueryPort"></server-link>
                                        </td>
                                        <td>
                                            @{
                                                double percentage = 0;
                                                if (item.LiveStatus != null &&
                                                item.LiveStatus.CurrentPlayers != 0 && item.LiveStatus.MaxPlayers != 0)
                                                {
                                                    percentage = (double)item.LiveStatus.CurrentPlayers /
                                                    item.LiveStatus.MaxPlayers * 100;
                                                }
                                            }

                                            <div class="progress" style="margin-right: 20px">
                                                <div style="width: @percentage%" aria-valuemax="100" aria-valuemin="0"
                                                    aria-valuenow="@percentage" role="progressbar" class="progress-bar">
                                                    <span class="visually-hidden">@percentage% Slots Filled</span>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            @item.LiveStatus?.Map
                                        </td>
                                        <td>
                                            @item.LiveStatus?.Mod
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

</div>

@section Scripts {
    <script src="~/js/servers-index.js" asp-append-version="true"></script>
}

