@inject IAuthorizationService AuthorizationService
@using XtremeIdiots.Portal.Web.Auth.Constants
@using XtremeIdiots.Portal.Web.Extensions
@using Microsoft.AspNetCore.Authorization
@using System.Text.Json
@using XtremeIdiots.Portal.Web.ViewModels
@using XtremeIdiots.Portal.Repository.Abstractions.Constants.V1
@model List<EditBanFileMonitorViewModel>

@{
    ViewData["Title"] = "Ban File Status";
    var serverConfigs = ViewBag.ServerConfigs as Dictionary<Guid, Dictionary<string, JsonElement>>;
}

@functions {
    static string GetCfg(Dictionary<Guid, Dictionary<string, JsonElement>>? configs, Guid id, string ns, string prop)
    {
        if (configs != null &&
            configs.TryGetValue(id, out var nc) &&
            nc.TryGetValue(ns, out var r) &&
            r.TryGetProperty(prop, out var v) &&
            v.ValueKind == JsonValueKind.String)
            return v.GetString() ?? "";
        return "";
    }

    static int GetCfgInt(Dictionary<Guid, Dictionary<string, JsonElement>>? configs, Guid id, string ns, string prop, int def = 0)
    {
        if (configs != null &&
            configs.TryGetValue(id, out var nc) &&
            nc.TryGetValue(ns, out var r) &&
            r.TryGetProperty(prop, out var v) &&
            v.ValueKind == JsonValueKind.Number)
            return v.GetInt32();
        return def;
    }
}

<div class="wrapper wrapper-content animated fadeInRight">

    <div class="alert alert-primary" role="alert">
        <i class="fa-solid fa-circle-info"></i> This confirms that the ban files on the game servers have been updated with
        the latest bans and any new bans have been imported.
    </div>

    <div class="alert alert-warning" role="alert">
        <i class="fa-solid fa-triangle-exclamation" aria-hidden="true"></i> This page is used for monitoring but at present does not alert. If there is an
        error displaying below then please contact Sitting-Duc.
    </div>

    <div class="row">
        <div class="col-12">

            <div class="container-fluid">
                <div class="ibox">
                    <div class="ibox-content">
                        <h2>Ban File Monitor Status</h2>

                        <hr />

                        <p>
                            This feature is where the portal gets its bans data from the game servers and ensures the
                            servers have the latest bans.
                            There is a process that runs every five minutes that will:
                        <ul>
                            <li>Import any new bans from the game servers placed through RCON</li>
                            <li>Update the remote ban file on the server if new bans have been added or imported</li>
                        </ul>
                        </p>

                        <p>
                            Additionally there is a process that runs every 10 minutes that:
                        <ul>
                            <li>Regenerates the ban file for each game including a static PBBans list and database bans
                            </li>
                        </ul>
                        </p>

                        <hr />

                        <h3>When stuff goes wrong</h3>
                        <p>
                            This is a pretty solid process and rarely fails in it's execution. The more common issue is
                            the mod changing and this configuration not being updated.
                        </p>
                        <p>
                            If this page shows an error then contact Sitting-Duc for a resolution.
                        </p>

                        <hr />

                        <h3>Conditions for this page showing an error:</h3>
                        <ul>
                            <li>The ban file has not been checked in 15 minutes.</li>
                        </ul>
                    </div>
                </div>
            </div>

        </div>
    </div>

    @foreach (var item in Model)
    {
        <div class="row">
            <div class="col-12">

                <div class="container-fluid">
                    <div class="ibox">
                        <div class="ibox-title">
                            <span>
                                @if (item.GameServer is not null)
                                {
                                    <game-type-icon game="@item.GameServer.GameType"></game-type-icon> <server-name title="@item.GameServer.Title" live-title="@item.GameServer.LiveTitle"></server-name>
                                }
                                else
                                {
                                    <text>Unknown Server</text>
                                }
                            </span>
                        </div>
                        <div class="ibox-content">
                            @if (item.GameServer is not null)
                            {
                                <p>
                                    @if ((await AuthorizationService.AuthorizeAsync(User, new Tuple<GameType,
                                                                Guid>(item.GameServer.GameType, item.GameServer.GameServerId),
                                                                AuthPolicies.ViewFtpCredential)).Succeeded)
                                    {
                                        var ftpHost = GetCfg(serverConfigs, item.GameServerId, "ftp", "hostname");
                                        var ftpPort = GetCfgInt(serverConfigs, item.GameServerId, "ftp", "port", 21);
                                        var ftpUser = GetCfg(serverConfigs, item.GameServerId, "ftp", "username");
                                        var ftpPass = GetCfg(serverConfigs, item.GameServerId, "ftp", "password");

                                        <strong>File Path: </strong>
                                        <ftp-path host="@ftpHost" port="@ftpPort" path="@item.FilePath" user="@ftpUser" password="@ftpPass"></ftp-path>

                                <br />
                                                            }
                                    else
                                    {
                                        var ftpHostNoCred = GetCfg(serverConfigs, item.GameServerId, "ftp", "hostname");
                                        var ftpPortNoCred = GetCfgInt(serverConfigs, item.GameServerId, "ftp", "port", 21);

                                        <strong>File Path: </strong>
                                        <ftp-path host="@ftpHostNoCred" port="@ftpPortNoCred" path="@item.FilePath" show-credentials="false"></ftp-path>

                                <br />
                                                            }

                                    <strong>Last Recorded Sync: </strong>@item.LastSync<br />
                                    <strong>Last Recorded Size: </strong>@item.RemoteFileSize<br />

                                    @if (item.LastSync < DateTime.UtcNow.AddMinutes(-15))
                                    {
                                        <strong class="text-danger">Last sync was more than 15 minutes ago.</strong>
                                    }
                                </p>
                            }
                            else
                            {
                                <p>
                                    <strong>File Path: </strong>@item.FilePath<br />
                                    <strong>Last Recorded Sync: </strong>@item.LastSync<br />
                                    <strong>Last Recorded Size: </strong>@item.RemoteFileSize<br />
                                    <strong class="text-warning">Server information not available.</strong>
                                </p>
                            }
                            
                            @if (item.LastSync < DateTime.UtcNow.AddMinutes(-15))
                            {
                                <div class="alert alert-danger">Ban file monitor has not run in the past 30 minutes</div>
                            }
                            else
                            {
                                <div class="alert alert-success">Everything looks OK, on the surface at least.</div>
                            }

                            <div class="btn-group btn-group-sm" role="group">
                                @if (item.GameServer is not null && (await AuthorizationService.AuthorizeAsync(User, item.GameServer.GameType,
                                                            AuthPolicies.EditGameServer)).Succeeded)
                                {
                                    <a type="button" class="btn btn-primary" asp-controller="GameServers" asp-action="Edit"
                                        asp-route-id="@item.GameServer.GameServerId">
                                        <i class="fa-solid fa-pen-to-square"></i> Edit Game Server
                                    </a>
                                }

                                @if (item.GameServer is not null && (await AuthorizationService.AuthorizeAsync(User, new Tuple<GameType,
                                                            Guid>(item.GameServer.GameType, item.GameServer.GameServerId),
                                                            AuthPolicies.EditBanFileMonitor)).Succeeded)
                                {
                                    <a type="button" class="btn btn-primary" asp-controller="BanFileMonitors" asp-action="Edit"
                                        asp-route-id="@item.BanFileMonitorId">
                                        <i class="fa-solid fa-pen-to-square"></i> Edit Ban File Monitor
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    }

</div>