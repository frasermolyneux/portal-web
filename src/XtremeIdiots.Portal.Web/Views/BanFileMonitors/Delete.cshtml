@using System.Text.Json
@using XtremeIdiots.Portal.Web.Extensions
@using XtremeIdiots.Portal.Repository.Abstractions.Models.V1.BanFileMonitors
@model BanFileMonitorDto

@{
    ViewData["Title"] = "Delete Ban File Monitor";
    var serverConfigs = ViewBag.ServerConfigs as Dictionary<Guid, Dictionary<string, JsonElement>>;
}

@functions {
    static string GetCfg(Dictionary<Guid, Dictionary<string, JsonElement>>? configs, Guid id, string ns, string prop)
    {
        if (configs != null &&
            configs.TryGetValue(id, out var nc) &&
            nc.TryGetValue(ns, out var r) &&
            r.TryGetProperty(prop, out var v) &&
            v.ValueKind == JsonValueKind.String)
            return v.GetString() ?? "";
        return "";
    }

    static int GetCfgInt(Dictionary<Guid, Dictionary<string, JsonElement>>? configs, Guid id, string ns, string prop, int def = 0)
    {
        if (configs != null &&
            configs.TryGetValue(id, out var nc) &&
            nc.TryGetValue(ns, out var r) &&
            r.TryGetProperty(prop, out var v) &&
            v.ValueKind == JsonValueKind.Number)
            return v.GetInt32();
        return def;
    }
}

<div class="wrapper wrapper-content animated fadeInRight">

    <div class="alert alert-primary" role="alert">
        <i class="fa-solid fa-fw fa-circle-info" aria-hidden="true"></i> If you are changing a mod on the server then you can update
        the existing
        monitor rather than deleting.
    </div>

    <div class="row">
        <div class="col-12">

            <div class="container-fluid">
                <div class="ibox">
                    <div class="ibox-title">
                        <h5>@ViewData["Title"]</h5>
                    </div>
                    <div class="ibox-content">
                        <p>Are you sure you want to delete this ban file monitor?</p>
                        <div class="alert alert-warning mb-3">
                            <i class="fa-solid fa-fw fa-triangle-exclamation" aria-hidden="true"></i>
                            This action cannot be undone. Ban file synchronisation for this server path will stop.
                        </div>
                        <dl class="detail-fields row">
                            <div class="detail-field col-sm-6">
                                <dt class="detail-label">Game Server</dt>
                                <dd class="detail-value" data-testid="ban-file-monitor-delete-gameserver">
                                    <server-name title="@Model.GameServer.Title"
                                        live-title="@Model.GameServer.LiveTitle"></server-name>
                                </dd>
                            </div>
                            <div class="detail-field col-sm-6">
                                <dt class="detail-label">@Html.DisplayNameFor(model => model.FilePath)</dt>
                                <dd class="detail-value" data-testid="ban-file-monitor-delete-filepath">
                                    <ftp-path host="@GetCfg(serverConfigs, Model.GameServerId, "ftp", "hostname")" port="@GetCfgInt(serverConfigs, Model.GameServerId, "ftp", "port", 21)"
                                        path="@Model.FilePath" user="@GetCfg(serverConfigs, Model.GameServerId, "ftp", "username")"
                                        password="@GetCfg(serverConfigs, Model.GameServerId, "ftp", "password")"></ftp-path>
                                </dd>
                            </div>
                        </dl>
                    </div>
                    <div class="ibox-footer">
                        <form asp-action="Delete" class="d-inline">
                            <input type="hidden" asp-for="BanFileMonitorId" />
                            <a class="btn btn-outline-secondary" asp-action="Index"
                                data-testid="ban-file-monitor-delete-back">
                                Cancel
                            </a>
                            <button class="btn btn-danger" type="submit"
                                data-testid="ban-file-monitor-delete-confirm">
                                <i class="fa-solid fa-fw fa-trash" aria-hidden="true"></i> Delete Ban File Monitor
                            </button>
                        </form>
                    </div>
                </div>
            </div>

        </div>
    </div>

</div>

@* ReSharper disable once Razor.SectionNotResolved *@

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
