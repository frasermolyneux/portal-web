@using XtremeIdiots.Portal.Web.ViewModels
@model EditBanFileMonitorViewModel

@{
    ViewData["Title"] = "Edit Ban File Monitor";
}

<div class="wrapper wrapper-content animated fadeInRight">

    <div class="alert alert-primary" role="alert">
        <i class="fa-solid fa-fw fa-circle-info" aria-hidden="true"></i> There may be a delay of 15 - 30 minutes before the next
        execution of the
        monitor process after editing.
    </div>

    <div class="row">
        <div class="col-12">

            <div class="container-fluid">
                <div class="ibox">
                    <div class="ibox-title">
                        <h5>@ViewData["Title"]</h5>
                    </div>
                    <div class="ibox-content">
                        <form asp-action="Edit" id="editBanFileMonitorForm">
                            <div asp-validation-summary="All" class="text-danger"></div>
                            <input type="hidden" asp-for="BanFileMonitorId" />
                            <div class="mb-3">
                                <label asp-for="GameServerId" class="form-label"></label>
                                <select asp-for="GameServerId" class="form-select" asp-items="ViewBag.GameServers"
                                    disabled="disabled" data-testid="ban-file-monitor-form-gameserver"></select>
                                <span asp-validation-for="GameServerId" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <label asp-for="FilePath" class="form-label"></label>
                                <input asp-for="FilePath" class="form-control"
                                    data-testid="ban-file-monitor-form-filepath" />
                                <span asp-validation-for="FilePath" class="text-danger"></span>
                            </div>
                            <div class="alert alert-primary" role="alert">
                                <i class="fa-solid fa-fw fa-circle-info" aria-hidden="true"></i> You do not need to enter the ftp
                                hostname or
                                credentials. example: /mods/xinam/ban.txt
                            </div>
                        </form>
                    </div>
                    <div class="ibox-footer">
                        <a class="btn btn-outline-secondary" asp-action="Index" data-testid="ban-file-monitor-edit-back">
                            <i class="fa-solid fa-fw fa-arrow-left" aria-hidden="true"></i> Back to List
                        </a>
                        <button type="submit" form="editBanFileMonitorForm" class="btn btn-primary" data-testid="ban-file-monitor-edit-submit">
                            <i class="fa-solid fa-fw fa-floppy-disk" aria-hidden="true"></i> Save
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>

</div>

@* ReSharper disable once Razor.SectionNotResolved *@

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}