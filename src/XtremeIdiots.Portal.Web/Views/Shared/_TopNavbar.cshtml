@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
<nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom fixed-top" aria-label="Top navigation">
    <div class="container-fluid">
        <button class="btn btn-primary me-2" type="button" data-bs-toggle="offcanvas" data-bs-target="#sideNav" 
                aria-controls="sideNav" aria-label="Toggle navigation menu" data-testid="topnav-menu-toggle">
            <i class="fa-solid fa-fw fa-bars" aria-hidden="true"></i>
        </button>
        
        @{
            var entryAssembly = System.Reflection.Assembly.GetEntryAssembly();
            var informationalVersion = entryAssembly?.GetCustomAttribute<System.Reflection.AssemblyInformationalVersionAttribute>()?.InformationalVersion ?? "unknown";
            var buildVersion = informationalVersion.Split('+')[0];
            var assemblyVersion = entryAssembly?.GetName().Version?.ToString() ?? "unknown";
        }
        <span class="navbar-text d-none d-md-inline me-auto">
            <i class="fa-solid fa-fw fa-house" aria-hidden="true"></i> Welcome to the XI Portal
            <span class="text-muted" style="font-size: 0.75rem; margin-left: 4px;" title="Full: @informationalVersion&#10;Assembly: @assemblyVersion">v@(buildVersion)</span>
        </span>

        <ul class="navbar-nav ms-auto">
            @if (SignInManager.IsSignedIn(User))
            {
                <li class="nav-item dropdown" id="notificationBell">
                    <a class="nav-link position-relative" href="#" id="notificationDropdown" role="button"
                       data-bs-toggle="dropdown" aria-expanded="false" aria-label="Notifications"
                       data-testid="topnav-notifications-dropdown">
                        <i class="fa-solid fa-fw fa-bell" aria-hidden="true"></i>
                        <span class="badge rounded-pill bg-danger position-absolute top-0 start-100 translate-middle d-none"
                              id="notificationBadge" style="font-size: 0.6rem;">0</span>
                    </a>
                    <div class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="notificationDropdown"
                         style="min-width: 350px; max-height: 450px;">
                        <div class="d-flex justify-content-between align-items-center px-3 py-2 border-bottom">
                            <h6 class="mb-0">Notifications</h6>
                            <a href="#" id="markAllReadBtn" class="text-decoration-none small">Mark all as read</a>
                        </div>
                        <div id="notificationList" style="max-height: 350px; overflow-y: auto;">
                            <div class="text-center py-3 text-muted">
                                <i class="fa-solid fa-fw fa-spinner fa-spin"></i> Loading...
                            </div>
                        </div>
                        <div class="border-top px-3 py-2 text-center">
                            <a href="/Profile/Notifications" class="text-decoration-none small">View all notifications</a>
                        </div>
                    </div>
                </li>
            }
            <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle" href="#" id="helpDropdown" role="button"
                   data-bs-toggle="dropdown" aria-expanded="false" aria-label="Help and information" 
                   data-testid="topnav-help-dropdown">
                    <i class="fa-solid fa-fw fa-circle-question" aria-hidden="true"></i>
                </a>
                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="helpDropdown">
                    <li>
                        <a class="dropdown-item" href="https://www.xtremeidiots.com/" target="_blank" 
                           rel="noopener noreferrer" data-testid="topnav-help-website">
                            <i class="fa-solid fa-fw fa-arrow-up-right-from-square" aria-hidden="true"></i> XtremeIdiots Website
                        </a>
                    </li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <a class="dropdown-item" href="https://www.xtremeidiots.com/forums/" target="_blank" 
                           rel="noopener noreferrer" data-testid="topnav-help-forums">
                            <i class="fa-solid fa-fw fa-comments" aria-hidden="true"></i> Forums
                        </a>
                    </li>
                </ul>
            </li>
        </ul>
    </div>
</nav>
