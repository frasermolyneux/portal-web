<!-- File Transport Browser Modal — reusable file browser component -->
<div class="modal fade" id="fileBrowseModal" tabindex="-1" aria-labelledby="fileBrowseModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="fileBrowseModalLabel">
                    <i class="fa-solid fa-fw fa-folder-open me-2"></i>Browse Server Files
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <!-- Breadcrumb navigation -->
                <nav aria-label="File transport path">
                    <ol class="breadcrumb" id="fileBrowseBreadcrumb">
                        <li class="breadcrumb-item"><a href="#" data-file-path="/">/</a></li>
                    </ol>
                </nav>

                <!-- Loading spinner -->
                <div id="fileBrowseLoading" class="text-center py-4" style="display:none;">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>

                <!-- Error message -->
                <div id="fileBrowseError" class="alert alert-danger" style="display:none;"></div>

                <!-- File listing table -->
                <div id="fileBrowseListingContainer">
                    <table class="table table-hover table-sm" id="fileBrowseListingTable">
                        <thead>
                            <tr>
                                <th style="width:30px"></th>
                                <th>Name</th>
                                <th style="width:100px" class="text-end">Size</th>
                                <th style="width:160px">Modified</th>
                            </tr>
                        </thead>
                        <tbody id="fileBrowseListingBody">
                        </tbody>
                    </table>
                    <p id="fileBrowseEmptyMessage" class="text-muted text-center py-3" style="display:none;">
                        This directory is empty.
                    </p>
                </div>
            </div>
            <div class="modal-footer">
                <span id="fileBrowseSelectedPath" class="text-muted me-auto"></span>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="fileBrowseSelectBtn" disabled>
                    <i class="fa-solid fa-fw fa-check"></i>Select
                </button>
            </div>
        </div>
    </div>
</div>