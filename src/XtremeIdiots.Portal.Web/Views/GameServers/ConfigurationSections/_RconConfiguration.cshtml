@using XtremeIdiots.Portal.Web.ViewModels
@model GameServerEditViewModel

<div class="ibox">
    <div class="ibox-title">
        RCON Configuration
    </div>
    <div class="ibox-content">
        <div class="mb-3">
            <label asp-for="RconConfigPassword" class="control-label"></label>
            <div class="input-group">
                <input name="RconConfigPassword" class="form-control" type="password" id="rconPasswordInput" value="@Model.RconConfigPassword" />
                <button class="btn btn-outline-secondary" type="button" onclick="togglePasswordVisibility('rconPasswordInput', this)">
                    <i class="fa-solid fa-eye"></i>
                </button>
            </div>
            <input type="hidden" asp-for="HasExistingRconPassword" />
            <span asp-validation-for="RconConfigPassword" class="text-danger"></span>
            @if (Model.HasExistingRconPassword)
            {
                <small class="form-text text-success"><i class="fa-solid fa-check-circle"></i> A password is currently set. Leave blank to keep the existing password.</small>
            }
            else
            {
                <small class="form-text text-muted">The RCON password used for remote server administration.</small>
            }
        </div>
    </div>
</div>
