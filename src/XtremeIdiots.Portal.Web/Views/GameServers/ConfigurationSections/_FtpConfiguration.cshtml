@using XtremeIdiots.Portal.Web.ViewModels
@model GameServerEditViewModel

<div class="ibox">
    <div class="ibox-title">
        File Transfer Configuration
    </div>
    <div class="ibox-content">
        <div class="mb-3">
            <label asp-for="GameServer.FileTransportType" class="form-label"></label>
            <select asp-for="GameServer.FileTransportType" class="form-select">
                <option value="Ftp">FTP</option>
                <option value="Sftp">SFTP</option>
            </select>
            <span asp-validation-for="GameServer.FileTransportType" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="FtpConfigHostname" class="form-label"></label>
            <input asp-for="FtpConfigHostname" class="form-control" />
            <span asp-validation-for="FtpConfigHostname" class="text-danger"></span>
            <small class="form-text text-muted">The hostname or IP address of the <span
                class="js-file-transport-label">@Model.FileTransportLabel</span> server for
                file transfers.</small>
            </div>
            <div class="mb-3">
                <label asp-for="FtpConfigPort" class="form-label"></label>
                <input asp-for="FtpConfigPort" class="form-control" type="number" />
                <span asp-validation-for="FtpConfigPort" class="text-danger"></span>
                <small class="form-text text-muted"><span class="js-file-transport-label">@Model.FileTransportLabel</span>
                    port number (default:
                    <span
                    id="file-transport-default-port">@XtremeIdiots.Portal.Web.ViewModels.GameServerEditViewModel.GetDefaultPort(Model.GameServer.FileTransportType)</span>).</small>
                </div>
                <div class="mb-3">
                    <label asp-for="FtpConfigUsername" class="form-label"></label>
                    <input asp-for="FtpConfigUsername" class="form-control" />
                    <span asp-validation-for="FtpConfigUsername" class="text-danger"></span>
                    <small class="form-text text-muted">Username for <span
                        class="js-file-transport-label">@Model.FileTransportLabel</span> authentication.</small>
                    </div>
                    <div class="mb-3">
                        <label asp-for="FtpConfigPassword" class="form-label"></label>
                        <div class="input-group">
                            <input name="FtpConfigPassword" class="form-control" type="password" id="ftpPasswordInput"
                                   value="@Model.FtpConfigPassword" />
                            <button class="btn btn-outline-secondary" type="button"
                                    onclick="togglePasswordVisibility('ftpPasswordInput', this)">
                                <i class="fa-solid fa-fw fa-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="FtpConfigPassword" class="text-danger"></span>
                        <small class="form-text text-muted">Password for <span
                            class="js-file-transport-label">@Model.FileTransportLabel</span> authentication.</small>
                        </div>
                    </div>
                </div>
