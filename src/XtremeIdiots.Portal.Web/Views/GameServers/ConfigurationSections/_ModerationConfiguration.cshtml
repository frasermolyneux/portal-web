@using XtremeIdiots.Portal.Web.ViewModels
@model GameServerEditViewModel

<div class="ibox">
    <div class="ibox-title">
        <h5>Player Protection</h5>
    </div>
    <div class="ibox-content">
        <div class="form-check mb-3">
            <label class="form-check-label">
                <input class="form-check-input" asp-for="ModerationProtectedNameEnforcementEnabled" />
                @Html.DisplayNameFor(m => m.ModerationProtectedNameEnforcementEnabled)
            </label>
            <small class="form-text text-muted d-block">Whether players using protected names are kicked if they don't
                match the expected identity.</small>
            </div>
        </div>
    </div>

    <div class="ibox">
        <div class="ibox-title">
            <h5>Chat Moderation</h5>
        </div>
        <div class="ibox-content">
            <p class="text-muted mb-3">Override chat moderation defaults for this server.</p>
            <div class="mb-3">
                <label asp-for="ModerationHateSeverityThreshold" class="form-label"></label>
                <select asp-for="ModerationHateSeverityThreshold" class="form-select"
                        asp-items="GlobalSettingsViewModel.BuildSeverityOptions(true)"></select>
                <span asp-validation-for="ModerationHateSeverityThreshold" class="text-danger"></span>
                <small class="form-text text-muted">Override hate threshold for this server, or leave as Use global default
                    (currently: @(Model.GlobalModerationHateSeverityThreshold ==
                                    GlobalSettingsViewModel.DisabledSeverityThreshold ? "Disabled" :
                                    Model.GlobalModerationHateSeverityThreshold.ToString())).</small>
                </div>
                <div class="mb-3">
                    <label asp-for="ModerationViolenceSeverityThreshold" class="form-label"></label>
                    <select asp-for="ModerationViolenceSeverityThreshold" class="form-select"
                            asp-items="GlobalSettingsViewModel.BuildSeverityOptions(true)"></select>
                    <span asp-validation-for="ModerationViolenceSeverityThreshold" class="text-danger"></span>
                    <small class="form-text text-muted">Override violence threshold for this server, or leave as Use global
                        default (currently: @(Model.GlobalModerationViolenceSeverityThreshold ==
                                        GlobalSettingsViewModel.DisabledSeverityThreshold ? "Disabled" :
                                        Model.GlobalModerationViolenceSeverityThreshold.ToString())).</small>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ModerationSexualSeverityThreshold" class="form-label"></label>
                        <select asp-for="ModerationSexualSeverityThreshold" class="form-select"
                                asp-items="GlobalSettingsViewModel.BuildSeverityOptions(true)"></select>
                        <span asp-validation-for="ModerationSexualSeverityThreshold" class="text-danger"></span>
                        <small class="form-text text-muted">Override sexual threshold for this server, or leave as Use global
                            default (currently: @(Model.GlobalModerationSexualSeverityThreshold ==
                                            GlobalSettingsViewModel.DisabledSeverityThreshold ? "Disabled" :
                                            Model.GlobalModerationSexualSeverityThreshold.ToString())).</small>
                        </div>
                        <div class="mb-3">
                            <label asp-for="ModerationSelfHarmSeverityThreshold" class="form-label"></label>
                            <select asp-for="ModerationSelfHarmSeverityThreshold" class="form-select"
                                    asp-items="GlobalSettingsViewModel.BuildSeverityOptions(true)"></select>
                            <span asp-validation-for="ModerationSelfHarmSeverityThreshold" class="text-danger"></span>
                            <small class="form-text text-muted">Override self-harm threshold for this server, or leave as Use global
                                default (currently: @(Model.GlobalModerationSelfHarmSeverityThreshold ==
                                                GlobalSettingsViewModel.DisabledSeverityThreshold ? "Disabled" :
                                                Model.GlobalModerationSelfHarmSeverityThreshold.ToString())).</small>
                            </div>
                            <div class="mb-3">
                                <label asp-for="ModerationMinMessageLength" class="form-label"></label>
                                <input asp-for="ModerationMinMessageLength" class="form-control" type="number" min="1"
                                       placeholder="@Model.GlobalModerationMinMessageLength" />
                                <span asp-validation-for="ModerationMinMessageLength" class="text-danger"></span>
                                <small class="form-text text-muted">Override the global minimum message length for content safety analysis
                                    on this server. Leave empty to use global default (currently:
                                    @Model.GlobalModerationMinMessageLength).</small>
                                </div>
                            </div>
                        </div>
