@using XtremeIdiots.Portal.Web.ViewModels
@model GameServerEditViewModel

<div class="ibox">
    <div class="ibox-title">
        <h5>Ban File Sync Configuration</h5>
    </div>
    <div class="ibox-content">
        <div class="alert alert-info small mb-3" role="alert">
            <i class="fa-solid fa-fw fa-circle-info" aria-hidden="true"></i>
            Ban file sync runs as part of the agent's check loop and requires
            <strong>Agent Enabled</strong>. Disabling the agent automatically disables ban file sync.
        </div>

        <div class="mb-3">
            <label asp-for="GameServer.BanFileRootPath" class="form-label"></label>
            <div class="input-group">
                <input asp-for="GameServer.BanFileRootPath" class="form-control" type="text" maxlength="255"
                       placeholder="/" />
                @if (Model.GameServer.FileTransportEnabled && Model.CanEditFileTransport)
                {
                    <button class="btn btn-outline-secondary" type="button"
                            data-file-browser
                            data-server-id="@Model.GameServer.GameServerId"
                            data-target-id="GameServer_BanFileRootPath"
                            data-selection-mode="directory"
                            data-initial-path-source="GameServer_BanFileRootPath">
                        <i class="fa-solid fa-fw fa-folder-open"></i>Browse
                    </button>
                }
            </div>
            <span asp-validation-for="GameServer.BanFileRootPath" class="text-danger"></span>
            <small class="form-text text-muted">
                File transport root path beneath which the ban file lives. The agent resolves the full path
                from this root plus per-game-type rules and the currently-running mod
                (e.g. <code>{root}/mods/&lt;mod&gt;/ban.txt</code> for CoD4/5,
                <code>{root}/ban.txt</code> for CoD2). Defaults to <code>/</code>. Use Browse to pick the
                remote folder via file transport.
            </small>
        </div>

        <div class="mb-3">
            <label asp-for="BanFileSyncConfigCheckIntervalSeconds" class="form-label"></label>
            <input asp-for="BanFileSyncConfigCheckIntervalSeconds" class="form-control" type="number" min="10"
                   max="86400" />
            <span asp-validation-for="BanFileSyncConfigCheckIntervalSeconds" class="text-danger"></span>
            <small class="form-text text-muted">How often (in seconds) to check for ban file updates. Valid range:
                10–86400 (default: 60).</small>
            </div>
        </div>
    </div>


