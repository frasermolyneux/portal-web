@using XtremeIdiots.Portal.Web.ViewModels
@model GameServerEditViewModel

<div class="ibox">
    <div class="ibox-title">
        <h5>Server List</h5>
    </div>
    <div class="ibox-content">
        <p class="text-muted mb-3">
            Configure server-list presentation overrides for this server.
        </p>
        <div class="mb-3">
            <label asp-for="ServerListConfigHtmlBanner" class="form-label"></label>
            <textarea asp-for="ServerListConfigHtmlBanner" class="form-control" rows="6"></textarea>
            <span asp-validation-for="ServerListConfigHtmlBanner" class="text-danger"></span>
            <small class="form-text text-muted">Custom HTML banner content displayed for this server in the server
                list.</small>
            </div>
        </div>
    </div>
