@model XtremeIdiots.Portal.Web.ViewModels.GameServerEditViewModel
@using XtremeIdiots.Portal.Settings.Contracts.V1.Contracts.Cod4xPower
@using XtremeIdiots.Portal.Settings.Contracts.V1.Contracts.Cod4xPlugin

<div class="ibox">
    <div class="ibox-title">
        <h5>CoD4x Settings</h5>
    </div>
    <div class="ibox-content">
        <p class="text-muted mb-0">Configure server-level CoD4x overrides. Keep inherit enabled to use fleet-wide
            defaults from Global Settings.</p>
        </div>
    </div>

    <div class="ibox">
        <div class="ibox-title">
            <h5><i class="fa-solid fa-fw fa-puzzle-piece" aria-hidden="true"></i> Plugin</h5>
        </div>
        <div class="ibox-content">
            <div class="form-check mb-3">
                <input class="form-check-input" asp-for="Cod4xInheritPluginSettings" />
                <label class="form-check-label" asp-for="Cod4xInheritPluginSettings"></label>
                <small class="form-text text-muted d-block">Global value: <strong>@(Model.GlobalCod4xPluginEnabled ?
                                                                                    "Enabled" : "Disabled")</strong></small>
                </div>

                <div id="cod4x-plugin-override-panel">
                    <div class="form-check mb-0">
                        <input class="form-check-input" asp-for="Cod4xPluginEnabled" />
                        <label class="form-check-label" asp-for="Cod4xPluginEnabled"></label>
                    </div>
                    <span asp-validation-for="Cod4xPluginEnabled" class="text-danger"></span>

                    <div class="mt-3 mb-0">
                        <label asp-for="Cod4xPluginRootDirectory" class="form-label"></label>
                        <div class="input-group">
                            <input asp-for="Cod4xPluginRootDirectory" class="form-control" type="text"
                                   id="Cod4xPluginRootDirectory"
                                   placeholder="@(string.IsNullOrWhiteSpace(Model.GlobalCod4xPluginRootDirectory) ? "/plugins" : Model.GlobalCod4xPluginRootDirectory)" />
                            @if (Model.GameServer.FileTransportEnabled && Model.CanEditFileTransport)
                            {
                                <button class="btn btn-outline-secondary" type="button" data-file-browser
                                        data-server-id="@Model.GameServer.GameServerId" data-target-id="Cod4xPluginRootDirectory"
                                        data-selection-mode="directory" data-initial-path-source="Cod4xPluginRootDirectory">
                                    <i class="fa-solid fa-fw fa-folder-open" aria-hidden="true"></i> Browse
                                </button>
                            }
                        </div>
                        <span asp-validation-for="Cod4xPluginRootDirectory" class="text-danger"></span>
                        @if (!string.IsNullOrWhiteSpace(Model.GlobalCod4xPluginRootDirectory))
                        {
                            <small class="form-text text-muted d-block">Global value:
                                <code>@Model.GlobalCod4xPluginRootDirectory</code></small>
                            }
                        </div>

                        <hr />

                        <div class="row g-3">
                            <div class="col-md-6">
                                <h6 class="mb-2">Runtime State</h6>
                                <dl class="row mb-0">
                                    <dt class="col-6">Current Version</dt>
                                    <dd class="col-6">@(Model.Cod4xRuntimeCurrentVersion ?? "-")</dd>

                                    <dt class="col-6">Known Good</dt>
                                    <dd class="col-6">@(Model.Cod4xRuntimePreviousKnownGoodVersion ?? "-")</dd>

                                    <dt class="col-6">Last Status</dt>
                                    <dd class="col-6">@Model.Cod4xRuntimeLastOperationStatus</dd>

                                    <dt class="col-6">Last Operation</dt>
                                    <dd class="col-6">@(Model.Cod4xRuntimeLastOperationId ?? "-")</dd>

                                    <dt class="col-6">Last Updated</dt>
                                    <dd class="col-6">@(Model.Cod4xRuntimeLastOperationUtc?.ToString("u") ?? "-")</dd>
                                </dl>

                                @if (!string.IsNullOrWhiteSpace(Model.Cod4xRuntimeLastError))
                                {
                                    <div class="alert alert-warning mt-2 mb-0">
                                        <strong>Last Error:</strong> @Model.Cod4xRuntimeLastError
                                    </div>
                                }
                            </div>

                            <div class="col-md-6">
                                <h6 class="mb-2">Pending Operation</h6>
                                @if (Model.Cod4xOperationRequestAction != Cod4xPluginOperationAction.Unknown)
                                {
                                    <dl class="row mb-0">
                                        <dt class="col-6">Operation Id</dt>
                                        <dd class="col-6">@(Model.Cod4xOperationRequestOperationId ?? "-")</dd>

                                        <dt class="col-6">Action</dt>
                                        <dd class="col-6">@Model.Cod4xOperationRequestAction</dd>

                                        <dt class="col-6">Target Version</dt>
                                        <dd class="col-6">@(Model.Cod4xOperationRequestTargetVersion ?? "-")</dd>

                                        <dt class="col-6">Requested At</dt>
                                        <dd class="col-6">@(Model.Cod4xOperationRequestRequestedAtUtc?.ToString("u") ?? "-")</dd>

                                        <dt class="col-6">Requested By</dt>
                                        <dd class="col-6">@(Model.Cod4xOperationRequestRequestedBy ?? "-")</dd>
                                    </dl>
                                }
                                else
                                {
                                    <p class="text-muted mb-0">No pending CoD4x plugin operation request.</p>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="ibox">
                <div class="ibox-title">
                    <h5><i class="fa-solid fa-fw fa-bolt" aria-hidden="true"></i> Power</h5>
                </div>
                <div class="ibox-content">
                    <div class="form-check mb-3">
                        <input class="form-check-input" asp-for="Cod4xInheritPowerSettings" />
                        <label class="form-check-label" asp-for="Cod4xInheritPowerSettings"></label>
                        <small class="form-text text-muted d-block">Global enabled: <strong>@(Model.GlobalCod4xPowerEnabled ?
                                                                                                        "Enabled" : "Disabled")</strong>, default power:
                            <strong>@Model.GlobalCod4xPowerDefaultPower</strong></small>
                        </div>

                        <div id="cod4x-power-override-panel">
                            <div class="row">
                                <div class="col-md-4">
                                    <div class="form-check mb-3">
                                        <input class="form-check-input" asp-for="Cod4xPowerEnabled" />
                                        <label class="form-check-label" asp-for="Cod4xPowerEnabled"></label>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="mb-3">
                                        <label asp-for="Cod4xPowerDefaultPower" class="form-label"></label>
                                        <input asp-for="Cod4xPowerDefaultPower" class="form-control" type="number" />
                                        <span asp-validation-for="Cod4xPowerDefaultPower" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>

                            <input type="hidden" asp-for="Cod4xPowerTagMappingsJson" />

                            <div class="mb-0">
                                <label class="form-label">CoD4x Power Tag Mappings</label>
                                @if (Model.Cod4xPowerTagMappings.Count == 0)
                                {
                                    <p class="text-muted mb-0">No tags are currently available. Add tags first to manage CoD4x power
                                        mappings.</p>
                                    }
                else
                                    {
                                        <div class="table-responsive">
                                            <table class="table table-striped table-hover align-middle mb-2">
                                                <thead>
                                                    <tr>
                                                        <th>Tag</th>
                                                        <th style="width: 220px;">Assigned Power</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @for (var i = 0; i < Model.Cod4xPowerTagMappings.Count; i++)
                                                    {
                                                        <tr>
                                                            <td>
                                                                <input type="hidden" asp-for="Cod4xPowerTagMappings[i].Tag" />
                                                                <strong>@Model.Cod4xPowerTagMappings[i].Tag</strong>
                                                            </td>
                                                            <td>
                                                                <input asp-for="Cod4xPowerTagMappings[i].Power" class="form-control" type="number"
                                                                       min="0" max="@Cod4xPowerSettingsConstants.MaxPower" />
                                                                <span asp-validation-for="Cod4xPowerTagMappings[i].Power"
                                                                      class="text-danger"></span>
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }

                                    <span asp-validation-for="Cod4xPowerTagMappingsJson" class="text-danger"></span>
                                    <small class="form-text text-muted">Tags are sourced from the tag catalog. New tags default to
                                        <strong>0</strong> and removed tags are dropped from this list (and from saved JSON) on the next
                                        save.</small>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="ibox">
                            <div class="ibox-title">
                                <h5><i class="fa-solid fa-fw fa-terminal" aria-hidden="true"></i> Command Minimum Power</h5>
                            </div>
                            <div class="ibox-content">
                                <div class="form-check mb-3">
                                    <input class="form-check-input" asp-for="Cod4xInheritCommandSettings" />
                                    <label class="form-check-label" asp-for="Cod4xInheritCommandSettings"></label>
                                    <small class="form-text text-muted d-block">Global command enforcement:
                                        <strong>@(Model.GlobalCod4xCommandsEnabled ? "Enabled" : "Disabled")</strong></small>
                                    </div>

                                    <div id="cod4x-command-override-panel">
                                        <div class="form-check mb-3">
                                            <input class="form-check-input" asp-for="Cod4xCommandsEnabled" />
                                            <label class="form-check-label" asp-for="Cod4xCommandsEnabled"></label>
                                        </div>

                                        <div class="table-responsive">
                                            <table class="table table-striped table-hover align-middle">
                                                <thead>
                                                    <tr>
                                                        <th>Command</th>
                                                        <th style="width: 160px;">Enabled</th>
                                                        <th style="width: 220px;">Minimum Power</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @for (var i = 0; i < Model.Cod4xCommands.Count; i++)
                                                    {
                                                        <tr>
                                                            <td>
                                                                <input type="hidden" asp-for="Cod4xCommands[i].Name" />
                                                                <strong>@Model.Cod4xCommands[i].Name</strong>
                                                            </td>
                                                            <td>
                                                                <div class="form-check">
                                                                    <input class="form-check-input" asp-for="Cod4xCommands[i].Enabled" />
                                                                </div>
                                                            </td>
                                                            <td>
                                                                <input asp-for="Cod4xCommands[i].MinPower" class="form-control" type="number" />
                                                                <span asp-validation-for="Cod4xCommands[i].MinPower" class="text-danger"></span>
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
