@inject IAuthorizationService AuthorizationService
@using Microsoft.AspNetCore.Authorization
@using XtremeIdiots.Portal.Repository.Abstractions.Models.V1.GameServers
@model IEnumerable<GameServerDto>

@{
    ViewData["Title"] = "Reorder Game Servers";
}

<div class="wrapper wrapper-content animated fadeInRight">

    <div class="row">
        <div class="col-12">

            <div class="container-fluid">
                <div class="ibox">
                    <div class="ibox-title">
                        <h5>@ViewData["Title"]</h5>
                        <small>Drag servers using the <i class="fa-solid fa-fw fa-grip-vertical"></i> handle to reorder. Click "Save Order" when done.</small>
                    </div>
                    <div class="ibox-content">
                        @Html.AntiForgeryToken()

                        <div id="gameServerReorderList">
                            @{ var index = 0; }
                            @foreach (var item in Model)
                            {
                                <div class="game-server-item d-flex align-items-center border rounded p-2 mb-2 bg-light"
                                     draggable="true"
                                     data-server-id="@item.GameServerId"
                                     data-index="@index">
                                    <span class="game-server-drag-handle me-2" title="Drag to reorder">
                                        <i class="fa-solid fa-fw fa-grip-vertical"></i>
                                    </span>
                                    <span class="badge bg-secondary me-2 game-server-position-badge" style="min-width:28px;">@(index + 1)</span>
                                    <game-type-icon game="@item.GameType"></game-type-icon>
                                    <span class="fw-bold ms-2 me-2">@item.Title</span>
                                    <span class="text-muted"><server-host host="@item.Hostname" port="@item.QueryPort"></server-host></span>
                                </div>
                                index++;
                            }
                        </div>

                        <div id="reorderFeedback" class="mt-2" style="display:none;"></div>

                        <div class="mt-3">
                            <button type="button" id="saveOrderBtn" class="btn btn-primary">
                                <i class="fa-solid fa-fw fa-floppy-disk"></i> Save Order
                            </button>
                        </div>
                    </div>
                    <div class="ibox-footer">
                        <div class="btn-group btn-group-sm" role="group">
                            <a class="btn btn-outline-secondary" asp-action="Index"><i class="fa-solid fa-fw fa-arrow-left"></i> Back to List</a>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

</div>

@section Scripts {
    <script src="~/js/game-servers-reorder.js" asp-append-version="true"></script>
}
