@inject IAuthorizationService AuthorizationService
@using XtremeIdiots.Portal.Web.Auth.Constants
@using XtremeIdiots.Portal.Web.Extensions
@using Microsoft.AspNetCore.Authorization
@using XtremeIdiots.Portal.Repository.Abstractions.Constants.V1
@using XtremeIdiots.Portal.Repository.Abstractions.Models.V1.GameServers
@model GameServerDto

@{
    ViewData["Title"] = "Game Server Details";
}

<div class="wrapper wrapper-content animated fadeInRight">

    <div class="row">
        <div class="col-12">

            <div class="container-fluid">
                <div class="ibox">
                    <div class="ibox-title">
                        <h5>@ViewData["Title"]</h5>
                    </div>
                    <div class="ibox-content">
                        <dl class="detail-fields row">
                            <div class="detail-field col-sm-6">
                                <dt class="detail-label">@Html.DisplayNameFor(model => model.Title)</dt>
                                <dd class="detail-value">@Html.DisplayFor(model => model.Title)</dd>
                            </div>
                            <div class="detail-field col-sm-6">
                                <dt class="detail-label">@Html.DisplayNameFor(model => model.GameType)</dt>
                                <dd class="detail-value">@Html.DisplayFor(model => model.GameType)</dd>
                            </div>
                            <div class="detail-field col-sm-6">
                                <dt class="detail-label">@Html.DisplayNameFor(model => model.Hostname)</dt>
                                <dd class="detail-value">
                                    <server-host host="@Model.Hostname" port="@Model.QueryPort"></server-host>
                                </dd>
                            </div>

                            @if ((await AuthorizationService.AuthorizeAsync(User, new Tuple<GameType,
                                                        Guid>(Model.GameType, Model.GameServerId), AuthPolicies.ViewFtpCredential)).Succeeded)
                            {
                                <div class="detail-field col-sm-6">
                                    <dt class="detail-label">FTP Hostname</dt>
                                    <dd class="detail-value">@ViewBag.FtpHostname</dd>
                                </div>
                                <div class="detail-field col-sm-6">
                                    <dt class="detail-label">FTP Port</dt>
                                    <dd class="detail-value">@ViewBag.FtpPort</dd>
                                </div>
                                <div class="detail-field col-sm-6">
                                    <dt class="detail-label">FTP Username</dt>
                                    <dd class="detail-value">@ViewBag.FtpUsername</dd>
                                </div>
                                <div class="detail-field col-sm-6">
                                    <dt class="detail-label">FTP Password</dt>
                                    <dd class="detail-value">@ViewBag.FtpPassword</dd>
                                </div>
                            }

                            @if ((await AuthorizationService.AuthorizeAsync(User, new Tuple<GameType,
                                                        Guid>(Model.GameType, Model.GameServerId), AuthPolicies.ViewRconCredential)).Succeeded)
                            {
                                <div class="detail-field col-sm-6">
                                    <dt class="detail-label">RCON Password</dt>
                                    <dd class="detail-value">@ViewBag.RconPassword</dd>
                                </div>
                            }

                            <div class="detail-field col-sm-6">
                                <dt class="detail-label">@Html.DisplayNameFor(model => model.AgentEnabled)</dt>
                                <dd class="detail-value">@Html.DisplayFor(model => model.AgentEnabled)</dd>
                            </div>
                            <div class="detail-field col-sm-6">
                                <dt class="detail-label">@Html.DisplayNameFor(model => model.FtpEnabled)</dt>
                                <dd class="detail-value">@Html.DisplayFor(model => model.FtpEnabled)</dd>
                            </div>
                            <div class="detail-field col-sm-6">
                                <dt class="detail-label">@Html.DisplayNameFor(model => model.RconEnabled)</dt>
                                <dd class="detail-value">@Html.DisplayFor(model => model.RconEnabled)</dd>
                            </div>
                            <div class="detail-field col-sm-6">
                                <dt class="detail-label">@Html.DisplayNameFor(model => model.BanFileSyncEnabled)</dt>
                                <dd class="detail-value">@Html.DisplayFor(model => model.BanFileSyncEnabled)</dd>
                            </div>
                            <div class="detail-field col-sm-6">
                                <dt class="detail-label">@Html.DisplayNameFor(model => model.ServerListEnabled)</dt>
                                <dd class="detail-value">@Html.DisplayFor(model => model.ServerListEnabled)</dd>
                            </div>
                            <div class="detail-field col-sm-6">
                                <dt class="detail-label">@Html.DisplayNameFor(model => model.ServerListPosition)</dt>
                                <dd class="detail-value">@Html.DisplayFor(model => model.ServerListPosition)</dd>
                            </div>
                        </dl>
                    </div>
                    <div class="ibox-footer">
                        <a class="btn btn-primary" asp-action="Edit"
                            asp-route-id="@Model.GameServerId"><i class="fa-solid fa-fw fa-pen-to-square"></i> Edit</a>
                        <a class="btn btn-outline-secondary" asp-action="Index"><i class="fa-solid fa-fw fa-arrow-left"></i>
                            Back to List</a>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <div class="row">
        <div class="col-12">

            <div class="container-fluid">
                <div class="ibox">
                    <div class="ibox-title">
                        <h5>Ban File Monitors</h5>
                    </div>
                    <div class="ibox-content">
                        <div class="table-responsive">
                            <table id="gameServerMonitorsTable" class="table table-striped table-hover w-100">
                                <thead>
                                    <tr>
                                        <th scope="col">
                                            File Path
                                        </th>
                                        <th scope="col" class="table-date-col">
                                            Last Sync
                                        </th>
                                        <th scope="col" class="table-action-col"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.BanFileMonitors)
                                    {
                                        <tr>
                                            <td>
                                            @if ((await AuthorizationService.AuthorizeAsync(User, new Tuple<GameType,
                                                                                    Guid>(Model.GameType, Model.GameServerId),
                                                                                    AuthPolicies.ViewFtpCredential)).Succeeded)
                                            {
                                                <ftp-path host="@ViewBag.FtpHostname" port="@(ViewBag.FtpPort ?? 0)"
                                                    path="@item.FilePath" user="@ViewBag.FtpUsername"
                                                    password="@ViewBag.FtpPassword"></ftp-path>
                                            }
                                            else
                                            {
                                                <ftp-path host="@ViewBag.FtpHostname" port="@(ViewBag.FtpPort ?? 0)"
                                                    path="@item.FilePath" show-credentials="false"></ftp-path>
                                            }
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.LastSync)
                                        </td>
                                        <td>
                                            <div class="btn-group btn-group-sm" role="group">
                                                @if ((await AuthorizationService.AuthorizeAsync(User, new Tuple<GameType,
                                                                                            Guid>(Model.GameType, Model.GameServerId),
                                                                                            AuthPolicies.EditBanFileMonitor)).Succeeded)
                                                {
                                                    <a class="btn btn-outline-secondary" asp-controller="BanFileMonitors"
                                                        asp-action="Edit" asp-route-id="@item.BanFileMonitorId"><i
                                                            class="fa-solid fa-fw fa-pen-to-square"></i> Edit</a>
                                                }

                                                @if ((await AuthorizationService.AuthorizeAsync(User, new Tuple<GameType,
                                                                                            Guid>(Model.GameType, Model.GameServerId),
                                                                                            AuthPolicies.ViewBanFileMonitor)).Succeeded)
                                                {
                                                    <a class="btn btn-outline-secondary" asp-controller="BanFileMonitors"
                                                        asp-action="Details" asp-route-id="@item.BanFileMonitorId"><i
                                                            class="fa-solid fa-fw fa-eye"></i> Details</a>
                                                }

                                                @if ((await AuthorizationService.AuthorizeAsync(User, new Tuple<GameType,
                                                                                            Guid>(Model.GameType, Model.GameServerId),
                                                                                            AuthPolicies.DeleteBanFileMonitor)).Succeeded)
                                                {
                                                    <a class="btn btn-outline-danger" asp-controller="BanFileMonitors"
                                                        asp-action="Delete" asp-route-id="@item.BanFileMonitorId"><i
                                                            class="fa-solid fa-fw fa-trash"></i> Delete</a>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

</div>

@section Scripts {
    <script src="~/js/game-server-details.js" asp-append-version="true"></script>
}