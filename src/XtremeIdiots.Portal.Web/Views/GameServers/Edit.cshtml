@using XtremeIdiots.Portal.Web.ViewModels
@model GameServerEditViewModel

@{
    ViewData["Title"] = "Edit Game Server";
}

<div class="wrapper wrapper-content animated fadeInRight">

    <form asp-action="Edit" method="post">

        <input type="hidden" asp-for="GameServer.GameServerId" />

        <div class="row">
            <div class="col-12">

                <div class="container-fluid">

                    <ul class="nav nav-tabs" id="serverConfigTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="general-tab-btn" data-bs-toggle="tab"
                                data-bs-target="#general-tab" type="button" role="tab"
                                aria-controls="general-tab" aria-selected="true">General</button>
                        </li>
                        @if (Model.CanEditFtp)
                        {
                            <li class="nav-item @(Model.GameServer.FtpEnabled ? "" : "d-none")" role="presentation"
                                id="ftp-tab-item">
                                <button class="nav-link" id="ftp-tab-btn" data-bs-toggle="tab"
                                    data-bs-target="#ftp-tab" type="button" role="tab"
                                    aria-controls="ftp-tab" aria-selected="false">FTP</button>
                            </li>
                        }
                        @if (Model.CanEditRcon)
                        {
                            <li class="nav-item @(Model.GameServer.RconEnabled ? "" : "d-none")" role="presentation"
                                id="rcon-tab-item">
                                <button class="nav-link" id="rcon-tab-btn" data-bs-toggle="tab"
                                    data-bs-target="#rcon-tab" type="button" role="tab"
                                    aria-controls="rcon-tab" aria-selected="false">RCON</button>
                            </li>
                        }
                        <li class="nav-item @(Model.GameServer.AgentEnabled ? "" : "d-none")" role="presentation"
                            id="agent-tab-item">
                            <button class="nav-link" id="agent-tab-btn" data-bs-toggle="tab"
                                data-bs-target="#agent-tab" type="button" role="tab"
                                aria-controls="agent-tab" aria-selected="false">Agent</button>
                        </li>
                        @if (Model.GameServer.AgentEnabled)
                        {
                            <li class="nav-item" role="presentation" id="moderation-tab-item">
                                <button class="nav-link" id="moderation-tab-btn" data-bs-toggle="tab"
                                    data-bs-target="#moderation-tab" type="button" role="tab"
                                    aria-controls="moderation-tab" aria-selected="false">Moderation</button>
                            </li>
                            <li class="nav-item" role="presentation" id="events-tab-item">
                                <button class="nav-link" id="events-tab-btn" data-bs-toggle="tab"
                                    data-bs-target="#events-tab" type="button" role="tab"
                                    aria-controls="events-tab" aria-selected="false">Event Processing</button>
                            </li>
                        }
                        <li class="nav-item @(Model.GameServer.BanFileSyncEnabled ? "" : "d-none")" role="presentation"
                            id="banfilesync-tab-item">
                            <button class="nav-link" id="banfilesync-tab-btn" data-bs-toggle="tab"
                                data-bs-target="#banfilesync-tab" type="button" role="tab"
                                aria-controls="banfilesync-tab" aria-selected="false">Ban File Sync</button>
                        </li>
                        <li class="nav-item @(Model.GameServer.ServerListEnabled ? "" : "d-none")" role="presentation"
                            id="serverlist-tab-item">
                            <button class="nav-link" id="serverlist-tab-btn" data-bs-toggle="tab"
                                data-bs-target="#serverlist-tab" type="button" role="tab"
                                aria-controls="serverlist-tab" aria-selected="false">Server List</button>
                        </li>
                    </ul>

                    <div class="tab-content" id="serverConfigTabContent">

                        <div class="tab-pane fade show active" id="general-tab" role="tabpanel"
                            aria-labelledby="general-tab-btn">
                            @await Html.PartialAsync("ConfigurationSections/_GeneralConfiguration", Model)
                        </div>

                        @if (Model.CanEditFtp)
                        {
                            <div class="tab-pane fade" id="ftp-tab" role="tabpanel"
                                aria-labelledby="ftp-tab-btn">
                                @await Html.PartialAsync("ConfigurationSections/_FtpConfiguration", Model)
                            </div>
                        }

                        @if (Model.CanEditRcon)
                        {
                            <div class="tab-pane fade" id="rcon-tab" role="tabpanel"
                                aria-labelledby="rcon-tab-btn">
                                @await Html.PartialAsync("ConfigurationSections/_RconConfiguration", Model)
                            </div>
                        }

                        <div class="tab-pane fade" id="agent-tab" role="tabpanel"
                            aria-labelledby="agent-tab-btn">
                            @await Html.PartialAsync("ConfigurationSections/_AgentConfiguration", Model)
                        </div>

                        @if (Model.GameServer.AgentEnabled)
                        {
                            <div class="tab-pane fade" id="moderation-tab" role="tabpanel"
                                aria-labelledby="moderation-tab-btn">
                                @await Html.PartialAsync("ConfigurationSections/_ModerationConfiguration", Model)
                            </div>

                            <div class="tab-pane fade" id="events-tab" role="tabpanel"
                                aria-labelledby="events-tab-btn">
                                @await Html.PartialAsync("ConfigurationSections/_EventsConfiguration", Model)
                            </div>
                        }

                        <div class="tab-pane fade" id="banfilesync-tab" role="tabpanel"
                            aria-labelledby="banfilesync-tab-btn">
                            @await Html.PartialAsync("ConfigurationSections/_BanFileSyncConfiguration", Model)
                        </div>

                        <div class="tab-pane fade" id="serverlist-tab" role="tabpanel"
                            aria-labelledby="serverlist-tab-btn">
                            @await Html.PartialAsync("ConfigurationSections/_ServerListConfiguration", Model)
                        </div>

                    </div>

                    <div class="ibox mt-3">
                        <div class="ibox-content">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        </div>
                        <div class="ibox-footer ibox-footer--sticky">
                            <a class="btn btn-outline-secondary" asp-action="Index">
                                <i class="fa-solid fa-fw fa-arrow-left"></i> Back to List
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fa-solid fa-fw fa-floppy-disk" aria-hidden="true"></i> Save
                            </button>
                        </div>
                    </div>

                </div>

            </div>
        </div>

    </form>

</div>

@await Html.PartialAsync("_FtpBrowserModal")

@* ReSharper disable once Razor.SectionNotResolved *@

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/js/ftp-browser.js" asp-append-version="true"></script>
    <script>
        // Password show/hide toggle
        function togglePasswordVisibility(inputId, button) {
            var input = document.getElementById(inputId);
            if (!input) return;
            var icon = button.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        }

        // Toggle tab visibility when feature checkboxes change
        document.querySelectorAll('.feature-toggle[data-toggle-tab]').forEach(function (checkbox) {
            checkbox.addEventListener('change', function () {
                var tabBtnId = this.getAttribute('data-toggle-tab');
                var tabBtn = document.getElementById(tabBtnId);
                var tabItem = tabBtn?.closest('.nav-item');
                if (tabItem) {
                    if (!this.checked && tabBtn.classList.contains('active')) {
                        var generalTab = document.getElementById('general-tab-btn');
                        var bsTab = new bootstrap.Tab(generalTab);
                        bsTab.show();
                    }
                    tabItem.classList.toggle('d-none', !this.checked);
                }
            });
        });

        // Rotate chevron icon on legacy settings collapse
        var legacyToggle = document.querySelector('[data-bs-target="#legacyTogglesBody"]');
        if (legacyToggle) {
            legacyToggle.addEventListener('click', function () {
                var icon = this.querySelector('.collapse-icon');
                if (icon) {
                    icon.classList.toggle('fa-chevron-right');
                    icon.classList.toggle('fa-chevron-down');
                }
            });
        }

        // Toggle dependency enforcement
        // AgentEnabled requires FtpEnabled AND RconEnabled
        // BanFileSyncEnabled requires FtpEnabled AND AgentEnabled
        function enforceToggleDependencies() {
            var ftp = document.getElementById('GameServer_FtpEnabled');
            var rcon = document.getElementById('GameServer_RconEnabled');
            var agent = document.getElementById('GameServer_AgentEnabled');
            var banSync = document.getElementById('GameServer_BanFileSyncEnabled');

            if (!ftp || !rcon || !agent || !banSync) return;

            // If Agent is checked but prerequisites aren't met, uncheck it
            if (agent.checked && (!ftp.checked || !rcon.checked)) {
                agent.checked = false;
                agent.dispatchEvent(new Event('change'));
            }

            // If BanFileSync is checked but prerequisites aren't met, uncheck it
            if (banSync.checked && (!ftp.checked || !agent.checked)) {
                banSync.checked = false;
                banSync.dispatchEvent(new Event('change'));
            }

            // Visual state for Agent
            var agentSwitch = agent.closest('.form-check');
            if (agentSwitch) {
                agentSwitch.classList.toggle('opacity-50', !ftp.checked || !rcon.checked);
            }

            // Visual state for BanFileSync
            var banSyncSwitch = banSync.closest('.form-check');
            if (banSyncSwitch) {
                banSyncSwitch.classList.toggle('opacity-50', !ftp.checked || !agent.checked);
            }
        }

        enforceToggleDependencies();

        ['GameServer_FtpEnabled', 'GameServer_RconEnabled', 'GameServer_AgentEnabled'].forEach(function (id) {
            var el = document.getElementById(id);
            if (el) el.addEventListener('change', enforceToggleDependencies);
        });
    </script>
}