@using XtremeIdiots.Portal.Web.ViewModels
@model GameServerEditViewModel

@{
    ViewData["Title"] = "Edit Game Server";
}

<div class="wrapper wrapper-content animated fadeInRight">

    <form asp-action="Edit" method="post" id="game-server-edit-form">

        <input type="hidden" asp-for="GameServer.GameServerId" />

        <div class="row">
            <div class="col-12">

                <div class="container-fluid">

                    <ul class="nav nav-tabs" id="serverConfigTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="general-tab-btn" data-bs-toggle="tab"
                                    data-bs-target="#general-tab" type="button" role="tab" aria-controls="general-tab"
                                    aria-selected="true">General</button>
                        </li>
                        @if (Model.CanEditFileTransport)
                        {
                            <li class="nav-item @(Model.GameServer.FileTransportEnabled ? "" : "d-none")"
                                role="presentation" id="filetransfer-tab-item">
                                <button class="nav-link" id="filetransfer-tab-btn" data-bs-toggle="tab"
                                        data-bs-target="#filetransfer-tab" type="button" role="tab"
                                        aria-controls="filetransfer-tab" aria-selected="false">File Transfer</button>
                            </li>
                        }
                        @if (Model.CanEditRcon)
                        {
                            <li class="nav-item @(Model.GameServer.RconEnabled ? "" : "d-none")" role="presentation"
                                id="rcon-tab-item">
                                <button class="nav-link" id="rcon-tab-btn" data-bs-toggle="tab" data-bs-target="#rcon-tab"
                                        type="button" role="tab" aria-controls="rcon-tab" aria-selected="false">RCON</button>
                            </li>
                        }
                        <li class="nav-item @(Model.GameServer.AgentEnabled ? "" : "d-none")" role="presentation"
                            id="agent-tab-item">
                            <button class="nav-link" id="agent-tab-btn" data-bs-toggle="tab" data-bs-target="#agent-tab"
                                    type="button" role="tab" aria-controls="agent-tab" aria-selected="false">Agent</button>
                        </li>
                        @if (Model.CanConfigureScreenshots)
                        {
                            <li class="nav-item @(Model.GameServer.AgentEnabled ? "" : "d-none")" role="presentation"
                                id="screenshots-config-tab-item">
                                <button class="nav-link" id="screenshots-config-tab-btn" data-bs-toggle="tab"
                                        data-bs-target="#screenshots-config-tab" type="button" role="tab"
                                        aria-controls="screenshots-config-tab" aria-selected="false">Screenshots</button>
                            </li>
                        }
                        @if (Model.GameServer.AgentEnabled)
                        {
                            <li class="nav-item" role="presentation" id="broadcasts-tab-item">
                                <button class="nav-link" id="broadcasts-tab-btn" data-bs-toggle="tab"
                                        data-bs-target="#broadcasts-tab" type="button" role="tab" aria-controls="broadcasts-tab"
                                        aria-selected="false">Broadcasts</button>
                            </li>
                            <li class="nav-item" role="presentation" id="chat-commands-tab-item">
                                <button class="nav-link" id="chat-commands-tab-btn" data-bs-toggle="tab"
                                        data-bs-target="#chat-commands-tab" type="button" role="tab"
                                        aria-controls="chat-commands-tab" aria-selected="false">Chat Commands</button>
                            </li>
                            <li class="nav-item" role="presentation" id="welcome-messages-tab-item">
                                <button class="nav-link" id="welcome-messages-tab-btn" data-bs-toggle="tab"
                                        data-bs-target="#welcome-messages-tab" type="button" role="tab"
                                        aria-controls="welcome-messages-tab" aria-selected="false">Welcome Messages</button>
                            </li>
                            <li class="nav-item" role="presentation" id="moderation-tab-item">
                                <button class="nav-link" id="moderation-tab-btn" data-bs-toggle="tab"
                                        data-bs-target="#moderation-tab" type="button" role="tab" aria-controls="moderation-tab"
                                        aria-selected="false">Chat Moderation</button>
                            </li>
                            <li class="nav-item" role="presentation" id="events-tab-item">
                                <button class="nav-link" id="events-tab-btn" data-bs-toggle="tab"
                                        data-bs-target="#events-tab" type="button" role="tab" aria-controls="events-tab"
                                        aria-selected="false">Event Processing</button>
                            </li>
                        }
                        <li class="nav-item @(Model.GameServer.BanFileSyncEnabled ? "" : "d-none")" role="presentation"
                            id="banfilesync-tab-item">
                            <button class="nav-link" id="banfilesync-tab-btn" data-bs-toggle="tab"
                                    data-bs-target="#banfilesync-tab" type="button" role="tab"
                                    aria-controls="banfilesync-tab" aria-selected="false">Ban File Sync</button>
                        </li>
                        <li class="nav-item @(Model.GameServer.ServerListEnabled ? "" : "d-none")" role="presentation"
                            id="serverlist-tab-item">
                            <button class="nav-link" id="serverlist-tab-btn" data-bs-toggle="tab"
                                    data-bs-target="#serverlist-tab" type="button" role="tab" aria-controls="serverlist-tab"
                                    aria-selected="false">Server List</button>
                        </li>
                    </ul>

                    <div class="tab-content" id="serverConfigTabContent">

                        <div class="tab-pane fade show active" id="general-tab" role="tabpanel"
                             aria-labelledby="general-tab-btn">
                            @await Html.PartialAsync("ConfigurationSections/_GeneralConfiguration", Model)
                        </div>

                        @if (Model.CanEditFileTransport)
                        {
                            <div class="tab-pane fade" id="filetransfer-tab" role="tabpanel"
                                 aria-labelledby="filetransfer-tab-btn">
                                @await Html.PartialAsync("ConfigurationSections/_FtpConfiguration", Model)
                            </div>
                        }

                        @if (Model.CanEditRcon)
                        {
                            <div class="tab-pane fade" id="rcon-tab" role="tabpanel" aria-labelledby="rcon-tab-btn">
                                @await Html.PartialAsync("ConfigurationSections/_RconConfiguration", Model)
                            </div>
                        }

                        <div class="tab-pane fade" id="agent-tab" role="tabpanel" aria-labelledby="agent-tab-btn">
                            @await Html.PartialAsync("ConfigurationSections/_AgentConfiguration", Model)
                        </div>

                        @if (Model.CanConfigureScreenshots)
                        {
                            <div class="tab-pane fade" id="screenshots-config-tab" role="tabpanel"
                                 aria-labelledby="screenshots-config-tab-btn">
                                @await Html.PartialAsync("ConfigurationSections/_ScreenshotsConfiguration", Model)
                            </div>
                        }

                        @if (Model.GameServer.AgentEnabled)
                        {
                            <div class="tab-pane fade" id="broadcasts-tab" role="tabpanel"
                                 aria-labelledby="broadcasts-tab-btn">
                                @await Html.PartialAsync("ConfigurationSections/_BroadcastsConfiguration", Model)
                            </div>

                            <div class="tab-pane fade" id="chat-commands-tab" role="tabpanel"
                                 aria-labelledby="chat-commands-tab-btn">
                                @await Html.PartialAsync("ConfigurationSections/_ChatCommandsConfiguration", Model)
                            </div>

                            <div class="tab-pane fade" id="welcome-messages-tab" role="tabpanel"
                                 aria-labelledby="welcome-messages-tab-btn">
                                @await Html.PartialAsync("ConfigurationSections/_WelcomeMessagesConfiguration", Model)
                            </div>

                            <div class="tab-pane fade" id="moderation-tab" role="tabpanel"
                                 aria-labelledby="moderation-tab-btn">
                                @await Html.PartialAsync("ConfigurationSections/_ModerationConfiguration", Model)
                            </div>

                            <div class="tab-pane fade" id="events-tab" role="tabpanel" aria-labelledby="events-tab-btn">
                                @await Html.PartialAsync("ConfigurationSections/_EventsConfiguration", Model)
                            </div>
                        }

                        <div class="tab-pane fade" id="banfilesync-tab" role="tabpanel"
                             aria-labelledby="banfilesync-tab-btn">
                            @await Html.PartialAsync("ConfigurationSections/_BanFileSyncConfiguration", Model)
                        </div>

                        <div class="tab-pane fade" id="serverlist-tab" role="tabpanel"
                             aria-labelledby="serverlist-tab-btn">
                            @await Html.PartialAsync("ConfigurationSections/_ServerListConfiguration", Model)
                        </div>

                    </div>

                    <div class="ibox mt-3">
                        <div class="ibox-content">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        </div>
                        <div class="ibox-footer ibox-footer--sticky">
                            <a class="btn btn-outline-secondary" asp-action="Index">
                                <i class="fa-solid fa-fw fa-arrow-left" aria-hidden="true"></i> Back to List
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fa-solid fa-fw fa-floppy-disk" aria-hidden="true"></i> Save
                            </button>
                        </div>
                    </div>

                </div>

            </div>
        </div>

    </form>

</div>

@await Html.PartialAsync("_FileBrowserModal")

@* ReSharper disable once Razor.SectionNotResolved *@

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/js/file-browse.js" asp-append-version="true"></script>
    <script src="~/js/welcome-rules-manager.js" asp-append-version="true"></script>
    <script src="~/js/settings-row-manager.js" asp-append-version="true"></script>
    <script>
        // Password show/hide toggle
        function togglePasswordVisibility(inputId, button) {
        var input = document.getElementById(inputId);
        if (!input) return;
        var icon = button.querySelector('i');
        if (input.type === 'password') {
        input.type = 'text';
        icon.classList.replace('fa-eye', 'fa-eye-slash');
        } else {
        input.type = 'password';
        icon.classList.replace('fa-eye-slash', 'fa-eye');
        }
        }

        // Toggle tab visibility when feature checkboxes change
        document.querySelectorAll('.feature-toggle[data-toggle-tab]').forEach(function (checkbox) {
        checkbox.addEventListener('change', function () {
        var tabBtnId = this.getAttribute('data-toggle-tab');
        var tabBtn = document.getElementById(tabBtnId);
        var tabItem = tabBtn?.closest('.nav-item');
        if (tabItem) {
        if (!this.checked && tabBtn.classList.contains('active')) {
        var generalTab = document.getElementById('general-tab-btn');
        var bsTab = new bootstrap.Tab(generalTab);
        bsTab.show();
        }
        tabItem.classList.toggle('d-none', !this.checked);
        }
        });
        });

        // Toggle dependency enforcement
        // AgentEnabled requires FileTransportEnabled AND RconEnabled
        // BanFileSyncEnabled requires FileTransportEnabled AND AgentEnabled
        function getFileTransportMeta(value) {
        var normalized = (value || '').toLowerCase();
        if (normalized === 'sftp' || normalized === '2') {
        return { label: 'SFTP', defaultPort: 22 };
        }

        return { label: 'FTP', defaultPort: 21 };
        }

        function updateFileTransportUi() {
        var typeSelect = document.getElementById('GameServer_FileTransportType');
        if (!typeSelect) return;

        var fileTransferTab = document.getElementById('filetransfer-tab');
        var portInput = document.getElementById('FtpConfigPort');
        var sftpHostKeyGroup = document.getElementById('sftp-host-key-fingerprint-group');
        var defaultPortValue = document.getElementById('file-transport-default-port');
        var transportLabelNodes = document.querySelectorAll('.js-file-transport-label');

        var previousValue = typeSelect.getAttribute('data-prev-value') || typeSelect.value;
        var previousMeta = getFileTransportMeta(previousValue);
        var currentMeta = getFileTransportMeta(typeSelect.value);

        transportLabelNodes.forEach(function (node) {
        node.textContent = currentMeta.label;
        });

        if (defaultPortValue) {
        defaultPortValue.textContent = currentMeta.defaultPort;
        }

        if (fileTransferTab) {
        var title = fileTransferTab.querySelector('.ibox-title');
        if (title) {
        title.textContent = 'File Transfer Configuration';
        }
        }

        if (sftpHostKeyGroup) {
        sftpHostKeyGroup.classList.toggle('d-none', currentMeta.label !== 'SFTP');
        }

        if (portInput) {
        var rawPort = (portInput.value || '').trim();
        var parsedPort = Number.parseInt(rawPort, 10);
        var shouldUpdateToDefault =
        rawPort.length === 0 ||
        Number.isNaN(parsedPort) ||
        parsedPort === previousMeta.defaultPort;

        if (shouldUpdateToDefault) {
        portInput.value = currentMeta.defaultPort;
        }
        }

        typeSelect.setAttribute('data-prev-value', typeSelect.value);
        }

        function enforceToggleDependencies() {
        var ftp = document.getElementById('GameServer_FileTransportEnabled');
        var rcon = document.getElementById('GameServer_RconEnabled');
        var agent = document.getElementById('GameServer_AgentEnabled');
        var banSync = document.getElementById('GameServer_BanFileSyncEnabled');

        if (!ftp || !rcon || !agent || !banSync) return;

        var isFileTransportEnabled = ftp.type === 'checkbox'
        ? ftp.checked
        : (ftp.value || '').toLowerCase() === 'true';

        var agentBlocked = !isFileTransportEnabled || !rcon.checked;
        var banSyncBlocked = !isFileTransportEnabled || !agent.checked;

        // Disable-only dependency behavior: keep authored checked values and only
        // block turning a currently unchecked dependency back on.
        agent.disabled = agentBlocked && !agent.checked;
        banSync.disabled = banSyncBlocked && !banSync.checked;

        // Visual state for Agent
        var agentSwitch = agent.closest('.form-check');
        if (agentSwitch) {
        agentSwitch.classList.toggle('opacity-50', agentBlocked);
        }

        // Visual state for BanFileSync
        var banSyncSwitch = banSync.closest('.form-check');
        if (banSyncSwitch) {
        banSyncSwitch.classList.toggle('opacity-50', banSyncBlocked);
        }

        var agentControlledTabIds = ['agent-tab-item', 'broadcasts-tab-item', 'chat-commands-tab-item', 'moderation-tab-item', 'events-tab-item', 'screenshots-config-tab-item'];
        agentControlledTabIds.forEach(function (tabId) {
        var tabItem = document.getElementById(tabId);
        if (!tabItem) return;

        var activeTabButton = tabItem.querySelector('.nav-link');
        if (!agent.checked && activeTabButton && activeTabButton.classList.contains('active')) {
        var generalTab = document.getElementById('general-tab-btn');
        if (generalTab) {
        var bsTab = new bootstrap.Tab(generalTab);
        bsTab.show();
        }
        }

        tabItem.classList.toggle('d-none', !agent.checked);
        });
        }

        enforceToggleDependencies();
        updateFileTransportUi();

        var fileTransportTypeSelect = document.getElementById('GameServer_FileTransportType');
        if (fileTransportTypeSelect) {
        fileTransportTypeSelect.addEventListener('change', updateFileTransportUi);
        }

        ['GameServer_FileTransportEnabled', 'GameServer_RconEnabled', 'GameServer_AgentEnabled'].forEach(function (id) {
        var el = document.getElementById(id);
        if (el) el.addEventListener('change', enforceToggleDependencies);
        });

        function isCodGameType() {
        var gameType = document.getElementById('GameServer_GameType')?.value || '';
        return gameType.startsWith('CallOfDuty');
        }

        function getEffectiveAgentNamePrefix() {
        var input = document.getElementById('AgentConfigName');
        if (!input) return '';

        var overrideValue = (input.value || '').trim();
        if (overrideValue.length > 0) return overrideValue;

        return input.getAttribute('data-global-agent-name') || '';
        }

        var serverSettingsEditors = [];
        var serverAgentNameInput = document.getElementById('AgentConfigName');

        var broadcastEditor = XISettingsRowManager.initializeMessageList({
        containerId: 'broadcast-messages-container',
        templateId: 'broadcast-message-template',
        addButtonId: 'add-broadcast-message',
        emptyStateId: 'broadcast-messages-empty',
        fieldNamePrefix: 'BroadcastMessages',
        normalizeIdPrefix: false,
        agentNameInput: serverAgentNameInput,
        agentNameProvider: getEffectiveAgentNamePrefix,
        replaceNameToken: false,
        codPreviewMode: 'conditional',
        isCodGameType: isCodGameType
        });

        if (broadcastEditor) {
        serverSettingsEditors.push(broadcastEditor);
        }

        document.querySelectorAll('[data-chat-command-messages-container]').forEach(function (container) {
        var editor = XISettingsRowManager.initializeMessageList({
        container: container,
        templateId: container.dataset.templateId,
        addButtonId: container.dataset.addButtonId,
        emptyStateId: container.dataset.emptyStateId,
        fieldNamePrefix: container.dataset.fieldNamePrefix,
        normalizeIdPrefix: false,
        agentNameInput: serverAgentNameInput,
        agentNameProvider: getEffectiveAgentNamePrefix,
        replaceNameToken: false,
        codPreviewMode: 'conditional',
        isCodGameType: isCodGameType
        });

        if (editor) {
        serverSettingsEditors.push(editor);
        }
        });

        XIWelcomeRulesManager.initializeEditor('server-welcome-local-rules-container', 'add-server-welcome-local-rule');
        XIWelcomeRulesManager.initializeEditor('server-welcome-rule-overrides-container', 'add-server-welcome-rule-override');

        document.querySelectorAll('[data-chat-command-card]').forEach(function (card) {
        function updateOverrideVisibility() {
        card.querySelectorAll('[data-global-toggle]').forEach(function (toggle) {
        var targetId = toggle.getAttribute('data-global-target');
        if (!targetId) return;

        var target = document.getElementById(targetId);
        if (!target) return;

        var mode = toggle.getAttribute('data-global-mode');
        var hideWhenChecked = mode !== 'override';
        target.classList.toggle('d-none', hideWhenChecked ? toggle.checked : !toggle.checked);
        });
        }

        card.querySelectorAll('[data-global-toggle]').forEach(function (toggle) {
        toggle.addEventListener('change', updateOverrideVisibility);
        });

        updateOverrideVisibility();
        });

        var editForm = document.getElementById('game-server-edit-form');
        if (editForm) {
        editForm.addEventListener('submit', function () {
        serverSettingsEditors.forEach(function (editor) {
        editor.reindex();
        editor.syncBooleanPosts();
        });

        // Ensure each global-toggle boolean posts a single value.
        document.querySelectorAll('[data-global-toggle]').forEach(function (toggle) {
        var scope = toggle.closest('.border') || editForm;
        var hidden = Array.from(scope.querySelectorAll('input[type="hidden"]')).find(function (input) {
        return input.name === toggle.name;
        });
        if (!hidden) return;

        hidden.disabled = toggle.checked;
        });
        });
        }
    </script>
}