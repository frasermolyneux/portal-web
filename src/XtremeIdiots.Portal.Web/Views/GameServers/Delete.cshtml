@using XtremeIdiots.Portal.Web.Extensions
@using XtremeIdiots.Portal.Web.ViewModels
@model GameServerViewModel

@{
    ViewData["Title"] = "Delete Game Server";
}

<div class="wrapper wrapper-content animated fadeInRight">

    <div class="row">
        <div class="col-12">

            <div class="container-fluid">
                <div class="ibox">
                    <div class="ibox-title">
                        <h5>@ViewData["Title"]</h5>
                    </div>
                    <div class="ibox-content">
                        <p>Are you sure you want to delete this game server?</p>
                        <div class="alert alert-warning mb-3">
                            <i class="fa-solid fa-fw fa-triangle-exclamation" aria-hidden="true"></i>
                            This action cannot be undone. This will permanently delete the server and all associated configurations, ban file monitors, and server event history.
                        </div>
                        <dl class="detail-fields row">
                            <div class="detail-field col-sm-6">
                                <dt class="detail-label">@Html.DisplayNameFor(model => model.Title)</dt>
                                <dd class="detail-value">
                                    <server-name title="@Model.Title"></server-name>
                                </dd>
                            </div>
                            <div class="detail-field col-sm-6">
                                <dt class="detail-label">@Html.DisplayNameFor(model => model.GameType)</dt>
                                <dd class="detail-value">@Html.DisplayFor(model => model.GameType)</dd>
                            </div>
                            <div class="detail-field col-sm-6">
                                <dt class="detail-label">@Html.DisplayNameFor(model => model.Hostname)</dt>
                                <dd class="detail-value">
                                    <server-host host="@Model.Hostname" port="@Model.QueryPort"></server-host>
                                </dd>
                            </div>
                        </dl>
                    </div>
                    <div class="ibox-footer">
                        <form asp-action="Delete">
                            <input type="hidden" asp-for="GameServerId" />
                            <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
                            <button class="btn btn-danger" type="submit">
                                <i class="fa-solid fa-fw fa-trash"></i> Delete Game Server
                            </button>
                        </form>
                    </div>
                </div>
            </div>

        </div>
    </div>

</div>