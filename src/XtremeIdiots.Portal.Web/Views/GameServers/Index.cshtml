@inject IAuthorizationService AuthorizationService
@using Microsoft.AspNetCore.Authorization
@using XtremeIdiots.Portal.Web.Auth.Constants
@using XtremeIdiots.Portal.Web.Extensions
@using XtremeIdiots.Portal.Repository.Abstractions.Constants.V1
@using XtremeIdiots.Portal.Repository.Abstractions.Models.V1.GameServers
@model IEnumerable<GameServerDto>

@{
    ViewData["Title"] = "Game Servers";
}

<div class="wrapper wrapper-content animated fadeInRight">

    <div class="row">
        <div class="col-12">

            <div class="container-fluid">
                <div class="list-filters mb-2" id="gameServersFilters">
                    <div class="filter-group">
                        <label class="form-label" for="resetFilters">Reset</label>
                        <button type="button" id="resetFilters" class="btn btn-outline-secondary btn-sm">Reset Filters</button>
                    </div>
                </div>
                <div class="ibox">
                    <div class="ibox-content">
                        <div class="table-responsive">
                            <table id="gameServersTable" class="table table-striped table-hover w-100">
                                <thead>
                                    <tr>
                                        <th scope="col">
                                            @Html.DisplayNameFor(model => model.GameType)
                                        </th>
                                        <th scope="col">
                                            @Html.DisplayNameFor(model => model.Title)
                                        </th>
                                        <th scope="col">
                                            @Html.DisplayNameFor(model => model.Hostname)
                                        </th>
                                    <th scope="col">
                                        @Html.DisplayNameFor(model => model.FtpEnabled)
                                    </th>
                                    <th scope="col">
                                        @Html.DisplayNameFor(model => model.RconEnabled)
                                    </th>
                                    <th scope="col">
                                        @Html.DisplayNameFor(model => model.AgentEnabled)
                                    </th>
                                    <th scope="col">
                                        @Html.DisplayNameFor(model => model.BanFileSyncEnabled)
                                    </th>
                                    <th scope="col">
                                        @Html.DisplayNameFor(model => model.ServerListEnabled)
                                    </th>
                                    <th class="table-action-col"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            <game-type-icon game="@item.GameType"></game-type-icon>
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.Title)
                                        </td>
                                        <td>
                                            <server-host host="@item.Hostname" port="@item.QueryPort"></server-host>
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.FtpEnabled)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.RconEnabled)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.AgentEnabled)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.BanFileSyncEnabled)
                                        </td>
                                        <td>
                                            @Html.DisplayFor(modelItem => item.ServerListEnabled)
                                        </td>
                                        <td>
                                            <div class="btn-group btn-group-sm" role="group">
                                                @if ((await AuthorizationService.AuthorizeAsync(User, item.GameType,
                                                                                            AuthPolicies.GameServers_Write)).Succeeded)
                                                {
                                                    <a class="btn btn-outline-secondary btn-sm" asp-action="Edit"
                                                        asp-route-id="@item.GameServerId" title="Edit" aria-label="Edit"><i class="fa-solid fa-fw fa-pen-to-square" aria-hidden="true"></i></a>
                                                }

                                                @if ((await AuthorizationService.AuthorizeAsync(User, item.GameType,
                                                                                            AuthPolicies.GameServers_Read)).Succeeded)
                                                {
                                                    <a class="btn btn-outline-secondary btn-sm" asp-action="Details"
                                                        asp-route-id="@item.GameServerId" title="Details" aria-label="Details"><i class="fa-solid fa-fw fa-eye" aria-hidden="true"></i></a>
                                                }

                                                @if ((await AuthorizationService.AuthorizeAsync(User,
                                                                                            AuthPolicies.GameServers_Delete)).Succeeded)
                                                {
                                                    <a class="btn btn-outline-danger btn-sm" asp-action="Delete"
                                                        asp-route-id="@item.GameServerId" title="Delete" aria-label="Delete"><i class="fa-solid fa-fw fa-trash" aria-hidden="true"></i></a>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        </div>
                    </div>
                    <div class="ibox-footer">
                        <div class="btn-group btn-group-sm" role="group">
                            <a policy="@AuthPolicies.GameServers_Write" policy-resource="@PotentialAccessProbe.Instance" class="btn btn-primary" asp-action="Create">
                                <i class="fa-solid fa-fw fa-plus"></i> Create New
                            </a>
                            @if ((await AuthorizationService.AuthorizeAsync(User, AuthPolicies.GameServers_Delete)).Succeeded)
                            {
                                <a class="btn btn-secondary" asp-action="Reorder"><i class="fa-solid fa-fw fa-grip-vertical"></i>
                                    Reorder Servers</a>
                            }
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

</div>

@section Scripts {
    <script src="~/js/game-servers-index.js" asp-append-version="true"></script>
}

