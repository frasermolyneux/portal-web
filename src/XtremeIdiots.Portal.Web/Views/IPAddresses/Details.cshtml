@using XtremeIdiots.Portal.Web.Extensions
@using XtremeIdiots.Portal.Repository.Abstractions.Constants.V1
@using MX.GeoLocation.Abstractions.Models.V1_1
@using System.Linq
@inject IConfiguration Configuration
@model XtremeIdiots.Portal.Web.ViewModels.IPAddressDetailsViewModel

@{
    ViewData["Title"] = "IP Address Details: " + Model.IpAddress;
    var hasGeo = Model.Intelligence != null && Model.Intelligence.MaxMindStatus == SourceStatus.Success;
    var hasProxyCheck = Model.Intelligence?.ProxyCheck != null && Model.Intelligence.ProxyCheckStatus == SourceStatus.Success;
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="row">
        <!-- IP Address Summary Card -->
        <div class="col-lg-4">
            <div class="ibox">
                <div class="ibox-title">
                    <h5>IP Address Summary</h5>
                </div>
                <div class="ibox-content">
                    <div class="text-center m-b-md">
                        <h2><ip-address ip="@Model.IpAddress" country-code="@Model.Intelligence?.CountryCode" risk="@Model.Intelligence?.ProxyCheck?.RiskScore" is-proxy="@Model.Intelligence?.ProxyCheck?.IsProxy" is-vpn="@Model.Intelligence?.ProxyCheck?.IsVpn" proxy-type="@Model.Intelligence?.ProxyCheck?.ProxyType" link-to-details="false"></ip-address></h2>
                    </div>
                    <div class="stats-container">
                        <div class="stat-item">
                            <i class="fa-solid fa-fw fa-users fa-2x text-navy"></i>
                            <h3>@Model.TotalPlayersCount</h3>
                            <p>Players used this IP</p>
                        </div>
                        @if (hasGeo)
                        {
                            <div class="stat-item">                <span class="fa-stack fa-2x">
                                    <i class="fa-solid fa-fw fa-circle fa-stack-2x text-navy"></i>
                                    @{
                                        var countryCode = Model.Intelligence?.CountryCode ?? "unknown";
                                        var flagSrc = !string.IsNullOrWhiteSpace(Model.Intelligence?.CountryCode)
                                            ? $"/images/flags/{Model.Intelligence!.CountryCode!.ToLower()}.png"
                                            : "/images/flags/unknown.png";
                                        <img class="fa-stack-1x" style="height:32px;width:auto;top:20%;" src="@flagSrc" />
                                    }
                                </span>
                                <h3>@Model.Intelligence?.CountryName</h3>
                                <p>@(string.IsNullOrEmpty(Model.Intelligence?.CityName) ? "Unknown City" : Model.Intelligence?.CityName)</p>
                            </div>
                        }
                        @if (hasProxyCheck)
                        {
                            <div class="stat-item">
                                <i class="fa-solid fa-fw fa-shield fa-2x @(Model.Intelligence!.ProxyCheck!.RiskScore >= 50 ? "text-danger" : "text-success")"></i>
                                <h3>Risk Score: @Model.Intelligence.ProxyCheck.RiskScore</h3>
                                <p>
                                    @if (Model.Intelligence.ProxyCheck.IsProxy || Model.Intelligence.ProxyCheck.IsVpn)
                                    {
                                        <span class="badge rounded-pill text-bg-danger">@Model.Intelligence.ProxyCheck.ProxyType</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill text-bg-success">Clean</span>
                                    }
                                </p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- GeoLocation Card -->
        <div class="col-lg-4">
            <div class="ibox">
                <div class="ibox-title">
                    <h5>GeoLocation Data</h5>
                </div>
                <div class="ibox-content">
                    @if (hasGeo)
                    {
                        <div class="m-b-md">
                            <div>
                                <h4><flag-image country-code="@Model.Intelligence!.CountryCode"></flag-image> <location-summary intelligence-model="@Model.Intelligence"></location-summary></h4>
                            </div>

                            <table class="table table-bordered">
                                <tbody>
                                    <tr>
                                        <th>Country</th>
                                        <td>@Model.Intelligence.CountryName (@Model.Intelligence.CountryCode)</td>
                                    </tr>
                                    @if (!string.IsNullOrEmpty(Model.Intelligence.CityName))
                                    {
                                        <tr>
                                            <th>City</th>
                                            <td>@Model.Intelligence.CityName</td>
                                        </tr>
                                    }
                                    @if (Model.Intelligence.Latitude.HasValue && Model.Intelligence.Longitude.HasValue
                                        && (Model.Intelligence.Latitude.Value != 0 || Model.Intelligence.Longitude.Value != 0))
                                    {
                                        <tr>
                                            <th>Coordinates</th>
                                            <td>@Model.Intelligence.Latitude, @Model.Intelligence.Longitude</td>
                                        </tr>
                                    }
                                    @if (!string.IsNullOrEmpty(Model.Intelligence.Timezone))
                                    {
                                        <tr>
                                            <th>Time Zone</th>
                                            <td>@Model.Intelligence.Timezone</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>

                            <div id="map" style="height: 250px; width: 100%; margin-top: 15px;"></div>
                            <a href="https://www.geo-location.net/Home/LookupAddress/@Model.IpAddress" target="_blank" class="btn btn-outline btn-primary btn-sm mt-2" data-testid="ipaddress-details-geolocation-link">
                                <i class="fa-solid fa-fw fa-arrow-up-right-from-square" aria-hidden="true"></i>View on geo-location.net
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            <i class="fa-solid fa-fw fa-circle-info"></i> No GeoLocation data available for this IP address.
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Risk Assessment Card -->
        <div class="col-lg-4">
            <div class="ibox">
                <div class="ibox-title">
                    <h5>Risk Assessment</h5>
                </div>
                <div class="ibox-content">
                    @if (hasProxyCheck)
                    {
                        <div class="m-b-md">
                            <div class="text-center m-b-md">
                                <div class="risk-score-gauge">
                                    <h3>Risk Score</h3>
                                    <div class="gauge-container">
                                        <div class="gauge" data-risk-score="@Model.Intelligence!.ProxyCheck!.RiskScore">
                                            <span class="gauge-value">@Model.Intelligence.ProxyCheck.RiskScore</span>
                                        </div>
                                    </div>
                                    <span class="badge rounded-pill @IPAddressExtensions.GetRiskClass(Model.Intelligence.ProxyCheck.RiskScore)">@Model.Intelligence.ProxyCheck.RiskScore</span>
                                </div>
                            </div>

                            <table class="table table-bordered">
                                <tbody>
                                    <tr>
                                        <th>Status</th>
                                        <td>
                                            @if (Model.Intelligence.ProxyCheck.IsProxy)
                                            {
                                                <span class="badge rounded-pill text-bg-danger">Proxy</span>
                                            }
                                            @if (Model.Intelligence.ProxyCheck.IsVpn)
                                            {
                                                <span class="badge rounded-pill text-bg-warning">VPN</span>
                                            }
                                            @if (!Model.Intelligence.ProxyCheck.IsProxy && !Model.Intelligence.ProxyCheck.IsVpn)
                                            {
                                                <span class="badge rounded-pill text-bg-success">Clean</span>
                                            }
                                        </td>
                                    </tr>
                                    @if (!string.IsNullOrEmpty(Model.Intelligence.ProxyCheck.ProxyType))
                                    {
                                        <tr>
                                            <th>Type</th>
                                            <td>@Model.Intelligence.ProxyCheck.ProxyType</td>
                                        </tr>
                                    }
                                    @if (!string.IsNullOrEmpty(Model.Intelligence.ProxyCheck.Country))
                                    {
                                        <tr>
                                            <th>Country</th>
                                            <td>@Model.Intelligence.ProxyCheck.Country</td>
                                        </tr>
                                    }
                                    @if (!string.IsNullOrEmpty(Model.Intelligence.ProxyCheck.Region))
                                    {
                                        <tr>
                                            <th>Region</th>
                                            <td>@Model.Intelligence.ProxyCheck.Region</td>
                                        </tr>
                                    }
                                    @if (!string.IsNullOrEmpty(Model.Intelligence.ProxyCheck.AsNumber))
                                    {
                                        <tr>
                                            <th>AS Number</th>
                                            <td>@Model.Intelligence.ProxyCheck.AsNumber</td>
                                        </tr>
                                    }
                                    @if (!string.IsNullOrEmpty(Model.Intelligence.ProxyCheck.AsOrganization))
                                    {
                                        <tr>
                                            <th>AS Organization</th>
                                            <td>@Model.Intelligence.ProxyCheck.AsOrganization</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            <i class="fa-solid fa-fw fa-circle-info"></i> No risk assessment data available for this IP address.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Players Table Card -->
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox">
                <div class="ibox-title">
                    <h5>Players Using This IP Address</h5>
                </div>
                <div class="ibox-content">
                    @if (Model.Players != null && Model.Players.Any())
                    {
                        <div class="table-responsive">
                            <table id="ipPlayersTable" class="table table-striped table-hover w-100">
                                <thead>
                                    <tr>
                                        <th scope="col">Game</th>
                                        <th scope="col">Username</th>
                                        <th scope="col">GUID</th>
                                        <th scope="col">First Seen</th>
                                        <th scope="col">Last Seen</th>
                                        <th scope="col" data-bs-toggle="tooltip" data-bs-placement="bottom" title="Confidence is determined by the amount of times that the IP Address has been linked to the GUID">
                                            Confidence
                                        </th>
                                        <th scope="col">Tags</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var player in Model.Players)
                                    {
                                        <tr>
                                            <td><game-type-icon game="@player.GameType"></game-type-icon></td>
                                        <td>
                                            <a asp-controller="Players" asp-action="Details" asp-route-id="@player.PlayerId">
                                                <player-name value="@player.Username"></player-name>
                                            </a>
                                        </td>
                                        <td><guid-link guid="@player.Guid" game="@player.GameType.ToString()"></guid-link></td>
                                        <td><time user-time utc="@player.FirstSeen"></time></td>
                                        <td><time user-time utc="@player.LastSeen"></time></td>
                                        <td>
                                            @{
                                                var ipAddress = player.PlayerIpAddresses.FirstOrDefault(p => p.Address == Model.IpAddress);
                                                <confidence-label score="@(ipAddress?.ConfidenceScore ?? 0)" last-used="@(ipAddress?.LastUsed ?? DateTime.UtcNow)"></confidence-label>
                                            }
                                        </td>
                                        <td>
                                            @if (player.Tags != null && player.Tags.Any())
                                            {
                                                foreach (var tag in player.Tags)
                                                {
                                                    @Html.Raw(tag.Tag?.TagHtml)
                                                }
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        </div>

                        @if (Model.TotalPlayersCount > Model.Players.Count())
                        {
                            <div class="alert alert-info">
                                <i class="fa-solid fa-fw fa-circle-info"></i> Showing @Model.Players.Count() of @Model.TotalPlayersCount players.
                            </div>
                        }
                    }
                    else
                    {
                        <div class="alert alert-info">
                            <i class="fa-solid fa-fw fa-circle-info"></i> No players found using this IP address.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    @{
        var mapsApiKey = Configuration["Google:MapsApiKey"];
        var isValidMapsApiKey = !string.IsNullOrEmpty(mapsApiKey) && System.Text.RegularExpressions.Regex.IsMatch(mapsApiKey, @"^[A-Za-z0-9_-]+$", System.Text.RegularExpressions.RegexOptions.None, TimeSpan.FromSeconds(1));
    }
    @if (hasGeo && Model.Intelligence!.Latitude.HasValue && Model.Intelligence.Longitude.HasValue
        && (Model.Intelligence.Latitude.Value != 0 || Model.Intelligence.Longitude.Value != 0) && isValidMapsApiKey)
    {
        <script type="text/javascript">
            function initMap() {
                var myLatLng = {
                    lat: @Model.Intelligence.Latitude,
                    lng: @Model.Intelligence.Longitude
                };

                var map = new google.maps.Map(document.getElementById('map'), {
                    zoom: 4,
                    center: myLatLng
                });

                new google.maps.Marker({
                    position: myLatLng,
                    map: map,
                    title: 'IP Location'
                });
            }
        </script>
        <script async defer src="https://maps.googleapis.com/maps/api/js?key=@mapsApiKey&signed_in=false&callback=initMap"></script>
        <script src="~/js/ip-address-details.js" asp-append-version="true"></script>
    }
}
