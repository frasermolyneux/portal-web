@using XtremeIdiots.Portal.Repository.Abstractions.Models.V1.AdminActions
@model List<AdminActionDto>

@{
    ViewData["Title"] = "My Admin Actions";
}

<div class="wrapper wrapper-content animated fadeInRight">

    @if (!Model.Any())
    {
        <div class="row">
            <div class="col-lg-12">
                <div class="ibox">
                    <div class="ibox-content">
                        <div class="empty-state">
                            <i class="fa-regular fa-folder-open empty-state-icon"></i>
                            <p class="empty-state-message">You have not performed any admin actions</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    @await Component.InvokeAsync("AdminActions", new { adminActions = Model, linkToPlayer = true })

</div>