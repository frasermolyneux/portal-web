@inject IAuthorizationService AuthorizationService
@inject IConfiguration Configuration
@using Microsoft.AspNetCore.Authorization
@using XtremeIdiots.Portal.Web.Auth.Constants
@using XtremeIdiots.Portal.Web.Extensions
@using XtremeIdiots.Portal.Web.Models
@using XtremeIdiots.Portal.Web.ViewModels
@using XtremeIdiots.Portal.Repository.Abstractions.Constants.V1
@using XtremeIdiots.Portal.Repository.Abstractions.Models.V1
@model PlayerDetailsViewModel

@{
    ViewData["Title"] = (Model?.Player?.Username ?? "Unknown Player") + " Player Details";
}

<div class="wrapper wrapper-content animated fadeInRight">

@if (Model?.Player != null)
{
    var player = Model.Player;

    // Detect active ban
    var activeBan = player.AdminActions?.FirstOrDefault(a =>
        (a.Type == AdminActionType.Ban && a.Expires is null) ||
        (a.Type == AdminActionType.TempBan && a.Expires > DateTime.UtcNow));

    // Admin action counts by type
    var adminActions = player.AdminActions ?? new List<XtremeIdiots.Portal.Repository.Abstractions.Models.V1.AdminActions.AdminActionDto>();
    var banCount = adminActions.Count(a => a.Type == AdminActionType.Ban);
    var tempBanCount = adminActions.Count(a => a.Type == AdminActionType.TempBan);
    var kickCount = adminActions.Count(a => a.Type == AdminActionType.Kick);
    var warningCount = adminActions.Count(a => a.Type == AdminActionType.Warning);
    var observationCount = adminActions.Count(a => a.Type == AdminActionType.Observation);

    // Risk level for gauge
    var riskScore = Model.Intelligence?.ProxyCheck?.RiskScore ?? 0;
    var riskLevel = riskScore >= 80 ? "critical" : (riskScore >= 50 ? "high" : (riskScore >= 25 ? "medium" : "low"));

<!-- Player Banner -->
<div class="row">
    <div class="col-12">
        <div class="ibox">
            <div class="ibox-content">
                <div class="row">
                    <div class="col-12">
                        <div class="d-flex flex-column flex-md-row align-items-start align-items-md-center">
                            <div class="me-0 me-md-3 mb-2 mb-md-0 text-center text-md-start">
                                <game-type-icon game="@player.GameType"></game-type-icon>
                            </div>
                            <div class="flex-grow-1">
                                <h2 class="mb-2 text-center text-md-start"><player-name value="@(player.Username ?? "Unknown Player")"></player-name></h2>
                                <div class="text-muted mb-3">
                                    <div class="row">
                                        <div class="col-12 col-lg-6 mb-2 mb-lg-0">
                                            <span class="d-flex align-items-center justify-content-center justify-content-md-start">
                                                <i class="fa-solid fa-fw fa-id-card" aria-hidden="true"></i> Player ID:
                                                <span id="playerId" class="mx-1 font-weight-bold">@player.PlayerId.ToString()</span>
                                                <i class="fa-solid fa-fw fa-copy cursor-pointer" data-copy-target="playerId" title="Copy Player ID" aria-hidden="true"></i>
                                            </span>
                                            <span class="d-flex align-items-center justify-content-center justify-content-md-start">
                                                <i class="fa-solid fa-fw fa-key" aria-hidden="true"></i> GUID:
                                                <span id="playerGuid" class="mx-1 font-weight-bold text-truncate"><guid-link guid="@player.Guid" game="@player.GameType.ToString()"></guid-link></span>
                                                <i class="fa-solid fa-fw fa-copy cursor-pointer" data-copy-target="playerGuid" title="Copy GUID" aria-hidden="true"></i>
                                            </span>
                                            @if (player.Tags != null && player.Tags.Any())
                                            {
                                                <span class="d-flex align-items-center justify-content-center justify-content-md-start">
                                                    <i class="fa-solid fa-fw fa-tag" aria-hidden="true"></i> Tags:
                                                    <span class="mx-1">
                                                        @foreach (var playerTag in player.Tags)
                                                        {
                                                            @Html.Raw(playerTag.Tag?.TagHtml)
                                                        }
                                                    </span>
                                                </span>
                                            }
                                        </div>

                                        <div class="col-12 col-lg-6 mb-2 mb-lg-0">
                                            <div class="btn-toolbar justify-content-center justify-content-md-start" role="toolbar">
                                                <div class="btn-group flex-wrap" role="group">
                                                @if ((await AuthorizationService.AuthorizeAsync(User, new Tuple<GameType, AdminActionType>(player.GameType, AdminActionType.Observation), AuthPolicies.AdminActions_Create)).Succeeded)
                                                {
                                                    <a asp-controller="AdminActions" asp-action="Create" asp-route-id="@player.PlayerId" asp-route-adminActionType="Observation" class="btn btn-outline-primary btn-sm">
                                                        <i class="fa-solid fa-fw fa-eye" aria-hidden="true"></i> Observation
                                                    </a>
                                                }

                                                @if ((await AuthorizationService.AuthorizeAsync(User, new Tuple<GameType, AdminActionType>(player.GameType, AdminActionType.Warning), AuthPolicies.AdminActions_Create)).Succeeded)
                                                {
                                                    <a asp-controller="AdminActions" asp-action="Create" asp-route-id="@player.PlayerId" asp-route-adminActionType="Warning" class="btn btn-outline-warning btn-sm">
                                                        <i class="fa-solid fa-fw fa-triangle-exclamation" aria-hidden="true"></i> Warning
                                                    </a>
                                                }

                                                @if ((await AuthorizationService.AuthorizeAsync(User, new Tuple<GameType, AdminActionType>(player.GameType, AdminActionType.Kick), AuthPolicies.AdminActions_Create)).Succeeded)
                                                {
                                                    <a asp-controller="AdminActions" asp-action="Create" asp-route-id="@player.PlayerId" asp-route-adminActionType="Kick" class="btn btn-outline-info btn-sm">
                                                        <i class="fa-solid fa-fw fa-arrow-right-from-bracket" aria-hidden="true"></i> Kick
                                                    </a>
                                                }

                                                @if ((await AuthorizationService.AuthorizeAsync(User, new Tuple<GameType, AdminActionType>(player.GameType, AdminActionType.TempBan), AuthPolicies.AdminActions_Create)).Succeeded)
                                                {
                                                    <a asp-controller="AdminActions" asp-action="Create" asp-route-id="@player.PlayerId" asp-route-adminActionType="TempBan" class="btn btn-outline-secondary btn-sm">
                                                        <i class="fa-solid fa-fw fa-clock" aria-hidden="true"></i> Temp Ban
                                                    </a>
                                                }

                                                @if ((await AuthorizationService.AuthorizeAsync(User, new Tuple<GameType, AdminActionType>(player.GameType, AdminActionType.Ban), AuthPolicies.AdminActions_Create)).Succeeded)
                                                {
                                                    <a asp-controller="AdminActions" asp-action="Create" asp-route-id="@player.PlayerId" asp-route-adminActionType="Ban" class="btn btn-outline-danger btn-sm">
                                                        <i class="fa-solid fa-fw fa-ban" aria-hidden="true"></i> Ban
                                                    </a>
                                                }

                                                <a policy="@AuthPolicies.Players_ProtectedNames_Write" asp-controller="ProtectedNames" asp-action="Add" asp-route-id="@player.PlayerId" class="btn btn-outline-secondary btn-sm">
                                                    <i class="fa-solid fa-fw fa-shield" aria-hidden="true"></i> Protected Name
                                                </a>
                                                @if ((await AuthorizationService.AuthorizeAsync(User, AuthPolicies.Tags_Write)).Succeeded)
                                                {
                                                    <a asp-controller="PlayerTags" asp-action="Add" asp-route-id="@player.PlayerId" class="btn btn-outline-dark btn-sm">
                                                        <i class="fa-solid fa-fw fa-tag" aria-hidden="true"></i> Tag
                                                    </a>
                                                }
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (activeBan is not null)
{
    <div class="row">
        <div class="col-12">
            <div class="alert alert-danger d-flex align-items-center" role="alert">
                <i class="fa-solid fa-fw fa-ban me-2" aria-hidden="true"></i>
                <div>
                    <strong>Active @(activeBan.Type == AdminActionType.Ban ? "Ban" : "Temp Ban")</strong>
                    @if (!string.IsNullOrWhiteSpace(activeBan.UserProfile?.DisplayName))
                    {
                        <span>by @activeBan.UserProfile.DisplayName</span>
                    }
                    @if (activeBan.Expires.HasValue)
                    {
                        <span>— expires <time user-time utc="@activeBan.Expires.Value"></time></span>
                    }
                    else
                    {
                        <span>— permanent</span>
                    }
                </div>
            </div>
        </div>
    </div>
}

<div class="row">

    <div class="col-12 col-lg-4 mb-4 mb-lg-0">
        <!-- Player Summary -->
        <div class="ibox">
            <div class="ibox-title"><h5>Player Summary</h5></div>
            <div class="ibox-content">
                <dl class="detail-fields row">
                    <div class="detail-field col-sm-12">
                        <dt class="detail-label">Current Alias</dt>
                        <dd class="detail-value"><player-name value="@player.Username"></player-name></dd>
                    </div>
                    @if (Model.Intelligence != null)
                    {
                        <div class="detail-field col-sm-12">
                            <dt class="detail-label">IP Address</dt>
                            <dd class="detail-value">
                                <span class="ip-address-container"
                                      data-ip="@player.IpAddress"
                                      data-risk="@(Model.Intelligence.ProxyCheck?.RiskScore ?? 0)"
                                      data-is-proxy="@((Model.Intelligence.ProxyCheck?.IsProxy ?? false).ToString().ToLower())"
                                      data-is-vpn="@((Model.Intelligence.ProxyCheck?.IsVpn ?? false).ToString().ToLower())"
                                      data-type="@(Model.Intelligence.ProxyCheck?.ProxyType ?? "")"
                                      data-country-code="@(Model.Intelligence.CountryCode ?? "")">
                                    <ip-address ip="@player.IpAddress" country-code="@Model.Intelligence.CountryCode" risk="@(Model.Intelligence.ProxyCheck?.RiskScore ?? 0)" is-proxy="@(Model.Intelligence.ProxyCheck?.IsProxy ?? false)" is-vpn="@(Model.Intelligence.ProxyCheck?.IsVpn ?? false)" proxy-type="@(Model.Intelligence.ProxyCheck?.ProxyType ?? "")"></ip-address>
                                </span>
                            </dd>
                        </div>
                        <div class="detail-field col-sm-12">
                            <dt class="detail-label">Country/City</dt>
                            <dd class="detail-value"><location-summary intelligence-model="@Model.Intelligence"></location-summary></dd>
                        </div>
                    }
                    <div class="detail-field col-sm-6">
                        <dt class="detail-label">First Seen</dt>
                        <dd class="detail-value"><i class="fa-solid fa-fw fa-clock" aria-hidden="true"></i> <time user-time utc="@player.FirstSeen"></time></dd>
                    </div>
                    <div class="detail-field col-sm-6">
                        <dt class="detail-label">Last Seen</dt>
                        <dd class="detail-value"><i class="fa-solid fa-fw fa-clock" aria-hidden="true"></i> <time user-time utc="@player.LastSeen"></time></dd>
                    </div>
                </dl>

                <h6 class="mt-3 mb-2 text-muted text-uppercase small fw-bold">Admin History</h6>
                <div class="player-admin-summary">
                    <dl class="detail-fields row mb-0">
                        @if (banCount > 0)
                        {
                            <div class="detail-field col-6">
                                <dt class="detail-label"><i class="fa-solid fa-fw fa-ban text-danger" aria-hidden="true"></i> Bans</dt>
                                <dd class="detail-value">@banCount</dd>
                            </div>
                        }
                        @if (tempBanCount > 0)
                        {
                            <div class="detail-field col-6">
                                <dt class="detail-label"><i class="fa-solid fa-fw fa-clock text-danger" aria-hidden="true"></i> Temp Bans</dt>
                                <dd class="detail-value">@tempBanCount</dd>
                            </div>
                        }
                        @if (kickCount > 0)
                        {
                            <div class="detail-field col-6">
                                <dt class="detail-label"><i class="fa-solid fa-fw fa-arrow-right-from-bracket text-info" aria-hidden="true"></i> Kicks</dt>
                                <dd class="detail-value">@kickCount</dd>
                            </div>
                        }
                        @if (warningCount > 0)
                        {
                            <div class="detail-field col-6">
                                <dt class="detail-label"><i class="fa-solid fa-fw fa-triangle-exclamation text-warning" aria-hidden="true"></i> Warnings</dt>
                                <dd class="detail-value">@warningCount</dd>
                            </div>
                        }
                        @if (observationCount > 0)
                        {
                            <div class="detail-field col-6">
                                <dt class="detail-label"><i class="fa-solid fa-fw fa-eye text-primary" aria-hidden="true"></i> Observations</dt>
                                <dd class="detail-value">@observationCount</dd>
                            </div>
                        }
                        @if (banCount == 0 && tempBanCount == 0 && kickCount == 0 && warningCount == 0 && observationCount == 0)
                        {
                            <div class="detail-field col-12">
                                <dd class="detail-value text-muted">No admin actions</dd>
                            </div>
                        }
                    </dl>
                </div>
            </div>
        </div>

        <!-- IP Intelligence -->
        <div class="ibox">
            <div class="ibox-title"><h5>IP Intelligence</h5></div>
            <div class="ibox-content">
                @if (Model.Intelligence != null)
                {
                    <div class="row mb-3">
                        <div class="col-6">
                            <div class="risk-score-gauge">
                                <div class="gauge-container">
                                    <div class="gauge" data-risk-level="@riskLevel">
                                        <span class="gauge-value">@riskScore</span>
                                    </div>
                                </div>
                                <p class="mt-2"><small class="text-muted">Risk Score</small></p>
                            </div>
                        </div>
                        <div class="col-6">
                            <dl class="detail-fields mb-0">
                                @if (Model.Intelligence.ProxyCheck?.IsProxy == true)
                                {
                                    <div class="detail-field">
                                        <dd class="detail-value"><span class="badge bg-danger">Proxy</span></dd>
                                    </div>
                                }
                                @if (Model.Intelligence.ProxyCheck?.IsVpn == true)
                                {
                                    <div class="detail-field">
                                        <dd class="detail-value"><span class="badge bg-warning text-dark">VPN</span></dd>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(Model.Intelligence.ProxyCheck?.ProxyType))
                                {
                                    <div class="detail-field">
                                        <dt class="detail-label">Type</dt>
                                        <dd class="detail-value">@Model.Intelligence.ProxyCheck.ProxyType</dd>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(Model.Intelligence.CountryCode))
                                {
                                    <div class="detail-field">
                                        <dt class="detail-label">Country</dt>
                                        <dd class="detail-value">
                                            <img src="/images/flags/@(Model.Intelligence.CountryCode.ToLower()).png" alt="@Model.Intelligence.CountryCode" />
                                            @Model.Intelligence.CountryCode
                                        </dd>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(Model.Intelligence.CityName))
                                {
                                    <div class="detail-field">
                                        <dt class="detail-label">City</dt>
                                        <dd class="detail-value">@Model.Intelligence.CityName</dd>
                                    </div>
                                }
                            </dl>
                        </div>
                    </div>
                }
                <div id="map" class="player-location-map"></div>
                <div class="text-end mt-2">
                    <small><a target="_blank" href="https://www.geo-location.net/">Powered by geo-location.net</a></small>
                </div>
            </div>
        </div>

    </div>

    <div class="col-12 col-lg-8 mb-8 mb-lg-0">
        <div class="ibox">
            <div class="ibox-title"><h5>Player Data</h5></div>
            <div class="ibox-content">

                <ul class="nav nav-tabs nav-tabs-responsive" id="playerDetailsTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <a class="nav-link active" id="aliases-tab" data-bs-toggle="tab" href="#aliases" role="tab" aria-controls="aliases" aria-selected="true">Aliases <span class="badge bg-secondary ms-1">@(player.AliasCount)</span></a>
                    </li>
                    <li class="nav-item" role="presentation">
                        <a class="nav-link" id="ipAddresses-tab" data-bs-toggle="tab" href="#ipAddresses" role="tab" aria-controls="ipAddresses" aria-selected="false">IP History <span class="badge bg-secondary ms-1">@(player.IpAddressCount)</span></a>
                    </li>
                    <li class="nav-item" role="presentation">
                        <a class="nav-link" id="protectedNames-tab" data-bs-toggle="tab" href="#protectedNames" role="tab" aria-controls="protectedNames" aria-selected="false">Protected Names <span class="badge bg-secondary ms-1">@(player.ProtectedNameCount)</span></a>
                    </li>
                    <li class="nav-item" role="presentation">
                        <a class="nav-link" id="playerTags-tab" data-bs-toggle="tab" href="#playerTags" role="tab" aria-controls="playerTags" aria-selected="false">Tags <span class="badge bg-secondary ms-1">@(player.TagCount)</span></a>
                    </li>
                    <li class="nav-item" role="presentation">
                        <a class="nav-link" id="chatLog-tab" data-bs-toggle="tab" href="#chatLog" role="tab" aria-controls="chatLog" aria-selected="false">ChatLog</a>
                    </li>
                </ul>

                <div class="tab-content">
                    <div class="ibox-content tab-pane container fade show active" id="aliases" role="tabpanel" aria-labelledby="aliases-tab">
                        <div class="table-responsive">
                            <table id="aliasesTable" class="table table-striped table-hover w-100">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th class="table-date-col">Added</th>
                                        <th class="table-date-col">Last Used</th>
                                        <th data-bs-toggle="tooltip" data-bs-placement="bottom" title="Confidence is determined by the amount of times that the Alias has been linked to the GUID">
                                            Confidence
                                        </th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (player.PlayerAliases != null)
                                    {
                                        @foreach (var aliasDto in player.PlayerAliases)
                                        {
                                        <tr>
                                            <td><player-name value="@aliasDto.Name"></player-name></td>
                                            <td><time user-time utc="@aliasDto.Added"></time></td>
                                            <td><time user-time utc="@aliasDto.LastUsed"></time></td>
                                            <td><confidence-label score="@aliasDto.ConfidenceScore" last-used="@aliasDto.LastUsed"></confidence-label></td>
                                        </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="ibox-content tab-pane container fade" id="ipAddresses" role="tabpanel" aria-labelledby="ipAddresses-tab">
                        @if (player.IpAddressCount > 10)
                        {
                            <div class="alert alert-info mb-2">
                                <i class="fa-solid fa-fw fa-circle-info" aria-hidden="true"></i> Showing 10 of @(player.IpAddressCount) IP addresses
                            </div>
                        }
                        <div class="table-responsive">
                            <table id="ipAddressesTable" class="table table-striped table-hover w-100">
                                <thead>
                                    <tr>
                                        <th>Address</th>
                                        <th class="table-date-col">Added</th>
                                        <th class="table-date-col">Last Used</th>
                                        <th data-bs-toggle="tooltip" data-bs-placement="bottom" title="Confidence is determined by the amount of times that the IP Address has been linked to the GUID">
                                            Confidence
                                        </th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.EnrichedIpAddresses != null)
                                    {
                                        @foreach (var ipAddress in Model.EnrichedIpAddresses)
                                        {
                                        <tr>
                                            <td class="ip-address-container"
                                              data-ip="@ipAddress.Address"
                                              data-risk="@ipAddress.RiskScore"
                                              data-is-proxy="@ipAddress.IsProxy.ToString().ToLower()"
                                              data-is-vpn="@ipAddress.IsVpn.ToString().ToLower()"
                                              data-type="@ipAddress.ProxyType"
                                              data-country-code="@ipAddress.CountryCode">
                                                <img src="/images/flags/@(ipAddress.CountryCode != "unknown" ? ipAddress.CountryCode.ToLower() : "unknown").png" alt="" /> @ipAddress.Address
                                            </td>
                                            <td><time user-time utc="@ipAddress.IpAddressDto.Added"></time></td>
                                            <td><time user-time utc="@ipAddress.IpAddressDto.LastUsed"></time></td>
                                            <td><confidence-label score="@ipAddress.IpAddressDto.ConfidenceScore" last-used="@ipAddress.IpAddressDto.LastUsed"></confidence-label></td>
                                        </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="ibox-content tab-pane container fade" id="protectedNames" role="tabpanel" aria-labelledby="protectedNames-tab">
                        @if (player.ProtectedNames != null && player.ProtectedNames.Any())
                        {
                            <div class="table-responsive">
                                <table id="protectedNamesTable" class="table table-striped table-hover w-100">
                                    <thead>
                                        <tr>
                                            <th>Name</th>
                                            <th class="table-date-col">Created</th>
                                            <th>Created By</th>
                                            <th class="table-action-col">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var protectedName in player.ProtectedNames)
                                        {
                                            <tr>
                                                <td><player-name value="@protectedName.Name"></player-name></td>
                                                <td><time user-time utc="@protectedName.CreatedOn"></time></td>
                                                <td>@protectedName.CreatedByUserProfile?.DisplayName</td>
                                                <td>
                                                    <div class="btn-group btn-group-sm" role="group">
                                                        <a policy="@AuthPolicies.Players_ProtectedNames_Write" asp-controller="ProtectedNames" asp-action="Report" asp-route-id="@protectedName.ProtectedNameId" class="btn btn-outline-secondary btn-sm" title="Usage Report" aria-label="Usage Report">
                                                            <i class="fa-solid fa-fw fa-flag" aria-hidden="true"></i>
                                                        </a>
                                                        <a policy="@AuthPolicies.Players_ProtectedNames_Write" asp-controller="ProtectedNames" asp-action="Delete" asp-route-id="@protectedName.ProtectedNameId" class="btn btn-outline-danger btn-sm"
                                                           data-confirm="Are you sure you want to delete this protected name?" title="Delete" aria-label="Delete">
                                                            <i class="fa-solid fa-fw fa-trash" aria-hidden="true"></i>
                                                        </a>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                            <p>
                                <a policy="@AuthPolicies.Players_ProtectedNames_Write" asp-controller="ProtectedNames" asp-action="Add" asp-route-id="@player.PlayerId" class="btn btn-primary">
                                    <i class="fa-solid fa-fw fa-plus" aria-hidden="true"></i> Add Another Protected Name
                                </a>
                            </p>
                        }
                        else
                        {
                            <div class="alert alert-info">
                                This player has no protected names.
                            </div>
                            <p>
                                <a policy="@AuthPolicies.Players_ProtectedNames_Write" asp-controller="ProtectedNames" asp-action="Add" asp-route-id="@player.PlayerId" class="btn btn-primary">
                                    <i class="fa-solid fa-fw fa-plus" aria-hidden="true"></i> Add Protected Name
                                </a>
                            </p>
                        }
                    </div>
                    <div class="ibox-content tab-pane container fade" id="playerTags" role="tabpanel" aria-labelledby="playerTags-tab">
                        @await Component.InvokeAsync("PlayerTags", new { playerId = player.PlayerId })
                    </div>

                    <div class="ibox-content tab-pane container fade" id="chatLog" role="tabpanel" aria-labelledby="chatLog-tab">
                        <div class="list-filters mb-2" id="chatLogFilters">
                            <div class="filter-group">
                                <label for="filterLocked" class="form-label">Locked</label>
                                <select id="filterLocked" class="form-select">
                                    <option value="">All</option>
                                    <option value="true">Locked Only</option>
                                </select>
                            </div>
                            <div class="filter-group">
                                <label class="form-label" for="resetFilters">Reset</label>
                                <button type="button" id="resetFilters" class="btn btn-outline-secondary btn-sm">Reset Filters</button>
                            </div>
                        </div>
                        @{
                            ViewData["ChatLogDataUrl"] = $"/ServerAdmin/GetPlayerChatLog/{Model?.Player?.PlayerId.ToString() ?? Guid.Empty.ToString()}";
                            ViewData["ChatLogShowServer"] = true;
                            ViewData["ChatLogTitle"] = "Player ChatLog";
                        }
                        <partial name="_ChatLogTable" />
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

<!-- Related Players -->
@if (Model?.EnrichedRelatedPlayers != null && Model.EnrichedRelatedPlayers.Count != 0)
{
<div class="row">
    <div class="col-12">
        <div class="ibox">
            <div class="ibox-title"><h5>Related Players <span class="badge bg-secondary ms-1">@(player.RelatedPlayerCount)</span></h5></div>
            <div class="ibox-content">
                <p class="text-muted small mb-2">
                    <i class="fa-solid fa-fw fa-circle-info" aria-hidden="true"></i>
                    Players linked by shared IP address history. Sorted by ban status, then by number of shared IPs.
                </p>
                <div class="table-responsive">
                    <table class="table table-striped table-hover w-100" id="relatedPlayersTable">
                        <thead>
                            <tr>
                                <th>Player Name</th>
                                <th>Linking IP</th>
                                <th class="table-date-col">IP Last Used (Player)</th>
                                <th class="table-date-col">IP Last Used (Related)</th>
                                <th>Shared IPs</th>
                                <th class="table-date-col">Last Seen</th>
                                <th>Actions</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var related in Model.EnrichedRelatedPlayers)
                            {
                                <tr>
                                    <td>
                                        <span class="player-name"
                                              data-game-type="@related.GameType"
                                              data-username="@related.Username"
                                              data-player-id="@related.PlayerId"></span>
                                    </td>
                                    <td>
                                        <code>@related.LinkingIpAddress</code>
                                        @if (related.IsCurrentIp)
                                        {
                                            <span class="badge bg-info text-dark ms-1">Current</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary ms-1">Historical</span>
                                        }
                                    </td>
                                    <td><time user-time utc="@related.LinkingIpLastUsedByPlayer"></time></td>
                                    <td><time user-time utc="@related.LinkingIpLastUsedByRelated"></time></td>
                                    <td>
                                        @if (related.SharedIpCount > 1)
                                        {
                                            <span class="badge bg-warning text-dark" data-bs-toggle="tooltip" title="@related.SharedIpCount distinct IPs shared between these players">@related.SharedIpCount</span>
                                        }
                                        else
                                        {
                                            <span>1</span>
                                        }
                                    </td>
                                    <td><time user-time utc="@related.LastSeen"></time></td>
                                    <td>
                                        @if (related.AdminActionCount > 0)
                                        {
                                            <span class="badge bg-warning text-dark">@related.AdminActionCount</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">0</span>
                                        }
                                    </td>
                                    <td>
                                        @if (related.HasActiveBan)
                                        {
                                            <span class="badge bg-danger">Banned</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">OK</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
}

<!-- Admin Actions -->
<div class="row">
    <div class="col-12">
        @await Component.InvokeAsync("AdminActions", new { adminActions = player.AdminActions, linkToPlayer = false, playerDto = player })
    </div>
</div>
}

</div>

@* ReSharper disable once Razor.SectionNotResolved *@

@section scripts {
    <form id="__af" method="post" class="af-hidden">@Html.AntiForgeryToken()</form>
    <script type="text/javascript">

        $(document).ready(function() {
            // Initialize Bootstrap 5 tooltips
            const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.map(function (tooltipTriggerEl) { return new bootstrap.Tooltip(tooltipTriggerEl); });

            // Recalculate DataTable columns when its tab becomes visible (uses unified chatlog-index.js table #dataTable)
            document.querySelectorAll('a[data-bs-toggle="tab"]').forEach(function (el) {
                el.addEventListener('shown.bs.tab', function (e) {
                    if (e.target && e.target.id === 'chatLog-tab') {
                        var tbl = $('#dataTable').DataTable();
                        tbl.columns.adjust();
                        if (tbl.responsive) tbl.responsive.recalc();
                    }
                });
            });
        });

        // Initialize Google Map with player location
        function initMap() {
            @if (Model?.Intelligence != null && Model.Intelligence.Latitude.HasValue && Model.Intelligence.Longitude.HasValue)
            {
                <text>
                    var myLatLng = {
                        lat: @Model.Intelligence.Latitude,
                        lng: @Model.Intelligence.Longitude
                    };

                    var map = new google.maps.Map(document.getElementById('map'),
                        {
                            zoom: 4,
                            center: myLatLng
                        });

                    new google.maps.Marker({
                        position: myLatLng,
                        map: map,
                        title: 'Player Location'
                    });
                </text>
            }
        }

    </script>

    @{
        var mapsApiKey = Configuration["Google:MapsApiKey"];
        var isValidMapsApiKey = !string.IsNullOrEmpty(mapsApiKey) && System.Text.RegularExpressions.Regex.IsMatch(mapsApiKey, @"^[A-Za-z0-9_-]+$", System.Text.RegularExpressions.RegexOptions.None, TimeSpan.FromSeconds(1));
    }
    @if (isValidMapsApiKey)
    {
        <script async defer src="https://maps.googleapis.com/maps/api/js?key=@mapsApiKey&signed_in=false&callback=initMap"></script>
    }
    <script src="~/js/chatlog-index.js" asp-append-version="true"></script>
    <script src="~/js/player-details-tables.js" asp-append-version="true"></script>
    <script>
        // Copy to clipboard via data attributes
        document.addEventListener('click', function(e) {
            var btn = e.target.closest('[data-copy-target]');
            if (!btn) return;
            var targetId = btn.getAttribute('data-copy-target');
            var element = document.getElementById(targetId);
            if (!element) return;
            var text = element.textContent || element.innerText;

            if (navigator.clipboard && window.isSecureContext) {
                navigator.clipboard.writeText(text).then(function() {
                    showCopyFeedback(btn);
                });
            } else {
                var textArea = document.createElement("textarea");
                textArea.value = text;
                textArea.style.position = "fixed";
                textArea.style.left = "-999999px";
                textArea.style.top = "-999999px";
                document.body.appendChild(textArea);
                textArea.focus();
                textArea.select();

                try {
                    document.execCommand('copy');
                    showCopyFeedback(btn);
                } catch (err) {
                    console.error('Could not copy text: ', err);
                }

                document.body.removeChild(textArea);
            }
        });

        function showCopyFeedback(icon) {
            var originalClass = icon.className;
            icon.className = 'fa-solid fa-fw fa-check cursor-pointer text-success';
            setTimeout(function() {
                icon.className = originalClass;
            }, 2000);
        }

        $(document).ready(function () {
            // Format all IP addresses with intelligence data
            $('.ip-address-container').each(function() {
                var container = $(this);
                var ip = container.data('ip');
                var risk = container.data('risk') || 0;
                var isProxy = container.data('is-proxy') === 'true';
                var isVpn = container.data('is-vpn') === 'true';
                var type = container.data('type') || '';
                var countryCode = container.data('country-code') || '';

                container.html(formatIPAddress(ip, risk, isProxy, isVpn, type, countryCode));
            });

            // Render related players using global helper (renderPlayerName) for consistency
            $('#relatedPlayersTable .player-name').each(function() {
                var el = $(this);
                var gameType = parseInt(el.data('game-type'));
                var username = el.data('username');
                var playerId = el.data('player-id');
                try {
                    el.html(renderPlayerName(gameType, username, playerId));
                } catch (e) {
                    el.text(username);
                }
            });
        });
    </script>
}
