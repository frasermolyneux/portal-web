@using XtremeIdiots.Portal.Repository.Abstractions.Models.V1.Demos
@model DemoDto

@{
    ViewData["Title"] = "Delete Demo";
}

<div class="wrapper wrapper-content animated fadeInRight">

    <div class="row">
        <div class="col-12">

            <div class="container-fluid">
                <div class="ibox">
                    <div class="ibox-title">
                        <h5>@ViewData["Title"]</h5>
                    </div>
                    <div class="ibox-content">
                        <p>Are you sure you want to delete this demo?</p>
                        <div class="alert alert-warning mb-3">
                            <i class="fa-solid fa-fw fa-triangle-exclamation" aria-hidden="true"></i>
                            This action cannot be undone. The demo recording and associated files will be permanently removed from storage.
                        </div>
                        <dl class="detail-fields row">
                            <div class="detail-field col-sm-6">
                                <dt class="detail-label">@Html.DisplayNameFor(model => model.Title)</dt>
                                <dd class="detail-value">@Html.DisplayFor(model => model.Title)</dd>
                            </div>
                            <div class="detail-field col-sm-6">
                                <dt class="detail-label">@Html.DisplayNameFor(model => model.FileName)</dt>
                                <dd class="detail-value">@Html.DisplayFor(model => model.FileName)</dd>
                            </div>
                            <div class="detail-field col-sm-6">
                                <dt class="detail-label">@Html.DisplayNameFor(model => model.UserProfile!.DisplayName)</dt>
                                <dd class="detail-value">@Html.DisplayFor(model => model.UserProfile!.DisplayName)</dd>
                            </div>
                            <div class="detail-field col-sm-6">
                                <dt class="detail-label">@Html.DisplayNameFor(model => model.Created)</dt>
                                <dd class="detail-value">@Html.DisplayFor(model => model.Created)</dd>
                            </div>
                        </dl>
                    </div>
                    <div class="ibox-footer">
                        <form asp-action="Delete">
                            <input type="hidden" asp-for="DemoId" />
                            <input name="filterGame" type="hidden" value="@(ViewData["FilterGame"]?.ToString() ?? string.Empty)" />
                            <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
                            <button class="btn btn-danger" type="submit">
                                <i class="fa-solid fa-fw fa-trash"></i> Delete Demo
                            </button>
                        </form>
                    </div>
                </div>
            </div>

        </div>
    </div>

</div>

@* ReSharper disable once Razor.SectionNotResolved *@

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}