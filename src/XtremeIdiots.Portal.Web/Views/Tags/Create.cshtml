@model XtremeIdiots.Portal.Web.ViewModels.CreateTagViewModel

@{
    ViewData["Title"] = "Create Tag";
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox">
                <div class="ibox-title">
                    <h5>Create New Tag</h5>
                </div>
                <div class="ibox-content">
                    <form asp-action="Create" method="post" id="createTagForm">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label"></label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="TagHtml" class="form-label"></label>
                            <textarea asp-for="TagHtml" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="TagHtml" class="text-danger"></span>
                            <small class="form-text">HTML that will be displayed as the tag (e.g., &lt;span
                                class="badge bg-primary"&gt;VIP&lt;/span&gt;)</small>
                        </div>

                        <div class="mb-3">
                            <div class="form-check">
                                <input asp-for="UserDefined" class="form-check-input" />
                                <label asp-for="UserDefined" class="form-check-label">Users can assign this tag to players</label>
                            </div>
                            <small class="form-text">If checked, users can add and remove this tag from
                                players on the player details page.</small>
                        </div>
                    </form>
                </div>
                <div class="ibox-footer">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="fa-solid fa-fw fa-arrow-left" aria-hidden="true"></i> Back to List
                    </a>
                    <button type="submit" form="createTagForm" class="btn btn-primary">
                        <i class="fa-solid fa-fw fa-plus" aria-hidden="true"></i> Create
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
