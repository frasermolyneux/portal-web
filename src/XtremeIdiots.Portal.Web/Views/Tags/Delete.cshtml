@model XtremeIdiots.Portal.Repository.Abstractions.Models.V1.Tags.TagDto

@{
    ViewData["Title"] = "Delete Tag";
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox">
                <div class="ibox-title">
                    <h5>Delete Tag</h5>
                </div>
                <div class="ibox-content">
                    <h3>Are you sure you want to delete this tag?</h3>
                    <div class="alert alert-warning">
                        <p>Deleting this tag will remove it from all players it is currently assigned to.</p>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <dl class="detail-fields">
                                <div class="detail-field">
                                    <dt class="detail-label">Name</dt>
                                    <dd class="detail-value">@Model.Name</dd>
                                </div>
                                <div class="detail-field">
                                    <dt class="detail-label">Description</dt>
                                    <dd class="detail-value">@Model.Description</dd>
                                </div>
                                <div class="detail-field">
                                    <dt class="detail-label">Tag Preview</dt>
                                    <dd class="detail-value">@Html.Raw(Model.TagHtml)</dd>
                                </div>
                            </dl>
                        </div>
                    </div>

                    <form asp-action="Delete" method="post" id="deleteTagForm">
                        <input type="hidden" name="id" value="@Model.TagId" />
                    </form>
                </div>
                <div class="ibox-footer">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="fa-solid fa-fw fa-arrow-left" aria-hidden="true"></i> Back to List
                    </a>
                    <button type="submit" form="deleteTagForm" class="btn btn-danger">
                        <i class="fa-solid fa-fw fa-trash" aria-hidden="true"></i> Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
