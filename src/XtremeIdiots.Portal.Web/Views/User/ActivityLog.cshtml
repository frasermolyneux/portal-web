@using XtremeIdiots.Portal.Web.Models.ActivityLog
@{
    ViewData["Title"] = "Activity Log";
}

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="alert alert-info" role="alert">
        <i class="fa-solid fa-circle-info"></i> Activity log shows user actions tracked via Application Insights. Data is subject to the configured retention period.
    </div>

    <div class="activity-log-filters mb-3" id="activityLogFilters">
        <div class="filter-group">
            <label for="filterTimeRange" class="form-label">Time Range</label>
            <select id="filterTimeRange" class="form-select">
                <option value="1h">Last 1 hour</option>
                <option value="6h">Last 6 hours</option>
                <option value="12h">Last 12 hours</option>
                <option value="24h" selected>Last 24 hours</option>
                <option value="7d">Last 7 days</option>
                <option value="30d">Last 30 days</option>
            </select>
        </div>

        <div class="filter-group">
            <label for="filterCategory" class="form-label">Categories</label>
            <select id="filterCategory" class="form-select" multiple size="4">
                @foreach (var cat in Enum.GetValues<ActivityLogCategory>())
                {
                    <option value="@cat">@cat</option>
                }
            </select>
        </div>

        <div class="filter-group">
            <label for="filterEventName" class="form-label">Events</label>
            <select id="filterEventName" class="form-select" multiple size="4">
            </select>
        </div>

        <div class="filter-group">
            <div class="form-check mt-4">
                <input class="form-check-input" type="checkbox" id="filterIncludeReads">
                <label class="form-check-label" for="filterIncludeReads">
                    Include read events
                </label>
            </div>
        </div>

        <div class="filter-group reset-group">
            <label class="form-label" for="resetFilters">Reset</label>
            <button type="button" id="resetFilters" class="btn btn-outline-secondary btn-sm">Clear Filters</button>
        </div>
    </div>

    <div class="ibox">
        <div class="ibox-title">
            <i class="fa-solid fa-clipboard-list"></i> @ViewData["Title"]
        </div>
        <div class="ibox-content">
            <div class="table-responsive">
                <table id="dataTable" class="table table-striped table-hover w-100">
                    <thead>
                        <tr>
                            <th>Timestamp</th>
                            <th>Category</th>
                            <th>Event</th>
                            <th>User</th>
                            <th>Source</th>
                            <th>Details</th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <form id="__af" method="post" style="display:none">@Html.AntiForgeryToken()</form>
    <script src="~/js/activity-log.js" asp-append-version="true"></script>
}
