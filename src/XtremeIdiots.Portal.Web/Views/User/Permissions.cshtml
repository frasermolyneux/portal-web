@{
    ViewData["Title"] = "Permissions Overview";
}

<div class="wrapper wrapper-content animated fadeInRight">

    <div class="ibox">
        <div class="ibox-title"><h5>@ViewData["Title"]</h5></div>
        <div class="ibox-content">
            <p>
                Permissions in the XtremeIdiots Portal come from two sources:
            </p>
            <ul>
                <li><strong>Role claims</strong> — automatically assigned based on your forum group membership (Senior Admin, Head Admin, Game Admin, Moderator)</li>
                <li><strong>Additional permissions</strong> — manually assigned by head admins, scoped to specific game types or servers</li>
            </ul>
            <p>
                To see all currently assigned permissions across all users, visit the
                <a href="@Url.ActionLink("PermissionsReport", "User")">
                    <i class="fa-solid fa-fw fa-shield-halved" aria-hidden="true"></i> Permissions Report
                </a>.
            </p>
        </div>
    </div>

    <div class="ibox">
        <div class="ibox-title"><h5>Role Hierarchy</h5></div>
        <div class="ibox-content">
            <div class="row">
                <div class="col-md-6 col-lg-3 mb-3">
                    <div class="ibox">
                        <div class="ibox-title">
                            <div class="ibox-tools">
                                <span class="badge bg-danger float-end">Senior Admin</span>
                            </div>
                            <h5>Senior Admin</h5>
                        </div>
                        <div class="ibox-content">
                            <p>No restrictions — full access to everything across all game types and servers.</p>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 col-lg-3 mb-3">
                    <div class="ibox">
                        <div class="ibox-title">
                            <div class="ibox-tools">
                                <span class="badge bg-warning float-end">Head Admin</span>
                            </div>
                            <h5>Head Admin</h5>
                        </div>
                        <div class="ibox-content">
                            <p>Full admin for their assigned game type(s). Can manage users, credentials, FTP/RCON config, ban file monitors, and all operations for their game.</p>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 col-lg-3 mb-3">
                    <div class="ibox">
                        <div class="ibox-title">
                            <div class="ibox-tools">
                                <span class="badge bg-success float-end">Game Admin</span>
                            </div>
                            <h5>Game Admin</h5>
                        </div>
                        <div class="ibox-content">
                            <p>Admin for their assigned game type(s). Can manage map rotations, maps, admin actions, view RCON and chat logs. Cannot manage credentials or FTP/RCON config.</p>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 col-lg-3 mb-3">
                    <div class="ibox">
                        <div class="ibox-title">
                            <div class="ibox-tools">
                                <span class="badge bg-secondary float-end">Moderator</span>
                            </div>
                            <h5>Moderator</h5>
                        </div>
                        <div class="ibox-content">
                            <p>Limited admin for their assigned game type(s). Can create observations/warnings/kicks, view players and server chat logs. Cannot manage maps, rotations, or server config.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="ibox">
        <div class="ibox-title"><h5>Additional Permissions</h5></div>
        <div class="ibox-content">
            <p>
                Head admins can assign additional permissions to users, scoped to specific game types or servers.
                These are separate from the role claims that come from forum groups and persist independently.
            </p>
        </div>
    </div>

    @foreach (var domainGroup in AdditionalPermission.Definitions.GroupBy(d => d.Domain))
    {
        <div class="ibox">
            <div class="ibox-title"><h5>@domainGroup.Key</h5></div>
            <div class="ibox-content">
                @foreach (var subGroup in domainGroup.GroupBy(d => d.SubDomain))
                {
                    if (!string.IsNullOrEmpty(subGroup.Key))
                    {
                        <h6 class="text-muted mt-3">@subGroup.Key</h6>
                    }
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Permission</th>
                                    <th>Description</th>
                                    <th>Scope</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var perm in subGroup)
                                {
                                    <tr>
                                        <td><code>@perm.ClaimType</code><br /><small>@perm.DisplayName</small></td>
                                        <td>@perm.Description</td>
                                        <td><span class="badge bg-secondary">@perm.Scope</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }

</div>