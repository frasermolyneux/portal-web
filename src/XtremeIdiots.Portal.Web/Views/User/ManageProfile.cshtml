@using XtremeIdiots.Portal.Web.ViewModels
@using XtremeIdiots.Portal.Repository.Abstractions.Models.V1;
@using XtremeIdiots.Portal.Repository.Abstractions.Models.V1.GameServers
@using XtremeIdiots.Portal.Repository.Abstractions.Models.V1.UserProfiles
@using XtremeIdiots.Portal.Repository.Abstractions.Constants.V1
@model XtremeIdiots.Portal.Web.ViewModels.ManageUserProfileViewModel

@{
    ViewData["Title"] = "Manage User Profile - " + Model.Profile.DisplayName;

    var gameServers = (List<GameServerDto>?)ViewData["GameServers"] ?? new List<GameServerDto>();
}

<div class="wrapper wrapper-content animated fadeInRight">

    <div class="alert alert-primary" role="alert">
        <i class="fa-solid fa-fw fa-circle-info"></i> To understand how the permissions work and what the additional permissions
        mean please see the <a href="@Url.ActionLink("Permissions", "User")">Permissions Overview</a>
    </div>

    <div class="mb-3">
        <a asp-action="ManageNotifications" asp-route-id="@Model.Profile.UserProfileId" class="btn btn-outline-primary">
            <i class="fa-solid fa-fw fa-bell"></i> Manage Notifications
        </a>
    </div>

    <div class="row">
        <div class="col-12 col-lg-6">

            <div class="container-fluid">
                <div class="ibox">
                    <div class="ibox-title">
                        @ViewData["Title"]
                    </div>
                    <div class="ibox-content">
                        <dl class="row">
                            <dt class="col-sm-3">Display Name</dt>
                            <dd class="col-sm-9">@Model.Profile.DisplayName</dd>
                            <dt class="col-sm-3">Email</dt>
                            <dd class="col-sm-9">@Model.Profile.Email</dd>
                            <dt class="col-sm-3">Forum Id</dt>
                            <dd class="col-sm-9">@Model.Profile.XtremeIdiotsForumId</dd>
                            <dt class="col-sm-3">Profile Id</dt>
                            <dd class="col-sm-9">@Model.Profile.UserProfileId</dd>
                        </dl>
                    </div>
                </div>
            </div>

        </div>

        <div class="col-12 col-lg-6">

            <div class="container-fluid">
                <div class="ibox">
                    <div class="ibox-title"><h5>Identity Details</h5></div>
                    <div class="ibox-content">
                        @if (Model.Identity is null)
                        {
                            <div class="alert alert-warning mb-0">No linked Identity user found.</div>
                        }
                        else
                        {
                            <dl class="row mb-0">
                                <dt class="col-sm-4">Email Confirmed</dt>
                                <dd class="col-sm-8">@(Model.Identity.EmailConfirmed ? "Yes" : "No")</dd>
                                <dt class="col-sm-4">Two Factor</dt>
                                <dd class="col-sm-8">@(Model.Identity.TwoFactorEnabled ? "Enabled" : "Disabled")</dd>
                                <dt class="col-sm-4">Lockout Enabled</dt>
                                <dd class="col-sm-8">@(Model.Identity.LockoutEnabled ? "Yes" : "No")</dd>
                                <dt class="col-sm-4">Lockout End</dt>
                                <dd class="col-sm-8">@if (Model.Identity.LockoutEnd.HasValue) { <time user-time utc="@Model.Identity.LockoutEnd.Value.UtcDateTime"></time> } else { <text>-</text> }</dd>
                                <dt class="col-sm-4">Access Failed Count</dt>
                                <dd class="col-sm-8">@Model.Identity.AccessFailedCount</dd>
                                <dt class="col-sm-4">Phone</dt>
                                <dd class="col-sm-8">@Model.Identity.PhoneNumber</dd>
                                <dt class="col-sm-4">Phone Confirmed</dt>
                                <dd class="col-sm-8">@(Model.Identity.PhoneNumberConfirmed ? "Yes" : "No")</dd>
                            </dl>
                        }
                    </div>
                </div>
            </div>

        </div>

    </div>

    <div class="row">
        <div class="col-12">

            <div class="container-fluid">
                <div class="ibox">
                    <div class="ibox-title"><h5>Add Additional Portal Permission</h5></div>
                    <div policy="@AuthPolicies.Users_ManageClaims" class="ibox-content">
                        <form asp-action="CreateUserClaim" id="createClaimForm">
                            <input id="id" name="id" type="hidden" value="@Model.Profile.UserProfileId" />
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                            <div class="mb-3">
                                <label class="form-label">Permission Type</label>
                                <select name="claimType" id="claimType" class="form-select">
                                    <option value="">Select a permission...</option>
                                    @foreach (var group in Model.AvailablePermissions.GroupBy(p => new { p.Domain, p.SubDomain }))
                                    {
                                        var label = !string.IsNullOrEmpty(group.Key.SubDomain)
                                            ? $"{group.Key.Domain} — {group.Key.SubDomain}"
                                            : group.Key.Domain;
                                        <optgroup label="@label">
                                            @foreach (var perm in group)
                                            {
                                                <option value="@perm.ClaimType"
                                                        data-scope="@perm.Scope"
                                                        data-description="@perm.Description">
                                                    @perm.DisplayName
                                                </option>
                                            }
                                        </optgroup>
                                    }
                                </select>
                                <small class="form-text text-muted" id="permissionDescription"></small>
                            </div>

                            <div id="scopeSelector" class="mb-3" style="display:none;">
                                <label class="form-label">Scope</label>
                                <div id="gameScopeGroup">
                                    <select id="gameTypeSelect" class="form-select">
                                        <option value="">Select game type...</option>
                                        @foreach (var gt in Model.AssignableGameTypes)
                                        {
                                            <option value="@gt">@gt</option>
                                        }
                                    </select>
                                </div>
                                <div id="serverScopeGroup" class="mt-2" style="display:none;">
                                    <select id="serverSelect" class="form-select"
                                            asp-items="ViewBag.GameServersSelect">
                                        <option value="">Select server...</option>
                                    </select>
                                </div>
                            </div>

                            <input type="hidden" name="claimValue" id="claimValueInput" />

                            <div class="mb-3">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fa-solid fa-fw fa-plus" aria-hidden="true"></i> Add Additional Permission
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <div class="row">
        <div class="col-12">

            <div class="container-fluid">
                <div class="ibox">
                    <div class="ibox-title">
                        Additional Portal Permission
                    </div>
                    <div class="ibox-content">
                        <div class="table-responsive">
                            <table class="table table-striped table-hover w-100">
                                <thead>
                                    <tr>
                                        <th scope="col">Permission</th>
                                        <th scope="col">Scope Value</th>
                                        <th scope="col" class="table-action-col"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var claim in Model.Profile.UserProfileClaims)
                                    {
                                        <tr>
                                            @{
                                                var definition = AdditionalPermission.GetDefinition(claim.ClaimType);
                                                Guid.TryParse(claim.ClaimValue, out var gameServerId);
                                                var server = gameServers?.FirstOrDefault(s => s.GameServerId == gameServerId);
                                            }

                                            <td>@(definition?.DisplayName ?? claim.ClaimType)</td>
                                            <td>
                                                @if (server is not null)
                                                {
                                                    @server.Title
                                                }
                                                else
                                                {
                                                    @claim.ClaimValue
                                                }
                                            </td>
                                            <td>
                                                @if (!claim.SystemGenerated)
                                                {
                                                    <form policy="@AuthPolicies.Users_ManageClaims" class="d-inline-flex" asp-controller="User" asp-action="RemoveUserClaim"
                                                        method="post">
                                                        <input id="id" name="id" type="hidden"
                                                            value="@Model.Profile.UserProfileId" />
                                                        <input id="claimId" name="claimId" type="hidden"
                                                            value="@claim.UserProfileClaimId" />

                                                        <button class="btn btn-outline-danger btn-sm" type="submit" data-confirm="Are you sure you want to remove this permission? It may take up to 15 minutes to take effect.">
                                                            <i class="fa-solid fa-fw fa-trash" aria-hidden="true"></i> Delete
                                                        </button>
                                                    </form>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

</div>

@* ReSharper disable once Razor.SectionNotResolved *@

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        (function () {
            var claimTypeSelect = document.getElementById('claimType');
            var descriptionEl = document.getElementById('permissionDescription');
            var scopeSelector = document.getElementById('scopeSelector');
            var gameGroup = document.getElementById('gameScopeGroup');
            var serverGroup = document.getElementById('serverScopeGroup');
            var gameTypeSelect = document.getElementById('gameTypeSelect');
            var serverSelect = document.getElementById('serverSelect');
            var claimValueInput = document.getElementById('claimValueInput');

            claimTypeSelect.addEventListener('change', function () {
                var selected = this.options[this.selectedIndex];
                var scope = selected.dataset.scope;
                var desc = selected.dataset.description || '';

                descriptionEl.textContent = desc;

                if (!scope || this.value === '') {
                    scopeSelector.style.display = 'none';
                    gameTypeSelect.value = '';
                    serverSelect.value = '';
                    return;
                }

                scopeSelector.style.display = '';

                if (scope === 'Game') {
                    gameGroup.style.display = '';
                    serverGroup.style.display = 'none';
                    serverSelect.value = '';
                } else if (scope === 'Server') {
                    gameGroup.style.display = 'none';
                    serverGroup.style.display = '';
                    gameTypeSelect.value = '';
                } else {
                    // GameOrServer — show both
                    gameGroup.style.display = '';
                    serverGroup.style.display = '';
                }
            });

            document.getElementById('createClaimForm').addEventListener('submit', function (e) {
                var selected = claimTypeSelect.options[claimTypeSelect.selectedIndex];
                var scope = selected.dataset.scope;
                var gameVal = gameTypeSelect.value;
                var serverVal = serverSelect.value;

                if (!claimTypeSelect.value) {
                    e.preventDefault();
                    alert('Please select a permission type.');
                    return;
                }

                if (scope === 'Server') {
                    claimValueInput.value = serverVal;
                } else if (scope === 'Game') {
                    claimValueInput.value = gameVal;
                } else {
                    // GameOrServer: prefer game if set, else server
                    claimValueInput.value = gameVal || serverVal;
                }

                if (!claimValueInput.value) {
                    e.preventDefault();
                    alert('Please select a game type or server for this permission.');
                    return;
                }
            });
        })();
    </script>
}